---
import PortalCategory from '@components/categorias/PortalCategory.astro';
import { getCategoryPaths } from '@/utils/category-data';

export async function getStaticPaths() {
  return getCategoryPaths('en');
}

const { category, posts, alternates } = Astro.props;
---

<PortalCategory locale="en" category={category} posts={posts} alternates={alternates} />
