---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/header/Header.astro';
import Footer from '@components/footer/Footer.astro';
import { t } from '../../../i18n/translations';

const lang = 'en';
---

<BaseLayout
  title="Free Financial Tools"
  description="Free calculators and tools to organize your finances. Interest simulator, currency converter and more."
  keywords={['financial calculator', 'compound interest simulator', 'currency converter', 'financial tools']}
>
  <Header />

  <main class="ferramentas-page">
    <div class="container">
      <header class="ferramentas-header">
        <h1 class="ferramentas-title">{t(lang, 'ferramentas.title')}</h1>
        <p class="ferramentas-description">{t(lang, 'ferramentas.desc')}</p>
      </header>

      <div class="ferramentas-grid">
        <div class="ferramenta-card">
          <span class="ferramenta-badge">Coming soon</span>
          <div class="ferramenta-icon">📈</div>
          <h3 class="ferramenta-title">{t(lang, 'ferramentas.juros.title')}</h3>
          <p class="ferramenta-description">{t(lang, 'ferramentas.juros.desc')}</p>
        </div>

        <div class="ferramenta-card">
          <span class="ferramenta-badge">Coming soon</span>
          <div class="ferramenta-icon">💰</div>
          <h3 class="ferramenta-title">{t(lang, 'ferramentas.orcamento.title')}</h3>
          <p class="ferramenta-description">{t(lang, 'ferramentas.orcamento.desc')}</p>
        </div>

        <div class="ferramenta-card">
          <span class="ferramenta-badge">Coming soon</span>
          <div class="ferramenta-icon">💱</div>
          <h3 class="ferramenta-title">{t(lang, 'ferramentas.conversor.title')}</h3>
          <p class="ferramenta-description">{t(lang, 'ferramentas.conversor.desc')}</p>
        </div>

        <div class="ferramenta-card">
          <span class="ferramenta-badge">Coming soon</span>
          <div class="ferramenta-icon">🎯</div>
          <h3 class="ferramenta-title">{t(lang, 'ferramentas.simulador.title')}</h3>
          <p class="ferramenta-description">{t(lang, 'ferramentas.simulador.desc')}</p>
        </div>

        <div class="ferramenta-card">
          <span class="ferramenta-badge">Coming soon</span>
          <div class="ferramenta-icon">🛡️</div>
          <h3 class="ferramenta-title">{t(lang, 'ferramentas.emergencia.title')}</h3>
          <p class="ferramenta-description">{t(lang, 'ferramentas.emergencia.desc')}</p>
        </div>

        <div class="ferramenta-card">
          <span class="ferramenta-badge">Coming soon</span>
          <div class="ferramenta-icon">🏦</div>
          <h3 class="ferramenta-title">{t(lang, 'ferramentas.cdb.title')}</h3>
          <p class="ferramenta-description">{t(lang, 'ferramentas.cdb.desc')}</p>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .ferramentas-page { padding: var(--space-8) 0 var(--space-16); }
  .ferramentas-header { text-align: center; margin-bottom: var(--space-12); }
  .ferramentas-title { font-size: var(--text-4xl); background: var(--gradient-hero); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: var(--space-4); }
  .ferramentas-description { color: var(--text-secondary); font-size: var(--text-lg); max-width: 500px; margin: 0 auto; }
  .ferramentas-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-6); }
  @media (min-width: 640px) { .ferramentas-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .ferramentas-grid { grid-template-columns: repeat(3, 1fr); } }
  .ferramenta-card { display: block; padding: var(--space-8); background: var(--gradient-card); border: 1px solid var(--border-default); border-radius: var(--radius-xl); text-decoration: none; transition: all var(--transition-base); position: relative; }
  .ferramenta-card:hover { border-color: var(--accent-primary); transform: translateY(-4px); box-shadow: var(--shadow-glow); }
  .ferramenta-badge { position: absolute; top: var(--space-3); right: var(--space-3); padding: 2px var(--space-2); background: rgba(0, 240, 255, 0.1); color: var(--brand-cyan); border-radius: var(--radius-sm); font-size: var(--text-xs); font-weight: 600; }
  .ferramenta-icon { font-size: 2.5rem; margin-bottom: var(--space-4); }
  .ferramenta-title { font-size: var(--text-lg); color: var(--text-primary); margin-bottom: var(--space-3); }
  .ferramenta-description { font-size: var(--text-sm); color: var(--text-secondary); line-height: var(--leading-relaxed); margin-bottom: 0; }
</style>
