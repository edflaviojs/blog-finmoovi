---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/header/Header.astro';
import Footer from '@components/footer/Footer.astro';
import PostGrid from '@components/posts/PostGrid.astro';
import Sidebar from '@components/sidebar/Sidebar.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft && data.locale === 'en');
const sortedPosts = allPosts.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
const featuredPosts = sortedPosts.filter(p => p.data.featured);
const recentPosts = sortedPosts.slice(0, 9);

const heroPost = featuredPosts[0] || sortedPosts[0];
const secondaryPosts = featuredPosts.length > 1 ? featuredPosts.slice(1, 4) : sortedPosts.slice(1, 4);

const postsForGrid = recentPosts.map(post => ({
  title: post.data.title,
  description: post.data.description,
  image: post.data.image,
  href: `/en/posts/${post.slug}`,
  category: post.data.category,
  date: post.data.publishedAt.toISOString(),
  readingTime: post.data.readingTime,
}));
---

<BaseLayout
  title="FinMoovi Blog"
  description="Practical personal finance tips, expense tracking and financial education. Organize your financial life with FinMoovi."
  keywords={['personal finance', 'financial control', 'financial education', 'budget', 'investments']}
>
  <Header />

  <main>
    <section class="hero-portal">
      <div class="container">
        {heroPost && (
          <div class="hero-grid">
            <a href={`/en/posts/${heroPost.slug}`} class="hero-main">
              <div class="hero-main-image">
                {heroPost.data.image && <img src={heroPost.data.image} alt="" loading="eager" />}
                <div class="hero-main-overlay"></div>
              </div>
              <div class="hero-main-content">
                <span class="hero-category">{heroPost.data.category}</span>
                <h1 class="hero-title">{heroPost.data.title}</h1>
                <p class="hero-description">{heroPost.data.description}</p>
              </div>
            </a>
            <div class="hero-secondary">
              {secondaryPosts.map(post => (
                <a href={`/en/posts/${post.slug}`} class="hero-secondary-card">
                  <div class="hero-secondary-image">
                    {post.data.image && <img src={post.data.image} alt="" loading="eager" />}
                  </div>
                  <div class="hero-secondary-content">
                    <span class="hero-secondary-category">{post.data.category}</span>
                    <h3 class="hero-secondary-title">{post.data.title}</h3>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2 class="section-title">Latest Posts</h2>
        <div class="layout-with-sidebar">
          <div>
            <PostGrid posts={postsForGrid} columns={2} />
          </div>
          <aside class="home-sidebar">
            <Sidebar />
          </aside>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .hero-portal { padding: var(--space-8) 0; }
  .hero-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-6); }
  @media (min-width: 768px) { .hero-grid { grid-template-columns: 2fr 1fr; } }
  .hero-main { position: relative; border-radius: var(--radius-lg); overflow: hidden; display: block; text-decoration: none; min-height: 300px; }
  .hero-main-image { position: absolute; inset: 0; }
  .hero-main-image img { width: 100%; height: 100%; object-fit: cover; }
  .hero-main-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.8), transparent); }
  .hero-main-content { position: relative; padding: var(--space-8); display: flex; flex-direction: column; justify-content: flex-end; min-height: 300px; }
  .hero-category { font-size: var(--text-xs); color: var(--accent-primary); font-weight: 600; text-transform: uppercase; }
  .hero-title { font-size: var(--text-3xl); color: #fff; margin-top: var(--space-2); }
  .hero-description { font-size: var(--text-sm); color: rgba(255,255,255,0.7); margin-top: var(--space-2); }
  .hero-secondary { display: flex; flex-direction: column; gap: var(--space-4); }
  .hero-secondary-card { display: flex; gap: var(--space-3); padding: var(--space-3); background: var(--bg-secondary); border: 1px solid var(--border-default); border-radius: var(--radius-md); text-decoration: none; transition: border-color var(--transition-fast); }
  .hero-secondary-card:hover { border-color: var(--accent-primary); }
  .hero-secondary-image { width: 80px; height: 60px; border-radius: var(--radius-sm); overflow: hidden; flex-shrink: 0; }
  .hero-secondary-image img { width: 100%; height: 100%; object-fit: cover; }
  .hero-secondary-category { font-size: 10px; color: var(--accent-primary); text-transform: uppercase; font-weight: 600; }
  .hero-secondary-title { font-size: var(--text-sm); color: var(--text-primary); margin-top: 2px; line-height: 1.3; }
  .section { padding: var(--space-12) 0; }
  .section-title { font-size: var(--text-2xl); color: var(--text-primary); margin-bottom: var(--space-8); }
  .home-sidebar { display: none; }
  @media (min-width: 1024px) { .home-sidebar { display: block; } }
</style>
