---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/header/Header.astro';
import Footer from '@components/footer/Footer.astro';
import PortalHome from '@components/home/PortalHome.astro';
import { getHomeData } from '@/utils/home-data';
import { config } from '../../../site.config';
import { imgSrcset } from '@/utils/responsive-image';

// Home portal EN — invólucro fino; conteúdo compartilhado em PortalHome.
const data = await getHomeData('en');
---

<BaseLayout
  title={`${config.brand.name} ${config.brand.blogSuffix} — ${config.content.homeTitleSuffix.en}`}
  description={config.siteDescription.en}
  preloadImage={data.hero?.image}
  preloadImageSrcset={data.hero?.image ? imgSrcset(data.hero.image) : undefined}
  preloadImageSizes="(min-width: 1024px) 900px, 100vw"
>
  <Header />

  <main>
    <PortalHome locale="en" data={data} />
  </main>

  <Footer />
</BaseLayout>
