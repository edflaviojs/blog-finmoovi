---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/header/Header.astro';
import Footer from '@components/footer/Footer.astro';
---

<BaseLayout
  title="Ferramentas Financeiras Gratuitas"
  description="Calculadoras e ferramentas gratuitas para organizar suas finanças. Simulador de juros, conversor de moedas e mais."
  keywords={['calculadora financeira', 'simulador juros compostos', 'conversor moedas', 'ferramentas financeiras']}
>
  <Header />

  <main class="ferramentas-page">
    <div class="container">
      <header class="ferramentas-header">
        <h1 class="ferramentas-title">Ferramentas Financeiras</h1>
        <p class="ferramentas-description">
          Calculadoras e simuladores gratuitos para te ajudar a tomar melhores decisões financeiras.
        </p>
      </header>

      <div class="ferramentas-grid">
        <a href="/ferramentas/calculadora-juros-compostos" class="ferramenta-card active">
          <span class="ferramenta-badge live">Disponível</span>
          <div class="ferramenta-icon">📈</div>
          <h3 class="ferramenta-title">Calculadora de Juros Compostos</h3>
          <p class="ferramenta-description">Simule quanto seu dinheiro pode render ao longo do tempo com juros compostos.</p>
        </a>

        <a href="/ferramentas/calculadora-orcamento" class="ferramenta-card active">
          <span class="ferramenta-badge live">Disponível</span>
          <div class="ferramenta-icon">💰</div>
          <h3 class="ferramenta-title">Calculadora de Orçamento 50-30-20</h3>
          <p class="ferramenta-description">Monte seu orçamento usando a regra 50-30-20 de forma rápida e visual.</p>
        </a>

        <a href="/ferramentas/conversor-moedas" class="ferramenta-card active">
          <span class="ferramenta-badge live">Disponível</span>
          <div class="ferramenta-icon">💱</div>
          <h3 class="ferramenta-title">Conversor de Moedas</h3>
          <p class="ferramenta-description">Converta entre BRL, USD, EUR e outras moedas com cotação atualizada.</p>
        </a>

        <a href="/ferramentas/simulador-investimento" class="ferramenta-card active">
          <span class="ferramenta-badge live">Disponível</span>
          <div class="ferramenta-icon">🎯</div>
          <h3 class="ferramenta-title">Simulador de Investimento</h3>
          <p class="ferramenta-description">Descubra quanto precisa investir por mês para alcançar seu objetivo.</p>
        </a>

        <a href="/ferramentas/calculadora-reserva" class="ferramenta-card active">
          <span class="ferramenta-badge live">Disponível</span>
          <div class="ferramenta-icon">🛡️</div>
          <h3 class="ferramenta-title">Calculadora de Reserva</h3>
          <p class="ferramenta-description">Calcule o valor ideal da sua reserva de emergência baseado nos seus gastos.</p>
        </a>

        <a href="/ferramentas/calculadora-financiamento" class="ferramenta-card active">
          <span class="ferramenta-badge live">Disponível</span>
          <div class="ferramenta-icon">🏠</div>
          <h3 class="ferramenta-title">Calculadora de Financiamento (SAC × Price)</h3>
          <p class="ferramenta-description">Compare os sistemas SAC e Price: veja parcelas e quanto paga de juros no financiamento.</p>
        </a>

        <a href="/ferramentas/calculadora-aposentadoria" class="ferramenta-card active">
          <span class="ferramenta-badge live">Disponível</span>
          <div class="ferramenta-icon">🌴</div>
          <h3 class="ferramenta-title">Calculadora de Aposentadoria</h3>
          <p class="ferramenta-description">Descubra quanto precisa para se aposentar (regra dos 4%) e em quanto tempo chega lá.</p>
        </a>

        <div class="ferramenta-card">
          <span class="ferramenta-badge">Em breve</span>
          <div class="ferramenta-icon">🏦</div>
          <h3 class="ferramenta-title">Comparador de CDB</h3>
          <p class="ferramenta-description">Compare rendimentos de CDBs com diferentes taxas e prazos.</p>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .ferramentas-page {
    padding: var(--space-8) 0 var(--space-16);
  }

  .ferramentas-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .ferramentas-title {
    font-size: var(--text-4xl);
    letter-spacing: -0.02em;
    background: var(--portal-grad);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: var(--space-4);
  }

  .ferramentas-description {
    color: var(--text-secondary);
    font-size: var(--text-lg);
    max-width: 500px;
    margin: 0 auto;
  }

  .ferramentas-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 640px) {
    .ferramentas-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .ferramentas-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Cards na linguagem da home portal */
  .ferramenta-card {
    display: block;
    padding: var(--space-8);
    background: var(--bg-secondary);
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color var(--transition-fast);
    position: relative;
  }

  .ferramenta-card:hover {
    border-color: var(--border-default);
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .ferramenta-badge {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    padding: 2px var(--space-2);
    background: rgba(0, 240, 255, 0.1);
    color: var(--brand-cyan);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-weight: 600;
  }

  .ferramenta-icon {
    font-size: 2.5rem;
    margin-bottom: var(--space-4);
  }

  .ferramenta-title {
    font-size: var(--text-lg);
    color: var(--text-primary);
    margin-bottom: var(--space-3);
  }

  .ferramenta-description {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: 0;
  }

  .ferramenta-card.active {
    border-color: #3fb950;
    cursor: pointer;
  }
  .ferramenta-card.active:hover {
    border-color: #3fb950;
    box-shadow: 0 0 20px rgba(63, 185, 80, 0.2);
  }
  .ferramenta-badge.live {
    background: rgba(63, 185, 80, 0.15);
    color: #3fb950;
  }
</style>
