---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/header/Header.astro';
import Footer from '@components/footer/Footer.astro';
import { getCollection } from 'astro:content';
import { t } from '../../../i18n/translations';

const lang = 'es';
// Show ES glossary terms, fallback to PT if none exist yet
let glossario = await getCollection('glossario', ({ data }) => data.locale === 'es');
if (glossario.length === 0) {
  glossario = await getCollection('glossario', ({ data }) => !data.locale || data.locale === 'pt');
}
const sorted = glossario.sort((a, b) => a.data.term.localeCompare(b.data.term, 'es'));

const grouped = sorted.reduce((acc, item) => {
  const letter = item.data.term[0].toUpperCase();
  if (!acc[letter]) acc[letter] = [];
  acc[letter].push(item);
  return acc;
}, {} as Record<string, typeof sorted>);

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": sorted.map(term => ({
    "@type": "Question",
    "name": `¿Qué es ${term.data.term}?`,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": term.data.definition
    }
  }))
};
---

<BaseLayout
  title="Glosario Financiero — Qué es CDT, interés compuesto y más"
  description="Diccionario completo de términos financieros explicados de forma simple. Descubre qué es CDT, interés compuesto, liquidez y más de 60 términos."
  keywords={['glosario financiero', 'qué es CDT', 'términos financieros', 'educación financiera']}
>
  <Header />

  <main class="glossario-page">
    <div class="container">
      <header class="glossario-header">
        <h1 class="glossario-title">{t(lang, 'glossario.title')}</h1>
        <p class="glossario-description">{t(lang, 'glossario.desc')}</p>
      </header>

      <nav class="alphabet-nav" aria-label="Navegar por letra">
        {Object.keys(grouped).map(letter => (
          <a href={`#letra-${letter}`} class="alphabet-link">{letter}</a>
        ))}
      </nav>

      <div class="glossario-content">
        {Object.entries(grouped).map(([letter, terms]) => (
          <section id={`letra-${letter}`} class="letter-section">
            <h2 class="letter-heading">{letter}</h2>
            <div class="terms-list">
              {terms.map((term) => (
                <details class="term-accordion">
                  <summary class="term-question">
                    <span class="term-q-icon">?</span>
                    <span>{t(lang, 'glossario.oQueE')} {term.data.term}?</span>
                    <svg class="term-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <polyline points="6 9 12 15 18 9"/>
                    </svg>
                  </summary>
                  <div class="term-answer">
                    <p class="term-definition">{term.data.definition}</p>
                    <a href={`/es/glossario/${term.slug}`} class="term-read-more">
                      {t(lang, 'glossario.lerMais')}
                    </a>
                  </div>
                </details>
              ))}
            </div>
          </section>
        ))}
      </div>
    </div>
  </main>

  <Footer />

  {sorted.length > 0 && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
</BaseLayout>

<style>
  .glossario-page { padding: var(--space-8) 0 var(--space-16); }
  .glossario-header { text-align: center; margin-bottom: var(--space-8); }
  .glossario-title { font-size: var(--text-4xl); background: linear-gradient(135deg, #00F0FF, #A91079); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: var(--space-4); }
  .glossario-description { color: var(--text-secondary); font-size: var(--text-lg); max-width: 500px; margin: 0 auto; }
  .alphabet-nav { display: flex; flex-wrap: wrap; justify-content: center; gap: var(--space-2); margin-bottom: var(--space-8); padding: var(--space-4); background: var(--bg-secondary); border-radius: var(--radius-lg); border: 1px solid var(--border-default); }
  .alphabet-link { width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; border-radius: var(--radius-md); font-weight: 600; font-size: var(--text-sm); color: var(--text-secondary); transition: all var(--transition-fast); }
  .alphabet-link:hover { background: var(--bg-tertiary); color: #00F0FF; }
  .letter-section { margin-bottom: var(--space-8); }
  .letter-heading { font-size: var(--text-3xl); color: #00F0FF; opacity: 0.5; margin-bottom: var(--space-4); padding-bottom: var(--space-2); border-bottom: 1px solid var(--border-muted); }
  .terms-list { display: flex; flex-direction: column; gap: var(--space-3); }
  .term-accordion { background: var(--bg-secondary); border: 1px solid var(--border-default); border-radius: var(--radius-lg); overflow: hidden; transition: border-color var(--transition-fast); }
  .term-accordion:hover { border-color: rgba(0, 240, 255, 0.3); }
  .term-accordion[open] { border-color: rgba(0, 240, 255, 0.4); }
  .term-question { display: flex; align-items: center; gap: var(--space-3); padding: var(--space-4) var(--space-5); cursor: pointer; font-size: var(--text-base); font-weight: 600; color: var(--text-primary); list-style: none; transition: background var(--transition-fast); }
  .term-question::-webkit-details-marker { display: none; }
  .term-question:hover { background: var(--bg-tertiary); }
  .term-q-icon { display: flex; align-items: center; justify-content: center; width: 28px; height: 28px; background: rgba(0, 240, 255, 0.1); color: #00F0FF; border-radius: var(--radius-full); font-size: var(--text-sm); font-weight: 700; flex-shrink: 0; }
  .term-chevron { margin-left: auto; color: var(--text-tertiary); transition: transform 0.2s ease; flex-shrink: 0; }
  .term-accordion[open] .term-chevron { transform: rotate(180deg); }
  .term-answer { padding: 0 var(--space-5) var(--space-5); padding-left: calc(var(--space-5) + 28px + var(--space-3)); }
  .term-definition { font-size: var(--text-sm); color: var(--text-secondary); line-height: var(--leading-relaxed); margin-bottom: var(--space-3); }
  .term-read-more { font-size: var(--text-sm); color: #00F0FF; font-weight: 500; transition: opacity var(--transition-fast); }
  .term-read-more:hover { opacity: 0.8; }
  .glossario-empty { text-align: center; padding: var(--space-16) 0; color: var(--text-secondary); font-size: var(--text-lg); }
</style>
