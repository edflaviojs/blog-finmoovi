---
import BaseLayout from '@layouts/BaseLayout.astro';
import { imgSrcset } from '@/utils/responsive-image';
import Header from '@components/header/Header.astro';
import Footer from '@components/footer/Footer.astro';
import CTAVariado from '@components/glossario/CTAVariado.astro';
import Sidebar from '@components/sidebar/Sidebar.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const glossario = await getCollection('glossario', ({ data }) => data.locale === 'es');
  return glossario.map(term => ({
    params: { slug: term.slug },
    props: { term },
  }));
}

const { term } = Astro.props;
const { Content } = await term.render();

const allTerms = await getCollection('glossario', ({ data }) => data.locale === 'es');
const relatedTerms = allTerms.filter(t =>
  term.data.relatedTerms.some((rt: string) => t.data.term.toLowerCase().includes(rt.toLowerCase())) && t.slug !== term.slug
).slice(0, 4);

// Find translated versions
const alternates: { pt?: string; en?: string; es?: string } = { es: `/es/glossario/${term.slug}` };
const allGlossario = await getCollection('glossario');
const ptSlug = term.slug.replace(/^es-/, '');
const ptTerm = allGlossario.find(g => g.data.locale === 'pt' && (g.slug === ptSlug || (term.data.translationKey && g.data.translationKey === term.data.translationKey)));
const enTerm = allGlossario.find(g => g.data.locale === 'en' && (g.slug === `en-${ptSlug}` || (term.data.translationKey && g.data.translationKey === term.data.translationKey)));
if (ptTerm) alternates.pt = `/glossario/${ptTerm.slug}`;
if (enTerm) alternates.en = `/en/glossario/${enTerm.slug}`;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [{
    "@type": "Question",
    "name": `¿Qué es ${term.data.term}?`,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": term.data.definition
    }
  }]
};
---

<BaseLayout
  title={`¿Qué es ${term.data.term}? Explicación simple`}
  description={term.data.definition}
  keywords={[term.data.term.toLowerCase(), `qué es ${term.data.term.toLowerCase()}`, 'glosario financiero', 'educación financiera']}
  alternates={alternates}
>
  <Header />

  <main class="glossario-post">
    <div class="container">
      <div class="layout-with-sidebar glossario-layout">
      <article class="glossario-article">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/es">Inicio</a>
          <span>/</span>
          <a href="/es/glossario">Glosario</a>
          <span>/</span>
          <span>{term.data.term}</span>
        </nav>

        <header class="glossario-post-header">
          <span class="glossario-post-category">{term.data.category}</span>
          <h1 class="glossario-post-title">¿Qué es {term.data.term}?</h1>
          <p class="glossario-post-definition">{term.data.definition}</p>
        </header>

        <!-- Cover Image -->
        {term.data.image && (
          <div class="glossario-cover">
            <img src={term.data.image} srcset={imgSrcset(term.data.image)} sizes="(min-width: 768px) 720px, 100vw" alt={term.data.imageAlt || term.data.term} loading="lazy" width="1200" height="630" />
          </div>
        )}

        <CTAVariado seed={term.slug.length} />

        <div class="glossario-post-content post-content">
          <Content />
        </div>

        <CTAVariado seed={term.slug.length + 5} />

        {relatedTerms.length > 0 && (
          <section class="related-terms">
            <h3>Términos Relacionados</h3>
            <div class="related-grid">
              {relatedTerms.map(rt => (
                <a href={`/es/glossario/${rt.slug}`} class="related-card">
                  <span class="related-question">¿Qué es {rt.data.term}?</span>
                  <p class="related-def">{rt.data.definition.substring(0, 100)}...</p>
                </a>
              ))}
            </div>
          </section>
        )}
      </article>

      <aside class="glossario-sidebar">
        <Sidebar />
      </aside>
      </div>
    </div>
  </main>

  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</BaseLayout>

<style>
  .glossario-post { padding: var(--space-8) 0 var(--space-16); }
  /* Mesmo esquema dos posts: artigo + sidebar, conjunto centrado em 1220px */
  .glossario-layout { max-width: 1220px; margin-inline: auto; }
  .glossario-article { max-width: 820px; }
  .glossario-sidebar { display: none; }
  @media (min-width: 1024px) { .glossario-sidebar { display: block; } }
  .breadcrumb { display: flex; align-items: center; gap: var(--space-2); font-size: var(--text-sm); color: var(--text-tertiary); margin-bottom: var(--space-6); }
  .breadcrumb a { color: var(--text-tertiary); transition: color var(--transition-fast); }
  .breadcrumb a:hover { color: var(--brand-cyan); }
  .glossario-post-header { margin-bottom: var(--space-8); padding-bottom: var(--space-6); border-bottom: 1px solid var(--border-muted); }
  .glossario-post-category { display: inline-block; padding: 3px var(--space-3); background: var(--portal-grad); color: #fff; border-radius: var(--radius-full); font-size: 11px; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: var(--space-3); }
  .glossario-post-title { font-size: var(--text-4xl); letter-spacing: -0.02em; background: var(--portal-grad); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: var(--space-4); }
  .glossario-post-definition { font-size: var(--text-lg); color: var(--text-secondary); line-height: var(--leading-relaxed); padding: var(--space-4); background: var(--bg-secondary); border-left: 3px solid #00c8d7; border-radius: 0 var(--radius-md) var(--radius-md) 0; box-shadow: var(--shadow-sm); }
  .glossario-post-content { margin: var(--space-8) 0; }
  .related-terms { margin-top: var(--space-10); padding-top: var(--space-8); border-top: 1px solid var(--border-muted); }
  .related-terms h3 { font-size: var(--text-xl); margin-bottom: var(--space-4); }
  .related-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-4); }
  @media (min-width: 640px) { .related-grid { grid-template-columns: repeat(2, 1fr); } }
  .related-card { padding: var(--space-4); background: var(--bg-secondary); border: 1px solid var(--border-muted); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); text-decoration: none; transition: border-color var(--transition-fast), transform 0.25s ease, box-shadow 0.25s ease; }
  .related-card:hover { border-color: var(--border-default); transform: translateY(-2px); box-shadow: var(--shadow-lg); }
  .related-question { display: block; font-size: var(--text-sm); font-weight: 600; color: var(--text-primary); margin-bottom: var(--space-2); }
  .related-def { font-size: var(--text-xs); color: var(--text-tertiary); margin-bottom: 0; }
</style>
