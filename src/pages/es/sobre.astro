---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/header/Header.astro';
import Footer from '@components/footer/Footer.astro';
import { t } from '../../i18n/translations';
import { config } from '../../../site.config';

const lang = 'es';
const brand = config.brand.name;
const blogTitle = `${brand} ${config.brand.blogSuffix}`;
---

<BaseLayout
  title={`Acerca del ${blogTitle}`}
  description={`Conoce el ${blogTitle}: ${config.brand.tagline.es}. Consejos prácticos y herramientas gratuitas.`}
  keywords={[config.content.niche.es, 'educación', 'consejos', 'quiénes somos']}
>
  <Header />

  <main class="sobre-page">
    <div class="container">
      <header class="sobre-header">
        <h1 class="sobre-title">{t(lang, 'sobre.title')}</h1>
        <p class="sobre-subtitle">{t(lang, 'sobre.subtitle')}</p>
      </header>

      <div class="sobre-content">
        <section class="sobre-section">
          <h2>{t(lang, 'sobre.missao')}</h2>
          <p>{t(lang, 'sobre.missao.p1')}</p>
          <p>{t(lang, 'sobre.missao.p2')}</p>
        </section>

        <section class="sobre-section">
          <h2>{t(lang, 'sobre.oque')}</h2>
          <div class="sobre-grid">
            <div class="sobre-card">
              <span class="sobre-card-icon">📝</span>
              <h3>{t(lang, 'sobre.card1.title')}</h3>
              <p>{t(lang, 'sobre.card1.desc')}</p>
            </div>
            <div class="sobre-card">
              <span class="sobre-card-icon">🛠️</span>
              <h3>{t(lang, 'sobre.card2.title')}</h3>
              <p>{t(lang, 'sobre.card2.desc')}</p>
            </div>
            <div class="sobre-card">
              <span class="sobre-card-icon">📖</span>
              <h3>{t(lang, 'sobre.card3.title')}</h3>
              <p>{t(lang, 'sobre.card3.desc')}</p>
            </div>
            <div class="sobre-card">
              <span class="sobre-card-icon">📊</span>
              <h3>{t(lang, 'sobre.card4.title')}</h3>
              <p>{t(lang, 'sobre.card4.desc')}</p>
            </div>
          </div>
        </section>

        <section class="sobre-section">
          <h2>{t(lang, 'sobre.sobreApp')}</h2>
          <p>{t(lang, 'sobre.sobreApp.p1')}</p>
          <p>{t(lang, 'sobre.sobreApp.p2')}</p>
        </section>

        <section class="sobre-section sobre-cta">
          <div class="sobre-cta-box">
            <h2>{t(lang, 'sobre.cta.title')}</h2>
            <p>{t(lang, 'sobre.cta.desc')}</p>
            <div class="sobre-cta-actions">
              <a href="/app" class="sobre-btn primary">{t(lang, 'sobre.cta.btn')}</a>
              <a href="/es" class="sobre-btn secondary">{t(lang, 'sobre.cta.blog')}</a>
            </div>
          </div>
        </section>

        <section class="sobre-section">
          <h2>{t(lang, 'sobre.editorial')}</h2>
          <p>{t(lang, 'sobre.editorial.p1')}</p>
          <p>{t(lang, 'sobre.editorial.p2')} <a href={`${config.app.url}/contato`} class="sobre-link">{t(lang, 'sobre.editorial.p2.link')}</a>.</p>
        </section>

        <section class="sobre-section">
          <h2>{t(lang, 'sobre.contato')}</h2>
          <p>{t(lang, 'sobre.contato.p1')} <a href="mailto:${config.email.replyTo}" class="sobre-link">${config.email.replyTo}</a>.</p>
          <p>{t(lang, 'sobre.contato.p2')}</p>
          <div class="sobre-social">
            <a href="#" target="_blank" rel="noopener" class="social-link">Instagram</a>
            <a href="#" target="_blank" rel="noopener" class="social-link">Twitter/X</a>
            <a href="#" target="_blank" rel="noopener" class="social-link">YouTube</a>
          </div>
        </section>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .sobre-page { padding: var(--space-8) 0 var(--space-16); }
  .sobre-header { text-align: center; margin-bottom: var(--space-12); }
  .sobre-title { font-size: var(--text-4xl); background: linear-gradient(135deg, var(--brand-cyan), #A91079); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: var(--space-4); }
  .sobre-subtitle { font-size: var(--text-lg); color: var(--text-secondary); }
  .sobre-content { max-width: 800px; margin: 0 auto; }
  .sobre-section { margin-bottom: var(--space-12); }
  .sobre-section h2 { font-size: var(--text-2xl); margin-bottom: var(--space-4); color: var(--text-primary); }
  .sobre-section p { font-size: var(--text-base); color: var(--text-secondary); line-height: var(--leading-relaxed); margin-bottom: var(--space-4); }
  .sobre-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-4); }
  @media (min-width: 640px) { .sobre-grid { grid-template-columns: repeat(2, 1fr); } }
  .sobre-card { padding: var(--space-6); background: var(--bg-secondary); border: 1px solid var(--border-default); border-radius: var(--radius-lg); }
  .sobre-card-icon { font-size: 2rem; display: block; margin-bottom: var(--space-3); }
  .sobre-card h3 { font-size: var(--text-base); margin-bottom: var(--space-2); }
  .sobre-card p { font-size: var(--text-sm); color: var(--text-secondary); margin-bottom: 0; }
  .sobre-cta-box { text-align: center; padding: var(--space-10); background: var(--gradient-card); border: 1px solid var(--border-default); border-radius: var(--radius-xl); position: relative; overflow: hidden; }
  .sobre-cta-box::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(135deg, var(--brand-cyan), #A91079); }
  .sobre-cta-box h2 { margin-bottom: var(--space-3); }
  .sobre-cta-box p { margin-bottom: var(--space-6); text-align: center; }
  .sobre-cta-actions { display: flex; gap: var(--space-4); justify-content: center; flex-wrap: wrap; }
  .sobre-btn { padding: var(--space-3) var(--space-6); border-radius: var(--radius-full); font-weight: 600; font-size: var(--text-sm); transition: all var(--transition-fast); }
  .sobre-btn.primary { background: linear-gradient(135deg, var(--brand-cyan), #A91079); color: #fff; }
  .sobre-btn.primary:hover { opacity: 0.9; transform: translateY(-1px); }
  .sobre-btn.secondary { background: var(--bg-tertiary); color: var(--text-primary); border: 1px solid var(--border-default); }
  .sobre-btn.secondary:hover { border-color: var(--brand-cyan); }
  .sobre-link { color: var(--brand-cyan); text-decoration: underline; text-underline-offset: 3px; }
  .sobre-social { display: flex; gap: var(--space-4); flex-wrap: wrap; }
  .social-link { padding: var(--space-2) var(--space-4); background: var(--bg-tertiary); border: 1px solid var(--border-default); border-radius: var(--radius-md); font-size: var(--text-sm); color: var(--text-secondary); transition: all var(--transition-fast); }
  .social-link:hover { border-color: var(--brand-cyan); color: var(--brand-cyan); }
</style>
