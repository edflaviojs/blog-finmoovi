---
import PostLayout from '@layouts/PostLayout.astro';
import SchemaArticle from '@components/seo/SchemaArticle.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft && data.locale === 'es');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();

const canonicalURL = new URL(`/es/posts/${post.slug}`, Astro.site).toString();

// Find translated versions via translationKey
const alternates: { pt?: string; en?: string; es?: string } = { es: `/es/posts/${post.slug}` };
if (post.data.translationKey) {
  const allPosts = await getCollection('posts', ({ data }) => !data.draft && data.translationKey === post.data.translationKey);
  const ptPost = allPosts.find(p => p.data.locale === 'pt');
  const enPost = allPosts.find(p => p.data.locale === 'en');
  if (ptPost) alternates.pt = `/posts/${ptPost.slug}`;
  if (enPost) alternates.en = `/en/posts/${enPost.slug}`;
}
---

<PostLayout
  title={post.data.seo?.metaTitle || post.data.title}
  description={post.data.seo?.metaDescription || post.data.description}
  image={post.data.image}
  publishedTime={post.data.publishedAt.toISOString()}
  author={post.data.author}
  keywords={post.data.seo?.keywords || post.data.tags}
  category={post.data.category}
  readingTime={post.data.readingTime}
  headings={headings}
  slug={post.slug}
  alternates={alternates}
>
  <SchemaArticle
    title={post.data.title}
    description={post.data.description}
    image={post.data.image}
    url={canonicalURL}
    publishedTime={post.data.publishedAt.toISOString()}
    author={post.data.author}
    category={post.data.category}
    keywords={post.data.tags}
  />

  <Content />
</PostLayout>
