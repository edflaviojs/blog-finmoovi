---
import PostLayout from '@layouts/PostLayout.astro';
import SchemaArticle from '@components/seo/SchemaArticle.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft && data.locale === 'es');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();

const rawContent = post.body || '';
const schemaMatch = rawContent.match(/<!-- SCHEMA_AUTO:([\s\S]*?) -->/);
const autoSchema = schemaMatch ? schemaMatch[1] : null;

const canonicalURL = new URL(`/es/posts/${post.slug}`, Astro.site).toString();

// Find translated versions via translationKey or same date+category
const alternates: { pt?: string; en?: string; es?: string } = { es: `/es/posts/${post.slug}` };
const allTranslatedPosts = await getCollection('posts', ({ data }) => !data.draft && data.locale !== 'es');

// Strategy 1: match by translationKey
let ptPost = post.data.translationKey
  ? allTranslatedPosts.find(p => p.data.locale === 'pt' && p.data.translationKey === post.data.translationKey)
  : null;
let enPost = post.data.translationKey
  ? allTranslatedPosts.find(p => p.data.locale === 'en' && p.data.translationKey === post.data.translationKey)
  : null;

// Strategy 2: match by same publishedAt date + category (only if unique match)
if (!ptPost || !enPost) {
  const postDate = post.data.publishedAt.toISOString().split('T')[0];
  const ptCandidates = allTranslatedPosts.filter(p =>
    p.data.locale === 'pt' && p.data.category === post.data.category &&
    p.data.publishedAt.toISOString().split('T')[0] === postDate
  );
  const enCandidates = allTranslatedPosts.filter(p =>
    p.data.locale === 'en' && p.data.category === post.data.category &&
    p.data.publishedAt.toISOString().split('T')[0] === postDate
  );
  if (!ptPost && ptCandidates.length === 1) ptPost = ptCandidates[0];
  if (!enPost && enCandidates.length === 1) enPost = enCandidates[0];
}

if (ptPost) alternates.pt = `/posts/${ptPost.slug}`;
if (enPost) alternates.en = `/en/posts/${enPost.slug}`;
---

<PostLayout
  title={post.data.seo?.metaTitle || post.data.title}
  description={post.data.seo?.metaDescription || post.data.description}
  image={post.data.image}
  imageAlt={post.data.imageAlt}
  publishedTime={post.data.publishedAt.toISOString()}
  updatedTime={post.data.updatedAt?.toISOString()}
  author={post.data.author}
  keywords={post.data.seo?.keywords || post.data.tags}
  category={post.data.category}
  readingTime={post.data.readingTime}
  headings={headings}
  slug={post.slug}
  alternates={alternates}
>
  <SchemaArticle
    title={post.data.title}
    description={post.data.description}
    image={post.data.image}
    url={canonicalURL}
    publishedTime={post.data.publishedAt.toISOString()}
    modifiedTime={post.data.updatedAt?.toISOString()}
    author={post.data.author}
    category={post.data.category}
    keywords={post.data.tags}
  />

  {autoSchema && <script type="application/ld+json" set:html={autoSchema} />}

  <Content />
</PostLayout>
