---
import BaseLayout from '@layouts/BaseLayout.astro';
import { imgSrcset } from '@/utils/responsive-image';
import Header from '@components/header/Header.astro';
import Footer from '@components/footer/Footer.astro';
import CTAVariado from '@components/glossario/CTAVariado.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const glossario = await getCollection('glossario', ({ data }) => data.locale === 'pt');
  return glossario.map(term => ({
    params: { slug: term.slug },
    props: { term },
  }));
}

const { term } = Astro.props;
const { Content } = await term.render();

const allTerms = await getCollection('glossario', ({ data }) => data.locale === 'pt');
const relatedTerms = allTerms.filter(t =>
  term.data.relatedTerms.some((rt: string) => t.data.term.toLowerCase().includes(rt.toLowerCase())) && t.slug !== term.slug
).slice(0, 4);

// Find translated versions
const alternates: { pt?: string; en?: string; es?: string } = { pt: `/glossario/${term.slug}` };
const allGlossario = await getCollection('glossario');
const enTerm = allGlossario.find(g => g.data.locale === 'en' && (g.slug === `en-${term.slug}` || (term.data.translationKey && g.data.translationKey === term.data.translationKey)));
const esTerm = allGlossario.find(g => g.data.locale === 'es' && (g.slug === `es-${term.slug}` || (term.data.translationKey && g.data.translationKey === term.data.translationKey)));
if (enTerm) alternates.en = `/en/glossario/${enTerm.slug}`;
if (esTerm) alternates.es = `/es/glossario/${esTerm.slug}`;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [{
    "@type": "Question",
    "name": `O que é ${term.data.term}?`,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": term.data.definition
    }
  }]
};
---

<BaseLayout
  title={`O que é ${term.data.term}? Entenda de forma simples`}
  description={term.data.definition}
  keywords={[term.data.term.toLowerCase(), `o que é ${term.data.term.toLowerCase()}`, 'glossário financeiro', 'educação financeira']}
  alternates={alternates}
>
  <Header />

  <main class="glossario-post">
    <div class="container">
      <article class="glossario-article" data-pagefind-body>
        <!-- Breadcrumb -->
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Início</a>
          <span>/</span>
          <a href="/glossario">Glossário</a>
          <span>/</span>
          <span>{term.data.term}</span>
        </nav>

        <!-- Header -->
        <header class="glossario-post-header">
          <span class="glossario-post-category">{term.data.category}</span>
          <h1 class="glossario-post-title">O que é {term.data.term}?</h1>
          <p class="glossario-post-definition">{term.data.definition}</p>
        </header>

        <!-- Cover Image -->
        {term.data.image && (
          <div class="glossario-cover">
            <img src={term.data.image} srcset={imgSrcset(term.data.image)} sizes="(min-width: 768px) 720px, 100vw" alt={term.data.imageAlt || term.data.term} loading="lazy" width="1200" height="630" />
          </div>
        )}

        <!-- CTA 1 (meio) -->
        <CTAVariado seed={term.slug.length} />

        <!-- Content -->
        <div class="glossario-post-content post-content">
          <Content />
        </div>

        <!-- CTA 2 (final) -->
        <CTAVariado seed={term.slug.length + 5} />

        <!-- Related Terms -->
        {relatedTerms.length > 0 && (
          <section class="related-terms">
            <h3>Termos Relacionados</h3>
            <div class="related-grid">
              {relatedTerms.map(rt => (
                <a href={`/glossario/${rt.slug}`} class="related-card">
                  <span class="related-question">O que é {rt.data.term}?</span>
                  <p class="related-def">{rt.data.definition.substring(0, 100)}...</p>
                </a>
              ))}
            </div>
          </section>
        )}
      </article>
    </div>
  </main>

  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</BaseLayout>

<style>
  .glossario-post {
    padding: var(--space-8) 0 var(--space-16);
  }

  .glossario-article {
    max-width: 800px;
    margin: 0 auto;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    margin-bottom: var(--space-6);
  }

  .breadcrumb a {
    color: var(--text-tertiary);
    transition: color var(--transition-fast);
  }

  .breadcrumb a:hover {
    color: var(--brand-cyan);
  }

  .glossario-post-header {
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--border-muted);
  }

  .glossario-cover {
    margin-bottom: var(--space-8);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border-default);
  }

  .glossario-cover img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Visual portal (Fase 3): chip e título com o gradiente da marca */
  .glossario-post-category {
    display: inline-block;
    padding: 3px var(--space-3);
    background: var(--portal-grad);
    color: #fff;
    border-radius: var(--radius-full);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: var(--space-3);
  }

  .glossario-post-title {
    font-size: var(--text-4xl);
    letter-spacing: -0.02em;
    background: var(--portal-grad);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: var(--space-4);
  }

  .glossario-post-definition {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    padding: var(--space-4);
    background: var(--bg-secondary);
    /* cor literal: var(--brand-cyan) escurece no tema claro */
    border-left: 3px solid #00c8d7;
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    box-shadow: var(--shadow-sm);
  }

  .glossario-post-content {
    margin: var(--space-8) 0;
  }

  .related-terms {
    margin-top: var(--space-10);
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-muted);
  }

  .related-terms h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-4);
  }

  .related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .related-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .related-card {
    padding: var(--space-4);
    background: var(--bg-secondary);
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    transition: border-color var(--transition-fast), transform 0.25s ease, box-shadow 0.25s ease;
  }

  .related-card:hover {
    border-color: var(--border-default);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .related-question {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .related-def {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    margin-bottom: 0;
  }
</style>
