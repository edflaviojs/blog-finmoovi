---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/header/Header.astro';
import Footer from '@components/footer/Footer.astro';
import { getCollection } from 'astro:content';

const glossario = await getCollection('glossario');
const sorted = glossario.sort((a, b) => a.data.term.localeCompare(b.data.term, 'pt-BR'));

const grouped = sorted.reduce((acc, item) => {
  const letter = item.data.term[0].toUpperCase();
  if (!acc[letter]) acc[letter] = [];
  acc[letter].push(item);
  return acc;
}, {} as Record<string, typeof sorted>);
---

<BaseLayout
  title="Glossário Financeiro"
  description="Dicionário completo de termos financeiros explicados de forma simples. De A a Z, tudo que você precisa saber sobre finanças."
  keywords={['glossário financeiro', 'termos financeiros', 'dicionário finanças', 'educação financeira']}
>
  <Header />

  <main class="glossario-page">
    <div class="container">
      <header class="glossario-header">
        <h1 class="glossario-title">Glossário Financeiro</h1>
        <p class="glossario-description">
          Termos financeiros explicados de forma simples e direta. Sem jargão, sem enrolação.
        </p>
      </header>

      <!-- Alphabet Navigation -->
      <nav class="alphabet-nav" aria-label="Navegação por letra">
        {Object.keys(grouped).map(letter => (
          <a href={`#letra-${letter}`} class="alphabet-link">{letter}</a>
        ))}
      </nav>

      <!-- Terms -->
      <div class="glossario-content">
        {Object.entries(grouped).map(([letter, terms]) => (
          <section id={`letra-${letter}`} class="letter-section">
            <h2 class="letter-heading">{letter}</h2>
            <div class="terms-list">
              {terms.map(term => (
                <article class="term-card">
                  <h3 class="term-title">{term.data.term}</h3>
                  <p class="term-definition">{term.data.definition}</p>
                  <a href={`/glossario/${term.slug}`} class="term-link">Ler mais →</a>
                </article>
              ))}
            </div>
          </section>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .glossario-page {
    padding: var(--space-8) 0 var(--space-16);
  }

  .glossario-header {
    text-align: center;
    margin-bottom: var(--space-10);
  }

  .glossario-title {
    font-size: var(--text-4xl);
    background: var(--gradient-hero);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: var(--space-4);
  }

  .glossario-description {
    color: var(--text-secondary);
    font-size: var(--text-lg);
    max-width: 500px;
    margin: 0 auto;
  }

  .alphabet-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2);
    margin-bottom: var(--space-10);
    padding: var(--space-4);
    background: var(--bg-secondary);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-default);
  }

  .alphabet-link {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--text-secondary);
    transition: all var(--transition-fast);
  }

  .alphabet-link:hover {
    background: var(--bg-tertiary);
    color: var(--accent-primary);
  }

  .letter-section {
    margin-bottom: var(--space-10);
  }

  .letter-heading {
    font-size: var(--text-3xl);
    color: var(--accent-primary);
    opacity: 0.5;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--border-muted);
  }

  .terms-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 768px) {
    .terms-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .term-card {
    padding: var(--space-5);
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    transition: border-color var(--transition-fast);
  }

  .term-card:hover {
    border-color: var(--accent-primary);
  }

  .term-title {
    font-size: var(--text-base);
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .term-definition {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-bottom: var(--space-3);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .term-link {
    font-size: var(--text-sm);
    color: var(--accent-primary);
    font-weight: 500;
  }
</style>
