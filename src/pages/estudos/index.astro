---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/header/Header.astro';
import Footer from '@components/footer/Footer.astro';
import { config } from '../../../site.config';
import endivData from '@/data/endividamento.json';

const fmt = (v: number) => v.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

const estudos = [
  {
    title: 'Índice FinMoovi de Endividamento',
    href: '/estudos/endividamento-das-familias',
    icon: '📊',
    stat: `${fmt(endivData.endividamento.latest.value)}%`,
    statLabel: 'endividamento das famílias (renda anual)',
    description: 'Série histórica do endividamento das famílias brasileiras, com dados do Banco Central. Atualizado automaticamente.',
  },
];
---

<BaseLayout
  title="Estudos e Dados"
  description={`Estudos de finanças com dados públicos (Banco Central, IBGE), atualizados automaticamente. ${config.brand.name} Blog.`}
  keywords={['estudos finanças', 'dados endividamento', 'índice financeiro', 'dados banco central']}
>
  <Header />

  <main class="estudos-index">
    <div class="container">
      <header class="estudos-header">
        <h1 class="estudos-title">Estudos e Dados</h1>
        <p class="estudos-description">
          Levantamentos de finanças com <strong>dados públicos reais</strong> (Banco Central, IBGE), atualizados automaticamente.
        </p>
      </header>

      <div class="estudos-grid">
        {estudos.map(e => (
          <a href={e.href} class="estudo-card">
            <div class="estudo-icon">{e.icon}</div>
            <div class="estudo-stat">{e.stat}</div>
            <div class="estudo-stat-label">{e.statLabel}</div>
            <h3 class="estudo-card-title">{e.title}</h3>
            <p class="estudo-card-desc">{e.description}</p>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .estudos-index { padding: var(--space-8) 0 var(--space-16); }
  .estudos-header { text-align: center; margin-bottom: var(--space-12); }
  .estudos-title {
    font-size: var(--text-4xl);
    background: var(--gradient-cta);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    margin-bottom: var(--space-4);
  }
  .estudos-description { color: var(--text-secondary); font-size: var(--text-lg); max-width: 560px; margin: 0 auto; }
  .estudos-description :global(strong) { color: var(--text-primary); }
  .estudos-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-6); }
  @media (min-width: 640px) { .estudos-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .estudos-grid { grid-template-columns: repeat(3, 1fr); } }
  .estudo-card {
    display: block; padding: var(--space-8);
    background: var(--gradient-card); border: 1px solid var(--border-default);
    border-radius: var(--radius-xl); text-decoration: none;
    transition: all var(--transition-base);
  }
  .estudo-card:hover { border-color: var(--accent-primary); transform: translateY(-4px); box-shadow: var(--shadow-glow); }
  .estudo-icon { font-size: 2rem; margin-bottom: var(--space-3); }
  .estudo-stat { font-size: var(--text-3xl); font-weight: 700; color: #f85149; line-height: 1; }
  .estudo-stat-label { font-size: var(--text-xs); color: var(--text-tertiary); text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: var(--space-3); }
  .estudo-card-title { font-size: var(--text-lg); color: var(--text-primary); margin-bottom: var(--space-2); }
  .estudo-card-desc { font-size: var(--text-sm); color: var(--text-secondary); line-height: var(--leading-relaxed); margin: 0; }
</style>
