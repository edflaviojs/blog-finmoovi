---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/header/Header.astro';
import Footer from '@components/footer/Footer.astro';
import { getCollection } from 'astro:content';
import { config } from '../../../site.config';
import { authors, personSchema } from '@/data/authors';

const author = authors['ed-flavio'];

// Posts recentes (PT) — o blog é editado por este autor.
const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const ptPosts = allPosts
  .filter(p => p.data.locale === 'pt' || (!p.data.locale && !p.slug.startsWith('en-') && !p.slug.startsWith('es-')))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 9);

const schema = {
  '@context': 'https://schema.org',
  ...personSchema(author),
};

const metaDescription = `${author.name} — ${author.jobTitle}. ${author.credentials.map(c => `${c.level} em ${c.name}`).join(', ')}. Artigos de finanças pessoais no ${config.brand.name} Blog.`;
---

<BaseLayout
  title={author.name}
  description={metaDescription}
  keywords={[author.name, ...author.knowsAbout, 'autor', 'especialista finanças']}
>
  <Header />

  <main class="autor-page">
    <div class="container">
      <header class="autor-header">
        <h1 class="autor-title">{author.name}</h1>
        <p class="autor-role">{author.jobTitle}</p>
        <ul class="autor-credenciais">
          {author.credentials.map(c => (
            <li>🎓 {c.level} em {c.name}</li>
          ))}
        </ul>
      </header>

      <div class="autor-content">
        <section class="autor-section">
          <h2>Sobre o autor</h2>
          <p>{author.description}</p>
        </section>

        <section class="autor-section">
          <h2>Áreas de especialidade</h2>
          <div class="autor-tags">
            {author.knowsAbout.map(t => <span class="autor-tag">{t}</span>)}
          </div>
        </section>

        <section class="autor-section">
          <h2>Artigos recentes</h2>
          <div class="autor-posts">
            {ptPosts.map(post => (
              <a class="autor-post" href={`/posts/${post.slug}`}>
                <span class="autor-post-title">{post.data.title}</span>
                <time datetime={post.data.publishedAt.toISOString()}>
                  {post.data.publishedAt.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' })}
                </time>
              </a>
            ))}
          </div>
        </section>
      </div>
    </div>
  </main>

  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</BaseLayout>

<style>
  .autor-page { padding: var(--space-8) 0 var(--space-16); }
  .autor-header { text-align: center; margin-bottom: var(--space-10); }
  .autor-title {
    font-size: var(--text-4xl);
    background: var(--gradient-cta);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: var(--space-2);
  }
  .autor-role { font-size: var(--text-lg); color: var(--text-secondary); margin-bottom: var(--space-4); }
  .autor-credenciais {
    list-style: none; padding: 0; display: flex; gap: var(--space-4);
    justify-content: center; flex-wrap: wrap;
  }
  .autor-credenciais li {
    font-size: var(--text-sm); color: var(--text-primary);
    background: var(--bg-secondary); border: 1px solid var(--border-default);
    border-radius: var(--radius-full); padding: var(--space-2) var(--space-4);
  }
  .autor-content { max-width: 800px; margin: 0 auto; }
  .autor-section { margin-bottom: var(--space-10); }
  .autor-section h2 { font-size: var(--text-2xl); margin-bottom: var(--space-4); color: var(--text-primary); }
  .autor-section p { color: var(--text-secondary); line-height: var(--leading-relaxed); }
  .autor-tags { display: flex; gap: var(--space-2); flex-wrap: wrap; }
  .autor-tag {
    font-size: var(--text-sm); color: var(--text-secondary);
    background: var(--bg-tertiary); border: 1px solid var(--border-default);
    border-radius: var(--radius-md); padding: var(--space-2) var(--space-3);
  }
  .autor-posts { display: grid; grid-template-columns: 1fr; gap: var(--space-3); }
  .autor-post {
    display: flex; justify-content: space-between; gap: var(--space-4); align-items: baseline;
    padding: var(--space-4); background: var(--bg-secondary);
    border: 1px solid var(--border-default); border-radius: var(--radius-lg);
    transition: border-color var(--transition-fast);
  }
  .autor-post:hover { border-color: #00F0FF; }
  .autor-post-title { color: var(--text-primary); font-weight: 500; }
  .autor-post time { color: var(--text-secondary); font-size: var(--text-sm); white-space: nowrap; }
</style>
