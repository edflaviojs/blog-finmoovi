---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/header/Header.astro';
import Footer from '@components/footer/Footer.astro';
import SchemaWebsite from '@components/seo/SchemaWebsite.astro';
import PortalHome from '@components/home/PortalHome.astro';
import { getHomeData } from '@/utils/home-data';
import { config } from '../../site.config';
import { imgSrcset } from '@/utils/responsive-image';

// Home portal PT — todo o conteúdo/estilo vive em PortalHome (compartilhado
// pelos 3 idiomas); esta página é só o invólucro de SEO.
const data = await getHomeData('pt');
---

<BaseLayout
  title={`${config.brand.name} ${config.brand.blogSuffix}`}
  description={config.siteDescription.pt}
  keywords={config.content.defaultKeywords.pt.split(', ')}
  preloadImage={data.hero?.image}
  preloadImageSrcset={data.hero?.image ? imgSrcset(data.hero.image) : undefined}
  preloadImageSizes="(min-width: 1024px) 900px, 100vw"
>
  <SchemaWebsite />
  <Header />

  <main>
    <PortalHome locale="pt" data={data} />
  </main>

  <Footer />
</BaseLayout>
