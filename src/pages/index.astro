---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/header/Header.astro';
import Footer from '@components/footer/Footer.astro';
import PostGrid from '@components/posts/PostGrid.astro';
import Sidebar from '@components/sidebar/Sidebar.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft && (!data.locale || data.locale === 'pt'));
const sortedPosts = allPosts.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
const featuredPosts = sortedPosts.filter(p => p.data.featured);
const recentPosts = sortedPosts.slice(0, 9);

const heroPost = featuredPosts[0] || sortedPosts[0];
const secondaryPosts = featuredPosts.length > 1 ? featuredPosts.slice(1, 4) : sortedPosts.slice(1, 4);

const postsForGrid = recentPosts.map(post => ({
  title: post.data.title,
  description: post.data.description,
  image: post.data.image,
  href: `/posts/${post.slug}`,
  category: post.data.category,
  date: post.data.publishedAt.toISOString(),
  readingTime: post.data.readingTime,
}));
---

<BaseLayout
  title="FinMoovi Blog"
  description="Dicas práticas de finanças pessoais, controle de gastos e educação financeira. Organize sua vida financeira com o FinMoovi."
  keywords={['finanças pessoais', 'controle financeiro', 'educação financeira', 'orçamento', 'investimentos']}
>
  <Header />

  <main>
    <!-- Hero Portal Style -->
    <section class="hero-portal">
      <div class="container">
        <div class="hero-grid">
          <!-- Main Featured Post -->
          <a href={`/posts/${heroPost.slug}`} class="hero-main">
            <div class="hero-main-image">
              {heroPost.data.image && <img src={heroPost.data.image} alt="" loading="eager" />}
              <div class="hero-main-overlay"></div>
            </div>
            <div class="hero-main-content">
              <span class="hero-category">{heroPost.data.category}</span>
              <h1 class="hero-title">{heroPost.data.title}</h1>
              <p class="hero-description">{heroPost.data.description}</p>
              <div class="hero-meta">
                <time datetime={heroPost.data.publishedAt.toISOString()}>
                  {heroPost.data.publishedAt.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}
                </time>
                {heroPost.data.readingTime && <span>· {heroPost.data.readingTime} min de leitura</span>}
              </div>
            </div>
          </a>

          <!-- Secondary Posts -->
          <div class="hero-secondary">
            {secondaryPosts.map(post => (
              <a href={`/posts/${post.slug}`} class="hero-secondary-card">
                <div class="hero-secondary-image">
                  {post.data.image && <img src={post.data.image} alt="" loading="eager" />}
                </div>
                <div class="hero-secondary-content">
                  <span class="hero-secondary-category">{post.data.category}</span>
                  <h3 class="hero-secondary-title">{post.data.title}</h3>
                  <time datetime={post.data.publishedAt.toISOString()}>
                    {post.data.publishedAt.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short' })}
                  </time>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Recent Posts + Sidebar -->
    <section class="section">
      <div class="container">
        <h2 class="section-title" data-i18n="section.ultimosPosts">Últimos Posts</h2>
        <div class="layout-with-sidebar">
          <div>
            <PostGrid posts={postsForGrid} columns={2} />
          </div>
          <aside class="home-sidebar">
            <Sidebar />
          </aside>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* Hero Portal */
  .hero-portal {
    padding: var(--space-8) 0 var(--space-12);
    border-bottom: 1px solid var(--border-muted);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: 2fr 1fr;
    }
  }

  /* Main Hero Post */
  .hero-main {
    position: relative;
    display: block;
    border-radius: var(--radius-xl);
    overflow: hidden;
    min-height: 400px;
    text-decoration: none;
    transition: transform var(--transition-base);
  }

  .hero-main:hover {
    transform: scale(1.01);
  }

  .hero-main-image {
    position: absolute;
    inset: 0;
  }

  .hero-main-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-main-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(13, 17, 23, 0.95) 0%, rgba(13, 17, 23, 0.4) 50%, rgba(13, 17, 23, 0.2) 100%);
  }

  .hero-main-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    height: 100%;
    min-height: 400px;
    padding: var(--space-8);
  }

  .hero-category {
    display: inline-block;
    padding: 3px var(--space-3);
    background: rgba(0, 240, 255, 0.15);
    color: #00F0FF;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-3);
    width: fit-content;
  }

  .hero-title {
    font-size: var(--text-3xl);
    color: #fff;
    line-height: 1.2;
    margin-bottom: var(--space-3);
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: var(--text-4xl);
    }
  }

  .hero-description {
    font-size: var(--text-base);
    color: rgba(255, 255, 255, 0.7);
    max-width: 600px;
    margin-bottom: var(--space-4);
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.5);
  }

  /* Secondary Posts */
  .hero-secondary {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .hero-secondary-card {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-4);
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .hero-secondary-card:hover {
    border-color: rgba(0, 240, 255, 0.3);
    background: var(--bg-tertiary);
  }

  .hero-secondary-image {
    width: 100px;
    height: 80px;
    border-radius: var(--radius-md);
    overflow: hidden;
    flex-shrink: 0;
  }

  .hero-secondary-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-secondary-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-1);
  }

  .hero-secondary-category {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #00F0FF;
  }

  .hero-secondary-title {
    font-size: var(--text-sm);
    color: var(--text-primary);
    font-weight: 600;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .hero-secondary-content time {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
  }

  /* Sections */
  .section {
    padding: var(--space-12) 0;
  }

  .section-title {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-8);
  }

  .home-sidebar {
    display: none;
  }

  @media (min-width: 1024px) {
    .home-sidebar {
      display: block;
    }
  }
</style>
