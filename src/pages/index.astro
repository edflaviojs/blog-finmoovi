---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/header/Header.astro';
import Footer from '@components/footer/Footer.astro';
import PostGrid from '@components/posts/PostGrid.astro';
import Sidebar from '@components/sidebar/Sidebar.astro';
import { getCollection } from 'astro:content';

// Strictly filter by locale PT only
const allPosts = await getCollection('posts', ({ data }) => !data.draft && data.locale === 'pt');
const sortedPosts = allPosts.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

// Hero: most recent PT post
const heroPost = sortedPosts[0];

// 3 dynamic cards: latest post (not hero), latest cotação, latest glossário
const latestPost = sortedPosts.find(p => p.slug !== heroPost?.slug && p.data.category !== 'cotacoes');
const latestCotacao = sortedPosts.find(p => p.data.category === 'cotacoes');

// Get latest glossário from glossario collection
const allGlossario = await getCollection('glossario', ({ data }) => data.locale === 'pt');
const sortedGlossario = allGlossario.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
const latestGlossario = sortedGlossario[0];

// Build secondary cards array (always 3)
const secondaryCards = [];
if (latestPost) {
  secondaryCards.push({
    title: latestPost.data.title,
    image: latestPost.data.image,
    category: latestPost.data.category,
    href: `/posts/${latestPost.slug}`,
    date: latestPost.data.publishedAt,
    type: 'post',
  });
}
if (latestCotacao) {
  secondaryCards.push({
    title: latestCotacao.data.title,
    image: latestCotacao.data.image,
    category: 'cotacoes',
    href: `/posts/${latestCotacao.slug}`,
    date: latestCotacao.data.publishedAt,
    type: 'cotacao',
  });
}
if (latestGlossario) {
  secondaryCards.push({
    title: latestGlossario.data.term,
    image: latestGlossario.data.image,
    category: 'glossario',
    href: `/glossario/${latestGlossario.slug}`,
    date: latestGlossario.data.publishedAt,
    type: 'glossario',
  });
}

// Fill remaining slots with posts if needed
if (secondaryCards.length < 3) {
  const remaining = sortedPosts.filter(p =>
    p.slug !== heroPost?.slug &&
    !secondaryCards.some(c => c.href === `/posts/${p.slug}`)
  );
  for (const post of remaining) {
    if (secondaryCards.length >= 3) break;
    secondaryCards.push({
      title: post.data.title,
      image: post.data.image,
      category: post.data.category,
      href: `/posts/${post.slug}`,
      date: post.data.publishedAt,
      type: 'post',
    });
  }
}

const recentPosts = sortedPosts.slice(0, 9);
const postsForGrid = recentPosts.map(post => ({
  title: post.data.title,
  description: post.data.description,
  image: post.data.image,
  href: `/posts/${post.slug}`,
  category: post.data.category,
  date: post.data.publishedAt.toISOString(),
  readingTime: post.data.readingTime,
}));

const categoryLabels: Record<string, string> = {
  dicas: 'Dicas',
  orcamento: 'Orçamento',
  investimentos: 'Investimentos',
  cotacoes: 'Cotações',
  ferramentas: 'Ferramentas',
  glossario: 'Glossário',
};
---

<BaseLayout
  title="FinMoovi Blog"
  description="Dicas práticas de finanças pessoais, controle de gastos e educação financeira. Organize sua vida financeira com o FinMoovi."
  keywords={['finanças pessoais', 'controle financeiro', 'educação financeira', 'orçamento', 'investimentos']}
>
  <Header />

  <main>
    <!-- Hero Portal Style -->
    <section class="hero-portal">
      <div class="container">
        {heroPost && (
          <div class="hero-grid">
            <!-- Main Featured Post -->
            <a href={`/posts/${heroPost.slug}`} class="hero-main">
              <div class="hero-main-image">
                {heroPost.data.image && <img src={heroPost.data.image} alt="" loading="eager" />}
                <div class="hero-main-overlay"></div>
              </div>
              <div class="hero-main-content">
                <span class="hero-category">{categoryLabels[heroPost.data.category] || heroPost.data.category}</span>
                <h1 class="hero-title">{heroPost.data.title}</h1>
                <p class="hero-description">{heroPost.data.description}</p>
                <div class="hero-meta">
                  <time datetime={heroPost.data.publishedAt.toISOString()}>
                    {heroPost.data.publishedAt.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}
                  </time>
                  {heroPost.data.readingTime && <span>· {heroPost.data.readingTime} min de leitura</span>}
                </div>
              </div>
            </a>

            <!-- 3 Dynamic Secondary Cards -->
            <div class="hero-secondary">
              {secondaryCards.map(card => (
                <a href={card.href} class="hero-secondary-card">
                  <div class="hero-secondary-image">
                    {card.image ? (
                      <img src={card.image} alt="" loading="eager" />
                    ) : (
                      <div class={`hero-secondary-placeholder hero-placeholder-${card.type}`}></div>
                    )}
                  </div>
                  <div class="hero-secondary-content">
                    <span class="hero-secondary-category">{categoryLabels[card.category] || card.category}</span>
                    <h3 class="hero-secondary-title">{card.title}</h3>
                    <time datetime={card.date.toISOString()}>
                      {card.date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short' })}
                    </time>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </section>

    <!-- Recent Posts + Sidebar -->
    <section class="section">
      <div class="container">
        <h2 class="section-title" data-i18n="section.ultimosPosts">Últimos Posts</h2>
        <div class="layout-with-sidebar">
          <div>
            <PostGrid posts={postsForGrid} columns={2} />
          </div>
          <aside class="home-sidebar">
            <Sidebar />
          </aside>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* Hero Portal */
  .hero-portal {
    padding: var(--space-8) 0 var(--space-12);
    border-bottom: 1px solid var(--border-muted);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: 2fr 1fr;
    }
  }

  /* Main Hero Post */
  .hero-main {
    position: relative;
    display: block;
    border-radius: var(--radius-xl);
    overflow: hidden;
    min-height: 400px;
    text-decoration: none;
    transition: transform var(--transition-base);
  }

  .hero-main:hover {
    transform: scale(1.01);
  }

  .hero-main-image {
    position: absolute;
    inset: 0;
  }

  .hero-main-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-main-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(13, 17, 23, 0.95) 0%, rgba(13, 17, 23, 0.4) 50%, rgba(13, 17, 23, 0.2) 100%);
  }

  .hero-main-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    height: 100%;
    min-height: 400px;
    padding: var(--space-8);
  }

  .hero-category {
    display: inline-block;
    padding: 3px var(--space-3);
    background: rgba(0, 240, 255, 0.15);
    color: #00F0FF;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-3);
    width: fit-content;
  }

  .hero-title {
    font-size: var(--text-3xl);
    color: #fff;
    line-height: 1.2;
    margin-bottom: var(--space-3);
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: var(--text-4xl);
    }
  }

  .hero-description {
    font-size: var(--text-base);
    color: rgba(255, 255, 255, 0.7);
    max-width: 600px;
    margin-bottom: var(--space-4);
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.5);
  }

  /* Secondary Cards - 3 cards */
  .hero-secondary {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .hero-secondary-card {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-3);
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .hero-secondary-card:hover {
    border-color: rgba(0, 240, 255, 0.3);
    background: var(--bg-tertiary);
  }

  .hero-secondary-image {
    width: 90px;
    height: 70px;
    border-radius: var(--radius-md);
    overflow: hidden;
    flex-shrink: 0;
  }

  .hero-secondary-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-secondary-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-placeholder-post {
    background: linear-gradient(135deg, #58a6ff 0%, #bc8cff 100%);
  }

  .hero-placeholder-cotacao {
    background: linear-gradient(135deg, #3fb950 0%, #58a6ff 100%);
  }

  .hero-placeholder-glossario {
    background: linear-gradient(135deg, #d29922 0%, #f85149 100%);
  }

  .hero-secondary-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 2px;
    min-width: 0;
  }

  .hero-secondary-category {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #00F0FF;
  }

  .hero-secondary-title {
    font-size: var(--text-sm);
    color: var(--text-primary);
    font-weight: 600;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .hero-secondary-content time {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
  }

  /* Sections */
  .section {
    padding: var(--space-12) 0;
  }

  .section-title {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-8);
  }

  .home-sidebar {
    display: none;
  }

  @media (min-width: 1024px) {
    .home-sidebar {
      display: block;
    }
  }
</style>
