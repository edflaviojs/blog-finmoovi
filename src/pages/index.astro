---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/header/Header.astro';
import Footer from '@components/footer/Footer.astro';
import PostGrid from '@components/posts/PostGrid.astro';
import { config } from '../../site.config';
import Sidebar from '@components/sidebar/Sidebar.astro';
import SchemaWebsite from '@components/seo/SchemaWebsite.astro';
import PreferredSourceCTA from '@components/shared/PreferredSourceCTA.astro';
import { getCollection } from 'astro:content';

// Strictly filter by locale PT only
const allPosts = await getCollection('posts', ({ data }) => !data.draft && data.locale === 'pt');
// Sort by date desc, then by translationKey asc (consistent across locales)
const sortedPosts = allPosts.sort((a, b) => {
  const dateDiff = b.data.publishedAt.getTime() - a.data.publishedAt.getTime();
  if (dateDiff !== 0) return dateDiff;
  return (a.data.translationKey || '').localeCompare(b.data.translationKey || '');
});

// Get latest glossário from glossario collection
const allGlossario = await getCollection('glossario', ({ data }) => data.locale === 'pt');
const sortedGlossario = allGlossario.sort((a, b) => {
  const dateDiff = b.data.publishedAt.getTime() - a.data.publishedAt.getTime();
  if (dateDiff !== 0) return dateDiff;
  return (a.data.translationKey || '').localeCompare(b.data.translationKey || '');
});

// Hero: absolute most recent content (posts OR glossário)
const latestPost = sortedPosts[0];
const latestGlossarioItem = sortedGlossario[0];

let heroContent: { title: string; description: string; image: string | undefined; href: string; category: string; date: Date; readingTime?: number; type: string } | null = null;

const postDate = latestPost?.data.publishedAt.getTime() || 0;
const glossarioDate = latestGlossarioItem?.data.publishedAt.getTime() || 0;

if (glossarioDate > postDate && latestGlossarioItem) {
  heroContent = {
    title: latestGlossarioItem.data.term,
    description: latestGlossarioItem.data.definition || '',
    image: latestGlossarioItem.data.image,
    href: `/glossario/${latestGlossarioItem.slug}`,
    category: 'glossario',
    date: latestGlossarioItem.data.publishedAt,
    type: 'glossario',
  };
} else if (latestPost) {
  heroContent = {
    title: latestPost.data.title,
    description: latestPost.data.description,
    image: latestPost.data.image,
    href: `/posts/${latestPost.slug}`,
    category: latestPost.data.category,
    date: latestPost.data.publishedAt,
    readingTime: latestPost.data.readingTime,
    type: 'post',
  };
}

// 4 Cards: latest Dica, latest Nova Categoria, latest Cotação, latest Glossário (skip if already in Hero)
const heroSlug = heroContent?.href || '';

// Card 1: latest Dica
const latestDica = sortedPosts.find(p => p.data.category === 'dicas' && `/posts/${p.slug}` !== heroSlug)
  || sortedPosts.find(p => !['cotacoes', 'investimentos', 'orcamento', 'ferramentas'].includes(p.data.category) && `/posts/${p.slug}` !== heroSlug);

// Card 2: latest from new categories (investimentos, orcamento, ferramentas)
const latestNovaCat = sortedPosts.find(p =>
  ['investimentos', 'orcamento', 'ferramentas'].includes(p.data.category) && `/posts/${p.slug}` !== heroSlug
);

// Card 3: latest Cotação
const latestCotacao = sortedPosts.find(p => p.data.category === 'cotacoes' && `/posts/${p.slug}` !== heroSlug);

// Card 4: latest Glossário
const latestGlossarioCard = sortedGlossario.find(g => `/glossario/${g.slug}` !== heroSlug);

// Build secondary cards array (always 4)
const secondaryCards = [];
if (latestDica) {
  secondaryCards.push({
    title: latestDica.data.title,
    image: latestDica.data.image,
    category: latestDica.data.category,
    href: `/posts/${latestDica.slug}`,
    date: latestDica.data.publishedAt,
    type: 'post',
  });
}
if (latestNovaCat) {
  secondaryCards.push({
    title: latestNovaCat.data.title,
    image: latestNovaCat.data.image,
    category: latestNovaCat.data.category,
    href: `/posts/${latestNovaCat.slug}`,
    date: latestNovaCat.data.publishedAt,
    type: 'post',
  });
}
if (latestCotacao) {
  secondaryCards.push({
    title: latestCotacao.data.title,
    image: latestCotacao.data.image,
    category: 'cotacoes',
    href: `/posts/${latestCotacao.slug}`,
    date: latestCotacao.data.publishedAt,
    type: 'cotacao',
  });
}
if (latestGlossarioCard) {
  secondaryCards.push({
    title: latestGlossarioCard.data.term,
    image: latestGlossarioCard.data.image,
    category: 'glossario',
    href: `/glossario/${latestGlossarioCard.slug}`,
    date: latestGlossarioCard.data.publishedAt,
    type: 'glossario',
  });
}

// Fill remaining slots with posts if needed
if (secondaryCards.length < 4) {
  const remaining = sortedPosts.filter(p =>
    `/posts/${p.slug}` !== heroSlug &&
    !secondaryCards.some(c => c.href === `/posts/${p.slug}`)
  );
  for (const post of remaining) {
    if (secondaryCards.length >= 4) break;
    secondaryCards.push({
      title: post.data.title,
      image: post.data.image,
      category: post.data.category,
      href: `/posts/${post.slug}`,
      date: post.data.publishedAt,
      type: 'post',
    });
  }
}

const recentPosts = sortedPosts.slice(0, 9);
const postsForGrid = recentPosts.map(post => ({
  title: post.data.title,
  description: post.data.description,
  image: post.data.image,
  href: `/posts/${post.slug}`,
  category: post.data.category,
  date: post.data.publishedAt.toISOString(),
  readingTime: post.data.readingTime,
}));

const categoryLabels: Record<string, string> = {
  dicas: 'Dicas',
  orcamento: 'Orçamento',
  investimentos: 'Investimentos',
  cotacoes: 'Cotações',
  ferramentas: 'Ferramentas',
  glossario: 'Glossário',
};
---

<BaseLayout
  title={`${config.brand.name} ${config.brand.blogSuffix}`}
  description={config.siteDescription.pt}
  keywords={config.content.defaultKeywords.pt.split(', ')}
>
  <SchemaWebsite />
  <Header />

  <main>
    <!-- Hero Portal Style -->
    <section class="hero-portal">
      <div class="container">
        {heroContent && (
          <div class="hero-grid">
            <!-- Main Featured Post -->
            <a href={heroContent.href} class="hero-main">
              <div class="hero-main-image">
                {heroContent.image && <img src={heroContent.image} alt={heroContent.title} loading="eager" width="800" height="450" fetchpriority="high" />}
                <div class="hero-main-overlay"></div>
              </div>
              <div class="hero-main-content">
                <span class="hero-category">{categoryLabels[heroContent.category] || heroContent.category}</span>
                <h1 class="hero-title">{heroContent.title}</h1>
                <p class="hero-description">{heroContent.description}</p>
                <div class="hero-meta">
                  <time datetime={heroContent.date.toISOString()}>
                    {heroContent.date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}
                  </time>
                  {heroContent.readingTime && <span>· {heroContent.readingTime} min de leitura</span>}
                </div>
              </div>
            </a>

            <!-- 4 Dynamic Secondary Cards -->
            <div class="hero-secondary">
              {secondaryCards.map(card => (
                <a href={card.href} class="hero-secondary-card">
                  <div class="hero-secondary-image">
                    {card.image ? (
                      <img src={card.image} alt={card.title} loading="lazy" width="400" height="225" />
                    ) : (
                      <div class={`hero-secondary-placeholder hero-placeholder-${card.type}`}></div>
                    )}
                  </div>
                  <div class="hero-secondary-content">
                    <span class="hero-secondary-category">{categoryLabels[card.category] || card.category}</span>
                    <h3 class="hero-secondary-title">{card.title}</h3>
                    <time datetime={card.date.toISOString()}>
                      {card.date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short' })}
                    </time>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </section>

    <!-- Recent Posts + Sidebar -->
    <section class="section">
      <div class="container">
        <h2 class="section-title" data-i18n="section.ultimosPosts">Últimos Posts</h2>
        <div class="layout-with-sidebar">
          <div>
            <PostGrid posts={postsForGrid} columns={2} />
            <div class="view-all-wrap">
              <a href="/posts/page/1" class="view-all-btn">Ver todos os posts →</a>
            </div>
          </div>
          <aside class="home-sidebar">
            <Sidebar />
          </aside>
        </div>
      </div>
    </section>

    <PreferredSourceCTA locale="pt" />
  </main>

  <Footer />
</BaseLayout>

<style>
  /* Hero Portal */
  .hero-portal {
    padding: var(--space-8) 0 var(--space-12);
    border-bottom: 1px solid var(--border-muted);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: 2fr 1fr;
    }
  }

  /* Main Hero Post */
  .hero-main {
    position: relative;
    display: block;
    border-radius: var(--radius-xl);
    overflow: hidden;
    min-height: 400px;
    text-decoration: none;
    transition: transform var(--transition-base);
  }

  .hero-main:hover {
    transform: scale(1.01);
  }

  .hero-main-image {
    position: absolute;
    inset: 0;
  }

  .hero-main-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-main-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(13, 17, 23, 0.95) 0%, rgba(13, 17, 23, 0.4) 50%, rgba(13, 17, 23, 0.2) 100%);
  }

  .hero-main-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    height: 100%;
    min-height: 400px;
    padding: var(--space-8);
  }

  .hero-category {
    display: inline-block;
    padding: 3px var(--space-3);
    background: rgba(0, 240, 255, 0.15);
    color: #00F0FF;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-3);
    width: fit-content;
  }

  .hero-title {
    font-size: var(--text-3xl);
    color: #fff;
    line-height: 1.2;
    margin-bottom: var(--space-3);
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: var(--text-4xl);
    }
  }

  .hero-description {
    font-size: var(--text-base);
    color: rgba(255, 255, 255, 0.7);
    max-width: 600px;
    margin-bottom: var(--space-4);
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.5);
  }

  /* Secondary Cards - 4 cards */
  .hero-secondary {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .hero-secondary-card {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-3);
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .hero-secondary-card:hover {
    border-color: rgba(0, 240, 255, 0.3);
    background: var(--bg-tertiary);
  }

  .hero-secondary-image {
    width: 90px;
    height: 70px;
    border-radius: var(--radius-md);
    overflow: hidden;
    flex-shrink: 0;
  }

  .hero-secondary-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-secondary-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-placeholder-post {
    background: linear-gradient(135deg, #58a6ff 0%, #bc8cff 100%);
  }

  .hero-placeholder-cotacao {
    background: linear-gradient(135deg, #00F0FF 0%, #A91079 100%);
  }

  .hero-placeholder-glossario {
    background: linear-gradient(135deg, #d29922 0%, #f85149 100%);
  }

  .hero-secondary-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 2px;
    min-width: 0;
  }

  .hero-secondary-category {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #00F0FF;
  }

  .hero-secondary-title {
    font-size: var(--text-sm);
    color: var(--text-primary);
    font-weight: 600;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .hero-secondary-content time {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
  }

  /* Sections */
  .section {
    padding: var(--space-12) 0;
  }

  .section-title {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-8);
  }

  .home-sidebar {
    display: none;
  }

  @media (min-width: 1024px) {
    .home-sidebar {
      display: block;
    }
  }

  .view-all-wrap {
    text-align: center;
    margin-top: var(--space-8);
  }

  .view-all-btn {
    display: inline-block;
    padding: var(--space-3) var(--space-6);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-full);
    color: var(--text-primary);
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .view-all-btn:hover {
    border-color: var(--border-accent);
    color: var(--accent-primary);
    background: var(--bg-secondary);
  }
</style>
