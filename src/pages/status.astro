---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/header/Header.astro';
import Footer from '@components/footer/Footer.astro';
import { readdirSync, readFileSync, existsSync } from 'node:fs';
import { join } from 'node:path';

// Página INTERNA de status das automações (histórico de 30 dias do Relatório do Dia).
// noindex + fora do sitemap (sitemap-index.xml.ts é curado à mão e NÃO inclui /status)
// + fora do Pagefind (indexação é opt-in via data-pagefind-body, que esta página não tem).
// Lê os snapshots gerados pelo digest-diario-conteudo.js em BUILD TIME.

interface Snapshot {
  date: string;
  counts: { content: number; videos: number; pins: number; failures: number; runs: number };
  failures: { name: string; htmlUrl: string; timeLisbon: string }[];
  content: { title: string; url: string; label: string; locale: string; category?: string }[];
  videos: { slug: string; videoId: string; title?: string; timeLisbon?: string }[];
  pins: { slug: string; title?: string; pinId: string; postUrl?: string; timeLisbon?: string }[];
  runsSummary: { name: string; count: number; ok: number; fail: number; firstTimeLisbon: string }[];
  emails: { name: string; timeLisbon: string }[];
  pendencias: string[];
  agenda: { name: string; times: string[] }[];
}

const relDir = join(process.cwd(), '.github/data/relatorios');
let days: Snapshot[] = [];
if (existsSync(relDir)) {
  days = readdirSync(relDir)
    .filter(f => /^\d{4}-\d{2}-\d{2}\.json$/.test(f))
    .sort()
    .reverse()
    .slice(0, 30)
    .map(f => {
      try {
        return JSON.parse(readFileSync(join(relDir, f), 'utf-8')) as Snapshot;
      } catch {
        return null;
      }
    })
    .filter((s): s is Snapshot => s !== null);
}

// Pendências atuais (PENDENCIAS.md, parseado em build — mesma regra do digest).
let pendencias: string[] = [];
const pendFile = join(process.cwd(), 'PENDENCIAS.md');
if (existsSync(pendFile)) {
  pendencias = readFileSync(pendFile, 'utf-8')
    .split('\n')
    .map(l => l.trim())
    .filter(l => /^-\s*\[\s\]\s+/.test(l))
    .map(l => l.replace(/^-\s*\[\s\]\s+/, '')
      .replace(/\*\*(.+?)\*\*/g, '$1')
      .replace(/\*(.+?)\*/g, '$1')
      .replace(/`(.+?)`/g, '$1')
      .replace(/\[(.+?)\]\((.+?)\)/g, '$1'));
}

const fmtDate = (iso: string) => {
  const [y, m, d] = iso.split('-');
  return `${d}/${m}/${y}`;
};

const localeFlag: Record<string, string> = { pt: '🇧🇷', en: '🇺🇸', es: '🇪🇸' };
---

<BaseLayout
  title="Status das Automações"
  description="Histórico interno do Relatório do Dia (últimos 30 dias)."
  noindex={true}
>
  <Header />

  <main class="status-page">
    <div class="container">
      <header class="status-header">
        <h1 class="status-title">📊 Status das Automações</h1>
        <p class="status-subtitle">
          Histórico do Relatório do Dia — últimos 30 dias (horário de Lisboa).
          Atualiza a cada envio do digest (~6h40).
        </p>
      </header>

      <section class="status-pendencias">
        <h2>📋 Pendências abertas <span class="count">({pendencias.length})</span></h2>
        {pendencias.length === 0 ? (
          <p class="empty-line">Nenhuma pendência registrada. 🎉</p>
        ) : (
          <ul>
            {pendencias.map(p => <li>☐ {p}</li>)}
          </ul>
        )}
      </section>

      {days.length === 0 ? (
        <div class="status-empty">
          <p class="status-empty-icon">🌱</p>
          <p class="status-empty-title">Ainda sem histórico</p>
          <p class="status-empty-text">
            O primeiro snapshot aparece aqui após o próximo envio do Relatório do Dia (~6h40 de Lisboa).
          </p>
        </div>
      ) : (
        <div class="status-days">
          {days.map(day => (
            <article class={`status-card${(day.counts?.failures ?? 0) > 0 ? ' has-failures' : ''}`}>
              <header class="card-head">
                <h2 class="card-date">
                  {(day.counts?.failures ?? 0) > 0 ? '❌' : '✅'} {fmtDate(day.date)}
                </h2>
                <div class="card-counters">
                  <span title="Conteúdos publicados">📝 {day.counts?.content ?? 0}</span>
                  <span title="Vídeos YouTube">🎬 {day.counts?.videos ?? 0}</span>
                  <span title="Pins Pinterest">📌 {day.counts?.pins ?? 0}</span>
                  <span title="Workflows executados">⚙️ {day.counts?.runs ?? 0}</span>
                  <span class={(day.counts?.failures ?? 0) > 0 ? 'fail' : ''} title="Falhas">
                    🚨 {day.counts?.failures ?? 0}
                  </span>
                </div>
              </header>

              {(day.failures?.length ?? 0) > 0 && (
                <ul class="failures">
                  {day.failures.map(f => (
                    <li>
                      <a href={f.htmlUrl} target="_blank" rel="noopener noreferrer">❌ {f.name}</a>
                      <span class="time">{f.timeLisbon}</span>
                    </li>
                  ))}
                </ul>
              )}

              {(day.content?.length ?? 0) > 0 && (
                <details>
                  <summary>📝 Conteúdo publicado ({day.content.length})</summary>
                  <ul>
                    {day.content.map(c => (
                      <li>
                        <a href={c.url} target="_blank" rel="noopener noreferrer">
                          {localeFlag[c.locale] || ''} {c.title}
                        </a>
                        {c.label && <span class="tag">{c.label}</span>}
                        {c.category && <span class="tag">{c.category}</span>}
                      </li>
                    ))}
                  </ul>
                </details>
              )}

              {(day.videos?.length ?? 0) > 0 && (
                <details>
                  <summary>🎬 Vídeos YouTube ({day.videos.length})</summary>
                  <ul>
                    {day.videos.map(v => (
                      <li>
                        <a href={`https://youtu.be/${v.videoId}`} target="_blank" rel="noopener noreferrer">
                          ▶️ {v.title || v.slug}
                        </a>
                        {v.timeLisbon && <span class="time">{v.timeLisbon}</span>}
                      </li>
                    ))}
                  </ul>
                </details>
              )}

              {(day.pins?.length ?? 0) > 0 && (
                <details>
                  <summary>📌 Pins Pinterest ({day.pins.length})</summary>
                  <ul>
                    {day.pins.map(p => (
                      <li>
                        <a href={`https://www.pinterest.com/pin/${p.pinId}/`} target="_blank" rel="noopener noreferrer">
                          📌 {p.title || p.slug}
                        </a>
                        {p.timeLisbon && <span class="time">{p.timeLisbon}</span>}
                      </li>
                    ))}
                  </ul>
                </details>
              )}

              {(day.runsSummary?.length ?? 0) > 0 && (
                <details>
                  <summary>⚙️ Workflows ({day.runsSummary.length})</summary>
                  <ul>
                    {day.runsSummary.map(r => (
                      <li>
                        <span class="time">{r.firstTimeLisbon}</span> {r.name}
                        <span class="tag">{r.count}× · {r.ok} ✅{r.fail > 0 ? ` · ${r.fail} ❌` : ''}</span>
                      </li>
                    ))}
                  </ul>
                </details>
              )}
            </article>
          ))}
        </div>
      )}
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .status-page {
    padding: var(--space-8) 0 var(--space-16);
  }

  .status-header {
    text-align: center;
    margin-bottom: var(--space-10);
  }

  .status-title {
    font-size: var(--text-3xl);
    background: var(--gradient-hero);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: var(--space-3);
  }

  .status-subtitle {
    font-size: var(--text-base);
    color: var(--text-secondary);
    max-width: 560px;
    margin: 0 auto;
  }

  .status-pendencias {
    max-width: 760px;
    margin: 0 auto var(--space-8);
    padding: var(--space-5) var(--space-6);
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    border-left: 3px solid var(--accent-yellow);
    border-radius: var(--radius-lg);
  }

  .status-pendencias h2 {
    font-size: var(--text-lg);
    margin: 0 0 var(--space-3);
  }

  .status-pendencias .count {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    font-weight: 400;
  }

  .status-pendencias ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .status-pendencias li {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    padding: var(--space-1) 0;
    border-bottom: 1px solid var(--border-muted);
  }

  .status-pendencias li:last-child {
    border-bottom: none;
  }

  .status-days {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 760px;
    margin: 0 auto;
  }

  .status-card {
    padding: var(--space-5) var(--space-6);
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
  }

  .status-card.has-failures {
    border-color: var(--accent-red);
  }

  .card-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-2);
  }

  .card-date {
    font-size: var(--text-lg);
    margin: 0;
  }

  .card-counters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .card-counters .fail {
    color: var(--accent-red);
    font-weight: 600;
  }

  .failures {
    list-style: none;
    margin: var(--space-3) 0 0;
    padding: 0;
  }

  .failures li {
    padding: var(--space-1) 0;
    font-size: var(--text-sm);
  }

  .failures a {
    color: var(--accent-red);
    font-weight: 600;
    text-decoration: none;
  }

  .failures a:hover {
    text-decoration: underline;
  }

  details {
    margin-top: var(--space-3);
    border-top: 1px solid var(--border-muted);
    padding-top: var(--space-2);
  }

  summary {
    cursor: pointer;
    font-size: var(--text-sm);
    color: var(--text-secondary);
    user-select: none;
  }

  summary:hover {
    color: var(--text-primary, #f0f6fc);
  }

  details ul {
    list-style: none;
    margin: var(--space-2) 0 0;
    padding: 0 0 0 var(--space-4);
  }

  details li {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    padding: var(--space-1) 0;
  }

  details a {
    color: var(--text-link);
    text-decoration: none;
  }

  details a:hover {
    text-decoration: underline;
  }

  .time {
    color: var(--text-tertiary, #8b949e);
    font-size: var(--text-xs, 0.75rem);
    margin-left: var(--space-2);
  }

  .tag {
    display: inline-block;
    margin-left: var(--space-2);
    font-size: var(--text-xs, 0.75rem);
    color: var(--text-tertiary, #8b949e);
    background: var(--bg-primary);
    border: 1px solid var(--border-default);
    border-radius: 10px;
    padding: 0 8px;
  }

  .empty-line {
    color: var(--text-tertiary, #8b949e);
    font-size: var(--text-sm);
    margin: 0;
  }

  .status-empty {
    text-align: center;
    max-width: 480px;
    margin: var(--space-12) auto;
    padding: var(--space-10) var(--space-6);
    background: var(--bg-secondary);
    border: 1px dashed var(--border-default);
    border-radius: var(--radius-lg);
  }

  .status-empty-icon {
    font-size: 2.5rem;
    margin: 0 0 var(--space-3);
  }

  .status-empty-title {
    font-size: var(--text-lg);
    font-weight: 600;
    margin: 0 0 var(--space-2);
  }

  .status-empty-text {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    margin: 0;
  }
</style>
