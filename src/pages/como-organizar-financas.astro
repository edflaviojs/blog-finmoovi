---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/header/Header.astro';
import Footer from '@components/footer/Footer.astro';
import SchemaBreadcrumb from '@components/seo/SchemaBreadcrumb.astro';

const breadcrumbItems = [
  { name: 'Início', url: '/' },
  { name: 'Como Organizar Finanças', url: '/como-organizar-financas' }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Como organizar minhas finanças pessoais?",
      "acceptedAnswer": { "@type": "Answer", "text": "Comece listando todas as suas receitas e despesas. Use a regra 50-30-20: 50% para necessidades, 30% para desejos e 20% para poupança. Automatize pagamentos e use um app como o FinMoovi para acompanhar tudo em tempo real." }
    },
    {
      "@type": "Question",
      "name": "Qual o primeiro passo para organizar finanças?",
      "acceptedAnswer": { "@type": "Answer", "text": "O primeiro passo é saber para onde seu dinheiro vai. Anote todos os gastos por 30 dias — sem julgamento. Só depois de entender o cenário completo você consegue fazer ajustes efetivos." }
    },
    {
      "@type": "Question",
      "name": "Existe app gratuito para organizar finanças?",
      "acceptedAnswer": { "@type": "Answer", "text": "Sim! O FinMoovi é gratuito por 7 dias e oferece controle multi-moeda, funciona offline, e usa inteligência artificial para categorizar seus gastos automaticamente." }
    },
    {
      "@type": "Question",
      "name": "Como sair das dívidas e organizar a vida financeira?",
      "acceptedAnswer": { "@type": "Answer", "text": "Liste todas as dívidas (valor, juros, parcelas). Priorize as de maior juros (cartão de crédito, cheque especial). Negocie com o banco e monte um plano de pagamento. Enquanto quita, evite criar novas dívidas." }
    }
  ]
};
---

<BaseLayout
  title="Como Organizar Finanças Pessoais - Guia Completo 2026"
  description="Aprenda como organizar suas finanças pessoais do zero. Método passo a passo, ferramentas gratuitas e dicas práticas para sair das dívidas e começar a investir."
  keywords={['como organizar finanças', 'organizar finanças pessoais', 'controle financeiro', 'como sair das dívidas', 'app finanças']}
>
  <SchemaBreadcrumb items={breadcrumbItems} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Header />

  <main class="landing-page">
    <!-- Hero -->
    <section class="landing-hero">
      <div class="container">
        <h1>Como Organizar suas Finanças Pessoais</h1>
        <p class="hero-subtitle">O guia definitivo para sair do caos financeiro e começar a construir patrimônio — mesmo ganhando pouco.</p>
        <div class="hero-cta-group">
          <a href="https://finmoovi.com" class="cta-primary" target="_blank" rel="noopener">Começar com o FinMoovi (Grátis)</a>
          <a href="#metodo" class="cta-secondary">Ver o método ↓</a>
        </div>
      </div>
    </section>

    <!-- Método -->
    <section class="landing-section" id="metodo">
      <div class="container">
        <h2>O Método dos 5 Passos</h2>
        <p class="section-subtitle">Simples, prático e funciona para qualquer renda.</p>

        <div class="steps-grid">
          <div class="step-card">
            <span class="step-number">1</span>
            <h3>Mapeie seus gastos</h3>
            <p>Anote tudo que entra e sai por 30 dias. Sem essa foto inicial, qualquer plano é cego.</p>
          </div>
          <div class="step-card">
            <span class="step-number">2</span>
            <h3>Aplique a regra 50-30-20</h3>
            <p>Divida: 50% necessidades, 30% desejos, 20% futuro. <a href="/ferramentas/calculadora-orcamento">Use nossa calculadora</a>.</p>
          </div>
          <div class="step-card">
            <span class="step-number">3</span>
            <h3>Monte reserva de emergência</h3>
            <p>Guarde 3 a 6 meses de gastos fixos. É o colchão que impede recaídas.</p>
          </div>
          <div class="step-card">
            <span class="step-number">4</span>
            <h3>Quite dívidas caras</h3>
            <p>Cartão e cheque especial primeiro. Negocie e livre-se dos juros compostos contra você.</p>
          </div>
          <div class="step-card">
            <span class="step-number">5</span>
            <h3>Comece a investir</h3>
            <p>Nem que seja R$ 50/mês. Juros compostos a seu favor. <a href="/ferramentas/calculadora-juros-compostos">Simule aqui</a>.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Ferramentas -->
    <section class="landing-section dark">
      <div class="container">
        <h2>Ferramentas Gratuitas para te Ajudar</h2>
        <div class="tools-grid">
          <a href="/ferramentas/calculadora-orcamento" class="tool-link">
            <span class="tool-icon">💰</span>
            <span class="tool-name">Calculadora 50-30-20</span>
          </a>
          <a href="/ferramentas/calculadora-juros-compostos" class="tool-link">
            <span class="tool-icon">📈</span>
            <span class="tool-name">Juros Compostos</span>
          </a>
          <a href="/ferramentas/simulador-investimento" class="tool-link">
            <span class="tool-icon">🎯</span>
            <span class="tool-name">Simulador de Investimento</span>
          </a>
          <a href="/ferramentas/conversor-moedas" class="tool-link">
            <span class="tool-icon">💱</span>
            <span class="tool-name">Conversor de Moedas</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Newsletter capture -->
    <section class="landing-section">
      <div class="container">
        <div class="capture-box">
          <h2>Receba dicas toda semana</h2>
          <p>Uma dica de finanças por dia, cotações semanais e ferramentas exclusivas. Grátis e sem spam.</p>
          <form class="capture-form" id="capture-form">
            <input type="email" id="capture-email" placeholder="seu@email.com" required />
            <button type="submit">Inscrever-se</button>
          </form>
          <p class="capture-message" id="capture-message"></p>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="landing-section">
      <div class="container">
        <h2>Perguntas Frequentes</h2>
        <div class="faq-grid">
          <details>
            <summary>Como organizar minhas finanças pessoais?</summary>
            <p>Comece listando todas as suas receitas e despesas. Use a regra 50-30-20: 50% para necessidades, 30% para desejos e 20% para poupança. Automatize pagamentos e use um app como o FinMoovi para acompanhar tudo em tempo real.</p>
          </details>
          <details>
            <summary>Qual o primeiro passo para organizar finanças?</summary>
            <p>O primeiro passo é saber para onde seu dinheiro vai. Anote todos os gastos por 30 dias — sem julgamento. Só depois de entender o cenário completo você consegue fazer ajustes efetivos.</p>
          </details>
          <details>
            <summary>Existe app gratuito para organizar finanças?</summary>
            <p>Sim! O FinMoovi é gratuito por 7 dias e oferece controle multi-moeda, funciona offline, e usa inteligência artificial para categorizar seus gastos automaticamente.</p>
          </details>
          <details>
            <summary>Como sair das dívidas e organizar a vida financeira?</summary>
            <p>Liste todas as dívidas (valor, juros, parcelas). Priorize as de maior juros (cartão de crédito, cheque especial). Negocie com o banco e monte um plano de pagamento. Enquanto quita, evite criar novas dívidas.</p>
          </details>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="landing-section cta-section">
      <div class="container">
        <h2>Pronto para organizar suas finanças?</h2>
        <p>Milhares de pessoas já usam o FinMoovi para controlar gastos e investir melhor.</p>
        <a href="https://finmoovi.com" class="cta-primary large" target="_blank" rel="noopener">Experimentar Grátis — 7 dias</a>
        <span class="cta-note">Sem cartão de crédito. Cancele quando quiser.</span>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  document.getElementById('capture-form')?.addEventListener('submit', async function(e) {
    e.preventDefault();
    const email = document.getElementById('capture-email').value.trim();
    const msg = document.getElementById('capture-message');
    const btn = this.querySelector('button');
    if (!email) return;
    btn.disabled = true;
    btn.textContent = '...';
    try {
      const res = await fetch('/api/newsletter', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, lang: 'pt', source: 'como-organizar-financas' })
      });
      const data = await res.json();
      msg.textContent = res.ok ? (data.message || 'Inscrito!') : (data.error || 'Erro.');
      msg.className = 'capture-message ' + (res.ok ? 'success' : 'error');
    } catch (err) {
      msg.textContent = 'Erro de conexão.';
      msg.className = 'capture-message error';
    }
    btn.disabled = false;
    btn.textContent = 'Inscrever-se';
  });
</script>

<style>
  .landing-page { }

  .landing-hero {
    padding: 4rem 0;
    text-align: center;
    background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
  }
  .landing-hero h1 {
    font-size: 2.5rem;
    color: var(--text-primary);
    margin-bottom: 1rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }
  .hero-subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 550px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }
  .hero-cta-group { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .cta-primary {
    display: inline-block;
    padding: 14px 32px;
    background: linear-gradient(135deg, #3fb950, #58a6ff);
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    border-radius: 10px;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .cta-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(63, 185, 80, 0.3); }
  .cta-primary.large { font-size: 1.1rem; padding: 16px 40px; }
  .cta-secondary {
    display: inline-block;
    padding: 14px 32px;
    color: var(--text-link);
    font-weight: 600;
    text-decoration: none;
    border: 1px solid var(--border-default);
    border-radius: 10px;
  }
  .cta-secondary:hover { border-color: var(--text-link); }

  .landing-section { padding: 3rem 0; }
  .landing-section.dark { background: var(--bg-secondary); }
  .landing-section h2 { font-size: 1.8rem; color: var(--text-primary); text-align: center; margin-bottom: 0.5rem; }
  .section-subtitle { text-align: center; color: var(--text-secondary); margin-bottom: 2rem; }

  .steps-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-top: 2rem; }
  .step-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    border-radius: 12px;
    padding: 1.5rem;
    position: relative;
  }
  .step-number {
    position: absolute;
    top: -12px;
    left: 16px;
    background: linear-gradient(135deg, #3fb950, #58a6ff);
    color: #fff;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.8rem;
  }
  .step-card h3 { color: var(--text-primary); font-size: 1rem; margin: 0.5rem 0; }
  .step-card p { color: var(--text-secondary); font-size: 0.85rem; line-height: 1.5; margin: 0; }
  .step-card a { color: var(--text-link); }

  .tools-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1rem; margin-top: 1.5rem; }
  .tool-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1.2rem;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-default);
    border-radius: 10px;
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s;
  }
  .tool-link:hover { border-color: #3fb950; transform: translateY(-2px); }
  .tool-icon { font-size: 1.8rem; }
  .tool-name { color: var(--text-primary); font-size: 0.85rem; font-weight: 600; text-align: center; }

  .capture-box {
    max-width: 500px;
    margin: 0 auto;
    text-align: center;
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    border-radius: 12px;
    padding: 2rem;
  }
  .capture-box h2 { font-size: 1.4rem; margin-bottom: 0.5rem; }
  .capture-box p { color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 1.2rem; }
  .capture-form { display: flex; gap: 0.5rem; }
  .capture-form input {
    flex: 1;
    padding: 0.7rem 1rem;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-default);
    border-radius: 8px;
    color: var(--text-primary);
    font-size: 0.9rem;
  }
  .capture-form input:focus { outline: none; border-color: var(--accent-primary); }
  .capture-form button {
    padding: 0.7rem 1.5rem;
    background: linear-gradient(135deg, #3fb950, #58a6ff);
    color: #fff;
    font-weight: 600;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    white-space: nowrap;
  }
  .capture-message { font-size: 0.8rem; margin-top: 0.5rem; }
  .capture-message.success { color: #3fb950; }
  .capture-message.error { color: #f85149; }

  .faq-grid { max-width: 700px; margin: 1.5rem auto 0; }
  .faq-grid details {
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    border-radius: 8px;
    margin-bottom: 0.5rem;
    padding: 1rem;
  }
  .faq-grid summary { color: var(--text-primary); font-weight: 600; cursor: pointer; }
  .faq-grid details p { color: var(--text-secondary); margin-top: 0.75rem; line-height: 1.6; font-size: 0.9rem; }

  .cta-section { text-align: center; padding: 4rem 0; }
  .cta-section p { color: var(--text-secondary); margin-bottom: 1.5rem; }
  .cta-note { display: block; margin-top: 0.75rem; font-size: 0.8rem; color: var(--text-tertiary); }

  @media (max-width: 640px) {
    .landing-hero h1 { font-size: 1.8rem; }
    .capture-form { flex-direction: column; }
  }
</style>
