---
import PostCard from '../posts/PostCard.astro';
import { getCollection } from 'astro:content';

interface Props {
  currentSlug: string;
  category: string;
  locale: string;
}

const { currentSlug, category, locale } = Astro.props;

// Query posts: same category + same locale, exclude current, sort by date, take 3
const allPosts = await getCollection('posts', ({ data, slug }) =>
  !data.draft &&
  data.locale === locale &&
  data.category === category &&
  slug !== currentSlug
);

const relatedPosts = allPosts
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);

// Locale-aware heading
const headingMap: Record<string, string> = {
  pt: 'Leia também',
  en: 'Read also',
  es: 'Lee también',
};
const heading = headingMap[locale] || headingMap.pt;

// Locale-aware href prefix
const localePrefix = locale === 'pt' ? '' : `/${locale}`;
---

{relatedPosts.length > 0 && (
  <section class="related-posts" aria-label={heading}>
    <h3 class="related-title">{heading}</h3>
    <div class="related-grid">
      {relatedPosts.map(post => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          image={post.data.image}
          href={`${localePrefix}/posts/${post.slug}`}
          category={post.data.category}
          date={post.data.publishedAt.toISOString()}
          readingTime={post.data.readingTime}
        />
      ))}
    </div>
  </section>
)}

<style>
  .related-posts {
    margin-top: var(--space-16);
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-default);
  }

  .related-title {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-6);
  }

  .related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 640px) {
    .related-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .related-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
