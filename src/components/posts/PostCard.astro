---
import { imgSrcset } from '@/utils/responsive-image';

interface Props {
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  href: string;
  category?: string;
  date?: string;
  readingTime?: number;
}

const { title, description, image, imageAlt, href, category, date, readingTime } = Astro.props;
---

<article class="post-card">
  <a href={href} class="post-card-link" aria-label={`Ler: ${title}`}>
    {image && (
      <div class="post-card-image">
        <img src={image} srcset={imgSrcset(image)} sizes="(min-width: 640px) 400px, 100vw" alt={imageAlt || title} loading="lazy" width="400" height="225" />
      </div>
    )}

    <div class="post-card-body">
      {category && <span class="post-card-category" data-i18n={`cat.${category}`}>{category}</span>}
      <h3 class="post-card-title">{title}</h3>
      <p class="post-card-description">{description}</p>

      <div class="post-card-footer">
        {date && (
          <time datetime={date}>
            {new Date(date).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short' })}
          </time>
        )}
        {readingTime && <span>{readingTime} min</span>}
      </div>
    </div>
  </a>
</article>

<style>
  .post-card {
    background: var(--gradient-card);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94), border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .post-card:hover {
    border-color: var(--border-accent);
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  .post-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .post-card-image {
    aspect-ratio: 16/9;
    overflow: hidden;
  }

  .post-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .post-card:hover .post-card-image img {
    transform: scale(1.02);
  }

  .post-card-body {
    padding: var(--space-5);
  }

  .post-card-category {
    display: inline-block;
    padding: 2px var(--space-2);
    background: rgba(88, 166, 255, 0.1);
    color: var(--accent-primary);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-weight: 500;
    margin-bottom: var(--space-3);
  }

  .post-card-title {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-2);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-description {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: var(--space-4);
  }

  .post-card-footer {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-xs);
    color: var(--text-tertiary);
  }

  .post-card-footer span::before {
    content: '·';
    margin-right: var(--space-2);
  }
</style>
