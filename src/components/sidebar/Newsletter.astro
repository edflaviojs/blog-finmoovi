---
const urlPath = Astro.url?.pathname || '';
let locale = 'pt';
if (urlPath.startsWith('/en/')) locale = 'en';
else if (urlPath.startsWith('/es/')) locale = 'es';

const texts = {
  pt: {
    title: 'Newsletter Semanal',
    desc: 'Receba as melhores dicas de finanças toda semana no seu email.',
    placeholder: 'seu@email.com',
    btn: 'Inscrever',
    privacy: 'Sem spam. Cancele quando quiser.'
  },
  en: {
    title: 'Weekly Newsletter',
    desc: 'Get the best finance tips delivered to your inbox every week.',
    placeholder: 'your@email.com',
    btn: 'Subscribe',
    privacy: 'No spam. Unsubscribe anytime.'
  },
  es: {
    title: 'Newsletter Semanal',
    desc: 'Recibe los mejores consejos de finanzas cada semana en tu email.',
    placeholder: 'tu@email.com',
    btn: 'Suscribirse',
    privacy: 'Sin spam. Cancela cuando quieras.'
  }
};
const t = texts[locale] || texts.pt;
---

<div class="sidebar-widget newsletter-widget">
  <h4 class="widget-title">{t.title}</h4>
  <p class="widget-description">{t.desc}</p>
  <form class="newsletter-form" id="newsletter-form">
    <input
      type="email"
      name="email"
      placeholder={t.placeholder}
      required
      class="newsletter-input"
      id="newsletter-email"
      aria-label="Email"
    />
    <button type="submit" class="newsletter-button" id="newsletter-btn">
      {t.btn}
    </button>
  </form>
  <p class="newsletter-message" id="newsletter-message"></p>
  <p class="newsletter-privacy">{t.privacy}</p>
</div>

<script>
  document.getElementById('newsletter-form')?.addEventListener('submit', async function(e) {
    e.preventDefault();
    var btn = document.getElementById('newsletter-btn');
    var msg = document.getElementById('newsletter-message');
    var email = document.getElementById('newsletter-email').value.trim();

    if (!email) return;

    btn.disabled = true;
    btn.textContent = '...';
    msg.textContent = '';
    msg.className = 'newsletter-message';

    // Detect locale from URL
    var path = window.location.pathname;
    var lang = 'pt';
    if (path.startsWith('/en/') || path === '/en') lang = 'en';
    else if (path.startsWith('/es/') || path === '/es') lang = 'es';

    try {
      var res = await fetch('/api/newsletter', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email, lang: lang })
      });

      var data = await res.json();

      if (res.ok) {
        msg.textContent = data.message || 'Inscrito com sucesso!';
        msg.className = 'newsletter-message success';
        document.getElementById('newsletter-email').value = '';
      } else {
        msg.textContent = data.error || 'Erro ao inscrever. Tente novamente.';
        msg.className = 'newsletter-message error';
      }
    } catch (err) {
      msg.textContent = 'Erro de conexão. Tente novamente.';
      msg.className = 'newsletter-message error';
    }

    btn.disabled = false;
    var btnTexts = { pt: 'Inscrever', en: 'Subscribe', es: 'Suscribirse' };
    btn.textContent = btnTexts[lang] || 'Inscrever';
  });
</script>

<style>
  .newsletter-widget {
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }

  .widget-title {
    font-size: var(--text-base);
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .widget-description {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-bottom: var(--space-4);
  }

  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .newsletter-input {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    background: var(--bg-tertiary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    font-size: var(--text-sm);
    transition: border-color var(--transition-fast);
  }

  .newsletter-input::placeholder {
    color: var(--text-tertiary);
  }

  .newsletter-input:focus {
    border-color: var(--accent-primary);
    outline: none;
  }

  .newsletter-button {
    padding: var(--space-3);
    background: var(--accent-primary);
    color: #fff;
    font-weight: 600;
    font-size: var(--text-sm);
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }

  .newsletter-button:hover {
    background: #4a9aef;
    transform: translateY(-1px);
  }

  .newsletter-button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .newsletter-message {
    font-size: var(--text-xs);
    text-align: center;
    margin-top: var(--space-2);
    margin-bottom: 0;
    min-height: 1.2em;
  }

  .newsletter-message.success {
    color: var(--accent-green);
  }

  .newsletter-message.error {
    color: var(--accent-red);
  }

  .newsletter-privacy {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    text-align: center;
    margin-top: var(--space-2);
    margin-bottom: 0;
  }
</style>
