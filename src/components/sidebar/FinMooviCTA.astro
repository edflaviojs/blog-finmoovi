---
const urlPath = Astro.url?.pathname || '';
let locale = 'pt';
if (urlPath.startsWith('/en/')) locale = 'en';
else if (urlPath.startsWith('/es/')) locale = 'es';

const texts = {
  pt: {
    badge: 'App Gratuito',
    title: 'Organize suas finanças com o FinMoovi',
    desc: 'Controle gastos, acompanhe investimentos e alcance seus objetivos financeiros. Multi-moeda, offline e inteligente.',
    f1: '✓ Multi-moeda (BRL, USD, EUR)',
    f2: '✓ Smart Capture com IA',
    f3: '✓ Relatórios inteligentes',
    f4: '✓ 100% offline e seguro',
    btn: 'Experimentar Grátis — 7 dias',
    note: 'Sem cartão de crédito. Cancele quando quiser.'
  },
  en: {
    badge: 'Free App',
    title: 'Organize your finances with FinMoovi',
    desc: 'Track expenses, monitor investments, and reach your financial goals. Multi-currency, offline, and smart.',
    f1: '✓ Multi-currency (BRL, USD, EUR)',
    f2: '✓ AI Smart Capture',
    f3: '✓ Intelligent reports',
    f4: '✓ 100% offline and secure',
    btn: 'Try Free — 7 days',
    note: 'No credit card. Cancel anytime.'
  },
  es: {
    badge: 'App Gratuita',
    title: 'Organiza tus finanzas con FinMoovi',
    desc: 'Controla gastos, acompaña inversiones y alcanza tus objetivos financieros. Multi-moneda, offline e inteligente.',
    f1: '✓ Multi-moneda (BRL, USD, EUR)',
    f2: '✓ Smart Capture con IA',
    f3: '✓ Reportes inteligentes',
    f4: '✓ 100% offline y seguro',
    btn: 'Probar Gratis — 7 días',
    note: 'Sin tarjeta de crédito. Cancela cuando quieras.'
  }
};
const t = texts[locale] || texts.pt;
---

<a href="https://finmoovi.com" target="_blank" rel="noopener noreferrer" class="sidebar-widget cta-widget">
  <div class="cta-badge">{t.badge}</div>
  <h3 class="cta-title">{t.title}</h3>
  <p class="cta-description">{t.desc}</p>
  <ul class="cta-features">
    <li>{t.f1}</li>
    <li>{t.f2}</li>
    <li>{t.f3}</li>
    <li>{t.f4}</li>
  </ul>
  <span class="cta-button">{t.btn}</span>
  <p class="cta-note">{t.note}</p>
</a>

<style>
  .cta-widget {
    display: block;
    background: var(--gradient-card);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    position: relative;
    overflow: visible;
    text-decoration: none;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .cta-widget:hover {
    border-color: var(--accent-green);
    box-shadow: 0 0 20px rgba(63, 185, 80, 0.1);
  }

  .cta-widget::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--gradient-cta);
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  }

  .cta-badge {
    display: inline-block;
    padding: 2px var(--space-3);
    background: rgba(63, 185, 80, 0.15);
    color: var(--accent-green);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
    margin-bottom: var(--space-4);
  }

  .cta-title {
    font-size: var(--text-lg);
    color: var(--text-primary);
    margin-bottom: var(--space-3);
    line-height: 1.3;
  }

  .cta-description {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-bottom: var(--space-4);
    line-height: var(--leading-relaxed);
  }

  .cta-features {
    margin-bottom: var(--space-5);
  }

  .cta-features li {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    padding: var(--space-1) 0;
  }

  .cta-button {
    display: block;
    width: 100%;
    padding: var(--space-3) var(--space-4);
    background: var(--gradient-cta);
    color: #fff;
    font-weight: 600;
    font-size: var(--text-sm);
    text-align: center;
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }

  .cta-widget:hover .cta-button {
    opacity: 0.9;
    transform: translateY(-1px);
    box-shadow: var(--shadow-glow);
  }

  .cta-note {
    margin-top: var(--space-3);
    font-size: 11px;
    color: var(--text-tertiary);
    text-align: center;
  }
</style>
