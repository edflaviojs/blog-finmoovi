---
import { getCollection } from 'astro:content';

const urlPath = Astro.url.pathname;
let locale = 'pt';
if (urlPath.startsWith('/en/')) locale = 'en';
else if (urlPath.startsWith('/es/')) locale = 'es';

const allPosts = await getCollection('posts', ({ data }) =>
  !data.draft && data.locale === locale
);

const localePrefix = locale === 'pt' ? '' : `/${locale}`;

const popularPosts = allPosts
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 5);

const headingMap: Record<string, string> = {
  pt: 'Mais Recentes',
  en: 'Most Recent',
  es: 'Más Recientes',
};
---

<div class="sidebar-widget popular-widget">
  <h4 class="widget-title">{headingMap[locale]}</h4>
  <ul class="popular-list">
    {popularPosts.map((post, i) => (
      <li class="popular-item">
        <span class="popular-number">{String(i + 1).padStart(2, '0')}</span>
        <a href={`${localePrefix}/posts/${post.slug}`} class="popular-link">{post.data.title}</a>
      </li>
    ))}
  </ul>
</div>

<style>
  .popular-widget {
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }

  .widget-title {
    font-size: var(--text-base);
    color: var(--text-primary);
    margin-bottom: var(--space-4);
  }

  .popular-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .popular-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
  }

  .popular-number {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--accent-primary);
    min-width: 28px;
  }

  .popular-link {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-normal);
    transition: color var(--transition-fast);
  }

  .popular-link:hover {
    color: var(--text-primary);
  }
</style>
