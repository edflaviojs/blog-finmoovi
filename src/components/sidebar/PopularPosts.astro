---
const popularPosts = [
  { title: 'Como criar um orçamento pessoal em 5 passos', href: '/posts/como-criar-orcamento-pessoal' },
  { title: 'Regra 50-30-20: guia completo', href: '/posts/regra-50-30-20-guia-completo' },
  { title: '7 erros financeiros que todo iniciante comete', href: '/posts/7-erros-financeiros-iniciante' },
  { title: 'Como controlar gastos com cartão de crédito', href: '/posts/controlar-gastos-cartao-credito' },
];
---

<div class="sidebar-widget popular-widget">
  <h4 class="widget-title">Mais Lidos</h4>
  <ul class="popular-list">
    {popularPosts.map((post, i) => (
      <li class="popular-item">
        <span class="popular-number">{String(i + 1).padStart(2, '0')}</span>
        <a href={post.href} class="popular-link">{post.title}</a>
      </li>
    ))}
  </ul>
</div>

<style>
  .popular-widget {
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }

  .widget-title {
    font-size: var(--text-base);
    color: var(--text-primary);
    margin-bottom: var(--space-4);
  }

  .popular-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .popular-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
  }

  .popular-number {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--accent-primary);
    opacity: 0.5;
    min-width: 28px;
  }

  .popular-link {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-normal);
    transition: color var(--transition-fast);
  }

  .popular-link:hover {
    color: var(--text-primary);
  }
</style>
