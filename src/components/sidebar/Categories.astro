---
import { getCollection } from 'astro:content';

const urlPath = Astro.url.pathname;
let locale = 'pt';
if (urlPath.startsWith('/en/')) locale = 'en';
else if (urlPath.startsWith('/es/')) locale = 'es';

const allPosts = await getCollection('posts', ({ data }) =>
  !data.draft && data.locale === locale
);

const countByCategory = (cat: string) => allPosts.filter(p => p.data.category === cat).length;
const localePrefix = locale === 'pt' ? '' : `/${locale}`;

const headingMap: Record<string, string> = {
  pt: 'Categorias',
  en: 'Categories',
  es: 'Categorías',
};

const categoryNames: Record<string, Record<string, string>> = {
  pt: { dicas: 'Dicas Financeiras', orcamento: 'Orçamento', investimentos: 'Investimentos', cotacoes: 'Cotações', ferramentas: 'Ferramentas' },
  en: { dicas: 'Financial Tips', orcamento: 'Budget', investimentos: 'Investments', cotacoes: 'Quotes', ferramentas: 'Tools' },
  es: { dicas: 'Consejos', orcamento: 'Presupuesto', investimentos: 'Inversiones', cotacoes: 'Cotizaciones', ferramentas: 'Herramientas' },
};

const labels = categoryNames[locale] || categoryNames.pt;

const categories = [
  { label: labels.dicas, href: `${localePrefix}/categorias/dicas`, count: countByCategory('dicas'), color: 'var(--accent-primary)' },
  { label: labels.orcamento, href: `${localePrefix}/categorias/orcamento`, count: countByCategory('orcamento'), color: 'var(--accent-green)' },
  { label: labels.investimentos, href: `${localePrefix}/categorias/investimentos`, count: countByCategory('investimentos'), color: 'var(--accent-purple)' },
  { label: labels.cotacoes, href: `${localePrefix}/categorias/cotacoes`, count: countByCategory('cotacoes'), color: 'var(--accent-yellow)' },
  { label: labels.ferramentas, href: `${localePrefix}/categorias/ferramentas`, count: countByCategory('ferramentas'), color: 'var(--accent-red)' },
];
---

<div class="sidebar-widget categories-widget">
  <h4 class="widget-title" data-i18n="sidebar.categorias">Categorias</h4>
  <ul class="categories-list">
    {categories.map(cat => (
      <li>
        <a href={cat.href} class="category-link">
          <span class="category-dot" style={`background: ${cat.color}`}></span>
          <span class="category-label" data-i18n={cat.i18n}>{cat.label}</span>
          <span class="category-count">{cat.count}</span>
        </a>
      </li>
    ))}
  </ul>
</div>

<style>
  .categories-widget {
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }

  .widget-title {
    font-size: var(--text-base);
    color: var(--text-primary);
    margin-bottom: var(--space-4);
  }

  .categories-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .category-link {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    transition: background var(--transition-fast);
  }

  .category-link:hover {
    background: var(--bg-tertiary);
  }

  .category-dot {
    width: 8px;
    height: 8px;
    border-radius: var(--radius-full);
    flex-shrink: 0;
  }

  .category-label {
    flex: 1;
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .category-link:hover .category-label {
    color: var(--text-primary);
  }

  .category-count {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    font-family: var(--font-mono);
  }
</style>
