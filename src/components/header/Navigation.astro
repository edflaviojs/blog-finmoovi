---
import { getNavCategories } from '@/utils/nav-categories';

// Navegação portal: pills planas e deslizáveis (desktop e mobile).
// Categorias — fonte única em site.config (content.categoryNav), filtradas
// pelas que já têm posts. Adicionar categoria lá reflete aqui automaticamente.
// "Sobre" saiu do menu e vive no footer (decisão do redesign portal).
const categorias = await getNavCategories();

const fixedItems = [
  { label: 'Ferramentas', key: 'nav.ferramentas', href: '/ferramentas' },
  { label: 'Glossário', key: 'nav.glossario', href: '/glossario' },
  { label: 'Estudos', key: 'nav.estudos', href: '/estudos' },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  currentPath === href || (href !== '/' && currentPath.startsWith(href));
---

<!-- Sem pill "Início": a logo já leva à home (convenção universal) -->
<nav class="nav-pills" aria-label="Navegação principal">
  {categorias.map(c => (
    <a href={c.href} class:list={['pill', { active: isActive(c.href) }]}>{c.label}</a>
  ))}
  {fixedItems.map(item => (
    <a href={item.href} class:list={['pill', { active: isActive(item.href) }]} data-i18n={item.key}>{item.label}</a>
  ))}
</nav>

<style>
  .nav-pills {
    display: flex;
    gap: var(--space-1);
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    min-width: 0;
  }

  .nav-pills::-webkit-scrollbar { display: none; }

  .pill {
    padding: var(--space-2) var(--space-3);
    color: var(--text-secondary);
    font-size: var(--text-sm);
    font-weight: 600;
    border-radius: var(--radius-full);
    border: 1px solid transparent;
    white-space: nowrap;
    transition: all var(--transition-fast);
  }

  .pill:hover {
    color: var(--text-primary);
    background: var(--bg-tertiary);
  }

  /* Desktop: ativa em pill suave (mockup); mobile: gradiente do portal */
  .pill.active {
    background: var(--bg-tertiary);
    color: var(--text-primary);
    border-color: var(--border-default);
  }

  /* Mobile: as pills descem para a segunda linha do header, com borda */
  @media (max-width: 767px) {
    .nav-pills {
      order: 3;
      flex-basis: 100%;
      padding: var(--space-1) 0 var(--space-2);
    }

    .pill {
      border-color: var(--border-muted);
      background: var(--bg-primary);
      font-size: 13px;
      padding: 7px 14px;
    }

    .pill.active {
      border-color: transparent;
      background: linear-gradient(90deg, #00c8d7, #A91079);
      color: #fff;
    }
  }
</style>
