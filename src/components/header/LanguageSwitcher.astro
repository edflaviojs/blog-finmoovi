---
import { config } from '../../../site.config';

const ALL_LANGS = [
  { code: 'pt', flag: '🇧🇷', label: 'Português' },
  { code: 'en', flag: '🇺🇸', label: 'English' },
  { code: 'es', flag: '🇪🇸', label: 'Español' },
];
// T8: só os idiomas configurados; com 1 idioma o switcher não renderiza.
const langs = ALL_LANGS.filter(l => config.locales.includes(l.code));
---

{langs.length > 1 && (
<div class="lang-switcher" id="lang-switcher">
  <!-- Bolinha com a sigla do idioma atual (estilo do mockup portal) -->
  <button class="lang-toggle" id="lang-toggle" aria-label="Selecionar idioma" aria-expanded="false">
    <span class="lang-current-code" id="lang-current-code">PT</span>
  </button>

  <div class="lang-dropdown" id="lang-dropdown" aria-hidden="true" inert>
    {langs.map(l => (
      <button class="lang-option" data-lang={l.code} data-flag={l.flag}>
        <span class="lang-flag">{l.flag}</span>
        <span class="lang-label">{l.label}</span>
        <span class="lang-check" data-check={l.code}>✓</span>
      </button>
    ))}
  </div>
</div>
)}

<script>
  var toggle = document.getElementById('lang-toggle');
  var dropdown = document.getElementById('lang-dropdown');
  var currentCode = document.getElementById('lang-current-code');
  var options = document.querySelectorAll('.lang-option');
  var checks = document.querySelectorAll('.lang-check');

  // Detect language: URL prefix takes priority
  var path = window.location.pathname;
  var urlLang = null;
  if (path.startsWith('/en/') || path === '/en') urlLang = 'en';
  else if (path.startsWith('/es/') || path === '/es') urlLang = 'es';

  var currentLang;
  if (urlLang) {
    currentLang = urlLang;
    try { localStorage.setItem('fm-lang', currentLang); } catch(e) {}
  } else {
    currentLang = 'pt';
  }

  updateLang(currentLang);

  if (toggle) toggle.addEventListener('click', function() {
    var isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    if (dropdown) { dropdown.setAttribute('aria-hidden', String(isOpen)); dropdown.inert = isOpen; }
  });

  options.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var lang = btn.getAttribute('data-lang') || 'pt';
      try { localStorage.setItem('fm-lang', lang); } catch(e) {}
      if (toggle) toggle.setAttribute('aria-expanded', 'false');
      if (dropdown) { dropdown.setAttribute('aria-hidden', 'true'); dropdown.inert = true; }

      // Try to find alternate hreflang link for the target language.
      // Usa só o PATHNAME do alternate: mantém o usuário no host atual
      // (produção ou preview) em vez de pular para a URL absoluta de produção.
      var alternateLink = document.querySelector('link[rel="alternate"][hreflang="' + lang + '"]');
      if (alternateLink) {
        try {
          var altUrl = new URL(alternateLink.getAttribute('href'), window.location.origin);
          window.location.href = altUrl.pathname + altUrl.search;
          return;
        } catch (err) { /* cai no fallback path-based abaixo */ }
      }

      // Fallback: navigate using path-based logic
      var currentPath = window.location.pathname;
      var basePath = currentPath;

      // Strip existing locale prefix
      if (basePath.startsWith('/en/')) basePath = basePath.slice(3);
      else if (basePath.startsWith('/es/')) basePath = basePath.slice(3);
      else if (basePath === '/en' || basePath === '/es') basePath = '/';

      // Normalize trailing slash
      if (basePath.length > 1 && basePath.endsWith('/')) basePath = basePath.slice(0, -1);

      // Pages that exist in all locales with same path
      var i18nPages = ['/', '/sobre', '/glossario', '/ferramentas'];
      var canNavigate = i18nPages.some(function(p) {
        return basePath === p;
      });

      var newPath;
      if (!canNavigate) {
        newPath = lang === 'pt' ? '/' : '/' + lang;
      } else if (lang === 'pt') {
        newPath = basePath || '/';
      } else {
        newPath = '/' + lang + (basePath === '/' ? '' : basePath);
      }

      if (newPath !== currentPath) {
        window.location.href = newPath;
      }
    });
  });

  document.addEventListener('click', function(e) {
    var switcher = document.getElementById('lang-switcher');
    if (switcher && !switcher.contains(e.target)) {
      if (toggle) toggle.setAttribute('aria-expanded', 'false');
      if (dropdown) { dropdown.setAttribute('aria-hidden', 'true'); dropdown.inert = true; }
    }
  });

  function updateLang(lang) {
    if (currentCode) currentCode.textContent = (lang || 'pt').toUpperCase();
    checks.forEach(function(c) {
      c.style.display = c.getAttribute('data-check') === lang ? 'inline' : 'none';
    });
    document.documentElement.setAttribute('data-lang', lang);
  }
</script>

<style>
  .lang-switcher {
    position: relative;
  }

  .lang-toggle {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-full);
    color: var(--text-secondary);
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    cursor: pointer;
    flex-shrink: 0;
    transition: all var(--transition-fast);
  }

  .lang-toggle:hover {
    color: var(--text-primary);
    border-color: var(--brand-cyan);
    transform: scale(1.06);
  }

  .lang-toggle[aria-expanded="true"] {
    border-color: var(--brand-cyan);
    color: var(--text-primary);
  }

  .lang-current-code {
    font-size: 10.5px;
    font-weight: 800;
    letter-spacing: 0.04em;
  }

  @media (max-width: 767px) {
    .lang-toggle { width: 31px; height: 31px; }
    .lang-current-code { font-size: 9.5px; }
  }

  .lang-dropdown {
    position: absolute;
    right: 0;
    top: calc(100% + 8px);
    min-width: 148px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    opacity: 0;
    transform: translateY(6px) scale(0.95);
    pointer-events: none;
    transition: all 0.15s ease;
    z-index: var(--z-dropdown);
  }

  .lang-dropdown[aria-hidden="false"] {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .lang-option {
    width: 100%;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-sm);
    color: var(--text-primary);
    transition: background var(--transition-fast);
    text-align: left;
  }

  .lang-option:hover {
    background: var(--bg-tertiary);
  }

  .lang-flag {
    font-size: 16px;
  }

  .lang-label {
    flex: 1;
  }

  .lang-check {
    font-size: 12px;
    color: var(--brand-cyan);
    display: none;
  }
</style>
