---
import CotacaoBar from './CotacaoBar.astro';
import Navigation from './Navigation.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import ThemeToggle from './ThemeToggle.astro';
import SearchOverlay from './SearchOverlay.astro';
import { config } from '../../../site.config';

const { brand } = config;
const blogTitle = `${brand.name} ${brand.blogSuffix}`;
---

<div class="header-wrapper">
  <CotacaoBar />

  <header class="header">
    <div class="container header-inner">
      <a href="/" class="logo" aria-label={`${blogTitle} - Home`}>
        <div class="logo-icon">
          <svg width="20" height="20" viewBox="0 0 64 64" fill="none">
            <path d={brand.logo.svgPath} stroke="url(#logoGrad)" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round"/>
            <defs>
              <linearGradient id="logoGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color={brand.logo.gradientStart}/>
                <stop offset="100%" stop-color={brand.logo.gradientEnd}/>
              </linearGradient>
            </defs>
          </svg>
        </div>
        <span class="logo-text">{brand.name}<span class="logo-blog">{brand.blogSuffix}</span></span>
      </a>

      <Navigation />

      <div class="header-right">
        <button class="icon-btn" id="search-toggle" aria-label="Buscar no blog">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m20.3 20.3-4.2-4.2"/></svg>
        </button>
        <ThemeToggle />
        <LanguageSwitcher />
        <a href={config.app.url} target="_blank" rel="noopener noreferrer" class="header-cta" data-i18n="nav.baixarApp">Baixar App</a>
      </div>
    </div>
  </header>

  <SearchOverlay />
</div>

<style>
  .header-wrapper {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
  }

  .header {
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border-bottom: 1px solid var(--glass-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    min-height: 64px;
    flex-wrap: wrap;
    padding-top: var(--space-2);
    padding-bottom: var(--space-2);
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-left: auto;
  }

  .icon-btn {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-full);
    border: 1px solid var(--border-default);
    background: var(--bg-secondary);
    color: var(--text-secondary);
    cursor: pointer;
    display: grid;
    place-items: center;
    flex-shrink: 0;
    transition: all var(--transition-fast);
  }

  .icon-btn:hover {
    color: var(--text-primary);
    border-color: var(--brand-cyan);
    transform: scale(1.06);
  }

  .header-cta {
    padding: var(--space-2) var(--space-4);
    background: var(--gradient-cta);
    color: #fff;
    font-size: var(--text-sm);
    font-weight: 600;
    border-radius: var(--radius-full);
    white-space: nowrap;
    transition: all var(--transition-fast);
  }

  .header-cta:hover {
    opacity: 0.9;
    transform: translateY(-1px);
    box-shadow: var(--shadow-glow);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: #0d1117;
    border: 1px solid rgba(var(--brand-cyan-rgb), 0.2);
    border-radius: var(--radius-md);
  }

  .logo-text {
    font-weight: 700;
    font-size: var(--text-lg);
    color: var(--text-primary);
    font-family: 'Plus Jakarta Sans', 'Inter', sans-serif;
  }

  .logo-blog {
    background: linear-gradient(135deg, var(--brand-cyan), var(--brand-gradient-end));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-left: 2px;
  }

  /* Mobile: linha 1 = logo + ações alinhadas; linha 2 = pills (Navigation) */
  @media (max-width: 767px) {
    .header-inner {
      gap: var(--space-2);
      justify-content: space-between;
    }

    .logo { gap: var(--space-2); }
    .logo-icon { width: 30px; height: 30px; }
    .logo-icon svg { width: 16px; height: 16px; }
    .logo-text { font-size: var(--text-base); }

    .header-right { gap: 6px; margin-left: 0; }
    .icon-btn { width: 32px; height: 32px; }
    .header-cta { font-size: 12.5px; padding: 8px 13px; }
  }
</style>
