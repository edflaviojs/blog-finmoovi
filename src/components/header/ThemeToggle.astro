---
// Toggle de tema no estilo do mockup portal: bolinha com emoji 🌙/☀️
---

<button class="theme-toggle" id="theme-toggle" aria-label="Alternar tema" data-i18n-aria="theme.toggle">
  <span class="icon-sun" aria-hidden="true">☀️</span>
  <span class="icon-moon" aria-hidden="true">🌙</span>
</button>

<style>
  .theme-toggle {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--border-default);
    border-radius: var(--radius-full);
    background: var(--bg-secondary);
    font-size: 15px;
    line-height: 1;
    cursor: pointer;
    flex-shrink: 0;
    transition: all var(--transition-fast);
  }

  .theme-toggle:hover {
    border-color: var(--brand-cyan);
    transform: scale(1.06);
  }

  :root[data-theme="dark"] .icon-sun { display: block; }
  :root[data-theme="dark"] .icon-moon { display: none; }
  :root[data-theme="light"] .icon-sun { display: none; }
  :root[data-theme="light"] .icon-moon { display: block; }

  /* Default (no data-theme yet) = dark */
  .icon-sun { display: block; }
  .icon-moon { display: none; }

  @media (max-width: 767px) {
    .theme-toggle { width: 31px; height: 31px; font-size: 13px; }
  }
</style>

<script>
  document.getElementById('theme-toggle')?.addEventListener('click', function() {
    var current = document.documentElement.getAttribute('data-theme') || 'dark';
    var next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    try { localStorage.setItem('fm-theme', next); } catch(e) {}
  });
</script>
