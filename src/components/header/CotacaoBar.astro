---
// CotacaoBar — Ticker animado de cotações com dados reais
---

<div class="cotacao-bar">
  <div class="cotacao-ticker">
    <div class="cotacao-track" aria-label="Cotações em tempo real">
      <span class="cotacao-item">
        <span class="cotacao-label">USD/BRL</span>
        <span class="cotacao-value" id="cot-usdbrl">--</span>
        <span class="cotacao-change" id="cot-usdbrl-change"></span>
      </span>
      <span class="cotacao-item">
        <span class="cotacao-label">EUR/BRL</span>
        <span class="cotacao-value" id="cot-eurbrl">--</span>
        <span class="cotacao-change" id="cot-eurbrl-change"></span>
      </span>
      <span class="cotacao-item">
        <span class="cotacao-label">BTC/USD</span>
        <span class="cotacao-value" id="cot-btcusd">--</span>
        <span class="cotacao-change" id="cot-btcusd-change"></span>
      </span>
      <span class="cotacao-item">
        <span class="cotacao-label">IBOV</span>
        <span class="cotacao-value" id="cot-ibov">--</span>
        <span class="cotacao-change" id="cot-ibov-change"></span>
      </span>
      <span class="cotacao-item">
        <span class="cotacao-label">SELIC</span>
        <span class="cotacao-value" id="cot-selic">14.75%</span>
      </span>
      <!-- Duplicado para loop infinito -->
      <span class="cotacao-item">
        <span class="cotacao-label">USD/BRL</span>
        <span class="cotacao-value" id="cot-usdbrl2">--</span>
        <span class="cotacao-change" id="cot-usdbrl-change2"></span>
      </span>
      <span class="cotacao-item">
        <span class="cotacao-label">EUR/BRL</span>
        <span class="cotacao-value" id="cot-eurbrl2">--</span>
        <span class="cotacao-change" id="cot-eurbrl-change2"></span>
      </span>
      <span class="cotacao-item">
        <span class="cotacao-label">BTC/USD</span>
        <span class="cotacao-value" id="cot-btcusd2">--</span>
        <span class="cotacao-change" id="cot-btcusd-change2"></span>
      </span>
      <span class="cotacao-item">
        <span class="cotacao-label">IBOV</span>
        <span class="cotacao-value" id="cot-ibov2">--</span>
        <span class="cotacao-change" id="cot-ibov-change2"></span>
      </span>
      <span class="cotacao-item">
        <span class="cotacao-label">SELIC</span>
        <span class="cotacao-value" id="cot-selic2">14.75%</span>
      </span>
    </div>
  </div>
</div>

<script>
  async function fetchCotacoes() {
    // AwesomeAPI - USD, EUR, BTC (gratuita, sem chave)
    try {
      const res = await fetch('https://economia.awesomeapi.com.br/last/USD-BRL,EUR-BRL,BTC-USD');
      if (res.ok) {
        const data = await res.json();
        const usd = data.USDBRL;
        updateCotacao('usdbrl', parseFloat(usd.bid).toFixed(2), parseFloat(usd.pctChange));
        const eur = data.EURBRL;
        updateCotacao('eurbrl', parseFloat(eur.bid).toFixed(2), parseFloat(eur.pctChange));
        const btc = data.BTCUSD;
        const btcVal = parseFloat(btc.bid);
        updateCotacao('btcusd', btcVal > 1000 ? Math.round(btcVal).toLocaleString('en-US') : btcVal.toFixed(2), parseFloat(btc.pctChange));
      }
    } catch (e) {
      updateCotacao('usdbrl', '5.67', 0);
      updateCotacao('eurbrl', '6.18', 0);
      updateCotacao('btcusd', '104,250', 0);
    }

    // Brapi.dev - IBOV (gratuita, sem chave, 15min delay)
    try {
      const res = await fetch('https://brapi.dev/api/quote/%5EBVSP');
      if (res.ok) {
        const data = await res.json();
        const ibov = data.results[0];
        const val = Math.round(ibov.regularMarketPrice).toLocaleString('pt-BR');
        updateCotacao('ibov', val, ibov.regularMarketChangePercent);
      }
    } catch (e) {
      updateCotacao('ibov', '138.420', 0);
    }

    // Banco Central do Brasil - SELIC (API oficial, gratuita)
    try {
      const res = await fetch('https://api.bcb.gov.br/dados/serie/bcdata.sgs.432/dados/ultimos/1?formato=json');
      if (res.ok) {
        const data = await res.json();
        const selic = parseFloat(data[0].valor).toFixed(2);
        const el1 = document.getElementById('cot-selic');
        const el2 = document.getElementById('cot-selic2');
        if (el1) el1.textContent = selic + '%';
        if (el2) el2.textContent = selic + '%';
      }
    } catch (e) { /* mantém valor estático */ }
  }

  function updateCotacao(pair, value, pctChange) {
    const el1 = document.getElementById('cot-' + pair);
    const el2 = document.getElementById('cot-' + pair + '2');
    const ch1 = document.getElementById('cot-' + pair + '-change');
    const ch2 = document.getElementById('cot-' + pair + '-change2');

    if (el1) el1.textContent = value;
    if (el2) el2.textContent = value;

    if (pctChange !== undefined && pctChange !== null) {
      var sign = pctChange >= 0 ? '+' : '';
      var cls = pctChange >= 0 ? 'positive' : 'negative';
      var text = sign + pctChange.toFixed(2) + '%';
      if (ch1) { ch1.textContent = text; ch1.className = 'cotacao-change ' + cls; }
      if (ch2) { ch2.textContent = text; ch2.className = 'cotacao-change ' + cls; }
    }
  }

  fetchCotacoes();
  setInterval(fetchCotacoes, 5 * 60 * 1000);
</script>

<style>
  .cotacao-bar {
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border-muted);
    overflow: hidden;
    height: 32px;
    display: flex;
    align-items: center;
  }

  .cotacao-ticker {
    width: 100%;
    overflow: hidden;
  }

  .cotacao-track {
    display: flex;
    gap: var(--space-8);
    animation: ticker 30s linear infinite;
    white-space: nowrap;
  }

  .cotacao-item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
  }

  .cotacao-label {
    color: var(--text-tertiary);
    font-weight: 500;
  }

  .cotacao-value {
    color: var(--text-primary);
    font-weight: 600;
    font-family: var(--font-mono);
  }

  .cotacao-change {
    font-size: 10px;
    font-weight: 600;
    font-family: var(--font-mono);
  }

  .cotacao-change.positive {
    color: var(--accent-green);
  }

  .cotacao-change.negative {
    color: var(--accent-red);
  }

  @keyframes ticker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .cotacao-bar:hover .cotacao-track {
    animation-play-state: paused;
  }
</style>
