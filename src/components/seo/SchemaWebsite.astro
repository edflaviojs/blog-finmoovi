---
import { config } from '../../../site.config';

const site = config.siteUrl;
const blogTitle = `${config.brand.name} ${config.brand.blogSuffix}`;

// sameAs dinâmico: app + quaisquer perfis sociais já preenchidos (URLs http).
// Ao preencher config.social com LinkedIn/YouTube/etc., o schema se atualiza só.
const socialProfiles = Object.values(config.social || {})
  .filter((v): v is string => typeof v === 'string' && /^https?:\/\//.test(v));
const orgSameAs = [config.app.url, ...socialProfiles];

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": blogTitle,
  "url": site,
  "description": config.siteDescription.pt,
  "publisher": {
    "@type": "Organization",
    "name": config.brand.name,
    "url": config.app.url,
    "logo": {
      "@type": "ImageObject",
      "url": `${site}/images/logo.png`
    },
    "sameAs": orgSameAs
  },
  "potentialAction": {
    "@type": "SearchAction",
    "target": `${site}/?q={search_term_string}`,
    "query-input": "required name=search_term_string"
  },
  "inLanguage": ["pt-BR", "en-US", "es-ES"]
};

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": config.app.name,
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "Android, iOS, Web",
  "url": config.app.url,
  "description": config.app.features.pt.join('. ') + '.',
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "BRL"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.8",
    "ratingCount": "150"
  }
};
---

<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />
