---
import { config } from '../../../site.config';
import { getNavCategories } from '@/utils/nav-categories';

const currentYear = new Date().getFullYear();
const { brand } = config;

// Categorias dinâmicas (mesma fonte do menu) + seções fixas do blog.
const navCategories = await getNavCategories();

const footerLinks = {
  blog: [
    ...navCategories.map(c => ({ label: c.label, href: c.href, i18n: undefined as string | undefined })),
    { label: 'Glossário', href: '/glossario', i18n: 'footer.link.glossario' },
    { label: 'Ferramentas', href: '/ferramentas', i18n: 'footer.link.ferramentas' },
    { label: 'Estudos', href: '/estudos', i18n: 'footer.link.estudos' },
  ],
  app: [
    { label: `Baixar ${config.app.name}`, href: '/app', i18n: 'footer.link.baixar' },
    { label: 'Funcionalidades', href: '/app#funcionalidades', i18n: 'footer.link.funcionalidades' },
    { label: 'Preços', href: '/app#precos', i18n: 'footer.link.precos' },
    { label: 'Suporte', href: '/app#suporte', i18n: 'footer.link.suporte' },
  ],
  legal: [
    { label: 'Privacidade', href: '/privacidade', i18n: 'footer.link.privacidade' },
    { label: 'Termos de Uso', href: '/termos', i18n: 'footer.link.termos' },
    { label: 'Cookies', href: '/cookies', i18n: 'footer.link.cookies' },
  ]
};

const socials = [
  { label: 'Instagram', href: config.social.instagram },
  { label: 'X', href: config.social.twitter },
  { label: 'YouTube', href: config.social.youtube },
  { label: 'Facebook', href: config.social.facebook },
  { label: 'LinkedIn', href: config.social.linkedin },
  { label: 'Pinterest', href: config.social.pinterest },
  { label: 'Bluesky', href: config.social.bluesky },
  { label: 'Substack', href: config.social.substack },
].filter(s => s.href);
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <span class="logo-icon">
            <svg width="16" height="16" viewBox="0 0 64 64" fill="none">
              <path d={brand.logo.svgPath} stroke="url(#fLogoGrad)" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/>
              <defs><linearGradient id="fLogoGrad" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color={brand.logo.gradientStart}/><stop offset="100%" stop-color={brand.logo.gradientEnd}/></linearGradient></defs>
            </svg>
          </span>
          <span class="logo-text">{brand.name}<span class="logo-blog">{brand.blogSuffix}</span></span>
        </a>
        <p class="footer-description" data-i18n="footer.desc">
          {config.siteDescription.pt}
        </p>
        <div class="footer-social">
          {socials.map(s => (
            <a href={s.href} target="_blank" rel="noopener" aria-label={s.label}>{s.label}</a>
          ))}
        </div>
      </div>

      <div class="footer-section">
        <h4 class="footer-title" data-i18n="footer.blog">Blog</h4>
        <ul class="footer-list">
          {footerLinks.blog.map(link => (
            <li><a href={link.href} data-i18n={link.i18n}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-section">
        <h4 class="footer-title" data-i18n="footer.app">App</h4>
        <ul class="footer-list">
          {footerLinks.app.map(link => (
            <li><a href={link.href} data-i18n={link.i18n}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-section">
        <h4 class="footer-title" data-i18n="footer.legal">Legal</h4>
        <ul class="footer-list">
          {footerLinks.legal.map(link => (
            <li><a href={link.href} data-i18n={link.i18n}>{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p data-i18n="footer.copyright">&copy; {currentYear} {brand.name}. Todos os direitos reservados.</p>
      <p class="footer-disclaimer" data-i18n="footer.disclaimer">
        Este blog tem caráter educativo. Não constitui recomendação de investimento.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-default);
    padding: var(--space-16) 0 var(--space-8);
    margin-top: var(--space-20);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr 1fr;
    }
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    margin-bottom: var(--space-4);
  }

  .footer-logo .logo-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: var(--bg-primary);
    border: 1px solid rgba(0, 240, 255, 0.2);
    border-radius: var(--radius-md);
  }

  .footer-logo .logo-text {
    font-weight: 700;
    color: var(--text-primary);
  }

  .footer-logo .logo-blog {
    background: linear-gradient(135deg, var(--brand-cyan), #A91079);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-left: 2px;
  }

  .footer-description {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    max-width: 300px;
  }

  .footer-social {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
    margin-top: var(--space-4);
  }

  .footer-social a {
    color: var(--text-secondary);
    font-size: var(--text-xs);
    transition: color var(--transition-fast);
  }

  .footer-social a:hover {
    color: var(--accent-primary);
  }

  .footer-title {
    color: var(--text-primary);
    font-size: var(--text-sm);
    font-weight: 600;
    margin-bottom: var(--space-4);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .footer-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-list a {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    transition: color var(--transition-fast);
  }

  .footer-list a:hover {
    color: var(--accent-primary);
  }

  .footer-bottom {
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-muted);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    align-items: center;
    text-align: center;
  }

  .footer-bottom p {
    color: var(--text-tertiary);
    font-size: var(--text-xs);
    margin-bottom: 0;
  }

  .footer-disclaimer {
    font-style: italic;
  }
</style>
