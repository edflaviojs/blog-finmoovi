---
import { config } from '../../../site.config';
import { getNavCategories } from '@/utils/nav-categories';
import CookieNotice from '../shared/CookieNotice.astro';
import BackToTop from '../shared/BackToTop.astro';

const currentYear = new Date().getFullYear();
const { brand } = config;

// Categorias dinâmicas (mesma fonte do menu) + seções fixas do blog.
const navCategories = await getNavCategories();

const footerLinks = {
  blog: [
    ...navCategories.map(c => ({ label: c.label, href: c.href, i18n: undefined as string | undefined })),
    { label: 'Glossário', href: '/glossario', i18n: 'footer.link.glossario' },
    { label: 'Ferramentas', href: '/ferramentas', i18n: 'footer.link.ferramentas' },
    { label: 'Estudos', href: '/estudos', i18n: 'footer.link.estudos' },
    { label: 'Sobre', href: '/sobre', i18n: 'nav.sobre' },
  ],
  app: [
    { label: `Baixar ${config.app.name}`, href: '/app', i18n: 'footer.link.baixar' },
    { label: 'Funcionalidades', href: '/app#funcionalidades', i18n: 'footer.link.funcionalidades' },
    { label: 'Preços', href: '/app#precos', i18n: 'footer.link.precos' },
    { label: 'Suporte', href: '/app#suporte', i18n: 'footer.link.suporte' },
  ],
  legal: [
    { label: 'Privacidade', href: '/privacidade', i18n: 'footer.link.privacidade' },
    { label: 'Termos de Uso', href: '/termos', i18n: 'footer.link.termos' },
    { label: 'Cookies', href: '/cookies', i18n: 'footer.link.cookies' },
  ]
};

// Iniciais para as bolinhas de redes sociais
const socialInitials: Record<string, string> = {
  Instagram: 'IG', X: 'X', YouTube: 'YT', Facebook: 'FB',
  LinkedIn: 'IN', Pinterest: 'Pin', Bluesky: 'BS', Substack: 'SS',
};

const socials = [
  { label: 'Instagram', href: config.social.instagram },
  { label: 'X', href: config.social.twitter },
  { label: 'YouTube', href: config.social.youtube },
  { label: 'Facebook', href: config.social.facebook },
  { label: 'LinkedIn', href: config.social.linkedin },
  { label: 'Pinterest', href: config.social.pinterest },
  { label: 'Bluesky', href: config.social.bluesky },
  { label: 'Substack', href: config.social.substack },
].filter(s => s.href);
---

<footer class="footer">
  <div class="footer-hairline" aria-hidden="true"></div>
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <span class="logo-icon">
            <svg width="16" height="16" viewBox="0 0 64 64" fill="none">
              <path d={brand.logo.svgPath} stroke="url(#fLogoGrad)" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/>
              <defs><linearGradient id="fLogoGrad" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color={brand.logo.gradientStart}/><stop offset="100%" stop-color={brand.logo.gradientEnd}/></linearGradient></defs>
            </svg>
          </span>
          <span class="logo-text">{brand.name}<span class="logo-blog">{brand.blogSuffix}</span></span>
        </a>
        <p class="footer-description" data-i18n="footer.desc">
          {config.siteDescription.pt}
        </p>
      </div>

      <div class="footer-section">
        <!-- p, não heading: títulos decorativos do rodapé quebravam a ordem
             h2→h4 apontada pelo Lighthouse (heading-order) -->
        <p class="footer-title" data-i18n="footer.blog">Blog</p>
        <ul class="footer-list">
          {footerLinks.blog.map(link => (
            <li><a href={link.href} data-i18n={link.i18n}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-section">
        <p class="footer-title" data-i18n="footer.app">App</p>
        <ul class="footer-list">
          {footerLinks.app.map(link => (
            <li><a href={link.href} data-i18n={link.i18n}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-section">
        <p class="footer-title" data-i18n="footer.legal">Legal</p>
        <ul class="footer-list">
          {footerLinks.legal.map(link => (
            <li><a href={link.href} data-i18n={link.i18n}>{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer-socials">
      {socials.map(s => (
        <a href={s.href} target="_blank" rel="noopener" aria-label={`${socialInitials[s.label] || s.label.slice(0, 2).toUpperCase()} · ${s.label}`}>
          <!-- o aria-label começa pela inicial visível ("IG · Instagram"):
               o axe exige o texto visível contido no nome acessível -->
          {socialInitials[s.label] || s.label.slice(0, 2).toUpperCase()}
        </a>
      ))}
    </div>

    <div class="footer-bottom">
      <p data-i18n="footer.copyright">&copy; {currentYear} {brand.name}. Todos os direitos reservados.</p>
      <p class="footer-disclaimer" data-i18n="footer.disclaimer">
        O conteúdo deste blog é educativo e não constitui recomendação de investimento.
      </p>
    </div>
  </div>
</footer>

<CookieNotice />
<BackToTop />

<style>
  /* Footer luxe: sempre escuro (nos dois temas), fio gradiente no topo */
  .footer {
    background: #0a0e14;
    color: #b9c6d4;
    padding: 0 0 var(--space-8);
    margin-top: var(--space-20);
  }

  .footer-hairline {
    height: 2px;
    background: var(--gradient-cta);
    opacity: 0.85;
    margin-bottom: var(--space-12);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
      gap: var(--space-8);
    }
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .logo-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    background: #0d1117;
    border: 1px solid rgba(var(--brand-cyan-rgb), 0.25);
    border-radius: var(--radius-md);
  }

  .logo-text {
    font-weight: 700;
    font-size: var(--text-base);
    color: #ffffff;
  }

  .logo-blog {
    background: linear-gradient(135deg, var(--brand-cyan), var(--brand-gradient-end));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-left: 2px;
  }

  .footer-description {
    font-size: 13.5px;
    color: #7e8c9c;
    margin: var(--space-3) 0 0;
    max-width: 32ch;
    line-height: 1.65;
  }

  /* Tons do rodapé calibrados p/ contraste >=4.5:1 sobre #0a0e14 (WCAG AA) */
  .footer-title {
    margin: 0 0 var(--space-4);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #8b9aab;
    font-weight: 700;
  }

  .footer-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-size: var(--text-sm);
  }

  .footer-list a {
    color: #aab8c6;
    transition: color var(--transition-fast);
  }

  .footer-list a:hover { color: #ffffff; }

  .footer-socials {
    display: flex;
    justify-content: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-top: var(--space-10);
    padding-top: var(--space-6);
    border-top: 1px solid #151d28;
  }

  .footer-socials a {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid #232d3a;
    display: grid;
    place-items: center;
    font-size: 11px;
    font-weight: 800;
    color: #94a3b3;
    transition: all var(--transition-base);
  }

  .footer-socials a:hover {
    border-color: var(--brand-cyan);
    color: var(--brand-cyan);
    transform: translateY(-3px);
    box-shadow: 0 8px 18px rgba(var(--brand-cyan-rgb), 0.18);
  }

  .footer-bottom {
    margin-top: var(--space-6);
    padding-top: var(--space-5);
    border-top: 1px solid #1a2330;
    text-align: center;
    font-size: var(--text-xs);
    color: #8b9aab;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .footer-disclaimer {
    color: #7e8c9c;
    font-size: 11.5px;
    max-width: 60ch;
    margin: 0 auto;
    line-height: 1.6;
  }

  .footer-bottom p { margin: 0; }

  /* Mobile luxe: leve e discreto — tipografia menor, chips finos e fantasma,
     ritmo apertado, separadores quase invisíveis */
  @media (max-width: 767px) {
    .footer-hairline { margin-bottom: var(--space-8); }
    .footer { padding-bottom: var(--space-5); }

    .footer-grid { text-align: center; }

    .footer-grid > div {
      padding: var(--space-5) 0;
      border-top: 1px solid rgba(255, 255, 255, 0.045);
    }

    .footer-grid > div:first-child {
      border-top: 0;
      padding-top: 0;
    }

    .footer-brand {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .footer-description {
      margin: var(--space-2) auto 0;
      font-size: 12px;
      max-width: 30ch;
      line-height: 1.6;
      color: #8494a5;
    }

    .footer-title {
      margin-bottom: var(--space-3);
      font-size: 9.5px;
      letter-spacing: 0.28em;
      color: #8b9aab;
    }

    .footer-title::after {
      content: "";
      display: block;
      width: 20px;
      height: 1.5px;
      border-radius: 1px;
      background: linear-gradient(90deg, #00c8d7, #A91079);
      opacity: 0.7;
      margin: 7px auto 0;
    }

    .footer-list {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      gap: 6px;
    }

    .footer-list a {
      display: inline-block;
      border: 1px solid rgba(255, 255, 255, 0.07);
      background: transparent;
      padding: 5px 12px;
      border-radius: var(--radius-full);
      font-size: 11.5px;
      font-weight: 500;
      letter-spacing: 0.01em;
      color: #8494a5;
    }

    .footer-list a:hover { border-color: var(--brand-cyan); color: #cfe3ee; }

    .footer-socials {
      margin-top: 0;
      padding-top: var(--space-5);
      gap: var(--space-2);
    }

    .footer-socials a {
      width: 29px;
      height: 29px;
      font-size: 9px;
      color: #8494a5;
      border-color: rgba(255, 255, 255, 0.08);
    }

    .footer-bottom {
      margin-top: var(--space-4);
      padding-top: var(--space-4);
      font-size: 10.5px;
      color: #8494a5;
    }

    .footer-disclaimer { font-size: 10px; color: #7e8c9c; }
  }
</style>
