<div class="banner-loovi">
  <div class="banner-content">
    <span class="banner-tag">Parceiro</span>
    <h4 class="banner-title">Loovi Seguros</h4>
    <p class="banner-description">
      Proteja seu carro com o seguro mais inteligente do Brasil. Sem franquia, sem burocracia.
    </p>
    <a href="https://loovi.com.br?ref=finmoovi" target="_blank" rel="noopener sponsored" class="banner-link">
      Conhecer →
    </a>
  </div>
</div>

<style>
  .banner-loovi {
    margin: var(--space-6) 0;
    padding: var(--space-5);
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    border-left: 3px solid var(--accent-purple);
  }

  .banner-tag {
    display: inline-block;
    padding: 1px var(--space-2);
    background: rgba(188, 140, 255, 0.1);
    color: var(--accent-purple);
    border-radius: var(--radius-sm);
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-3);
  }

  .banner-title {
    font-size: var(--text-base);
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .banner-description {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-bottom: var(--space-3);
  }

  .banner-link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--accent-purple);
    transition: opacity var(--transition-fast);
  }

  .banner-link:hover {
    opacity: 0.8;
  }
</style>
