---
const urlPath = Astro.url?.pathname || '';
let locale = 'pt';
if (urlPath.startsWith('/en/')) locale = 'en';
else if (urlPath.startsWith('/es/')) locale = 'es';

const texts = {
  pt: {
    tag: 'Parceiro',
    title: 'Loovi Seguros',
    desc: 'Proteja seu carro com o seguro mais inteligente do Brasil. Sem franquia, sem burocracia.',
    cta: 'Conhecer →'
  },
  en: {
    tag: 'Partner',
    title: 'Loovi Insurance',
    desc: 'Protect your car with Brazil\'s smartest auto insurance. No deductible, no bureaucracy.',
    cta: 'Learn more →'
  },
  es: {
    tag: 'Socio',
    title: 'Loovi Seguros',
    desc: 'Protege tu auto con el seguro más inteligente de Brasil. Sin franquicia, sin burocracia.',
    cta: 'Conocer →'
  }
};
const t = texts[locale] || texts.pt;
---

<div class="banner-loovi">
  <div class="banner-content">
    <span class="banner-tag">{t.tag}</span>
    <h4 class="banner-title">{t.title}</h4>
    <p class="banner-description">{t.desc}</p>
    <a href="https://loovi.com.br?ref=finmoovi" target="_blank" rel="noopener sponsored" class="banner-link">
      {t.cta}
    </a>
  </div>
</div>

<style>
  .banner-loovi {
    margin: var(--space-6) 0;
    padding: var(--space-5);
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    border-left: 3px solid var(--accent-purple);
  }

  .banner-tag {
    display: inline-block;
    padding: 1px var(--space-2);
    background: rgba(188, 140, 255, 0.1);
    color: var(--accent-purple);
    border-radius: var(--radius-sm);
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-3);
  }

  .banner-title {
    font-size: var(--text-base);
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .banner-description {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-bottom: var(--space-3);
  }

  .banner-link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--accent-purple);
    transition: opacity var(--transition-fast);
  }

  .banner-link:hover {
    opacity: 0.8;
  }
</style>
