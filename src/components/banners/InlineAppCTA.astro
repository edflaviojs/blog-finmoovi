---
interface Props {
  variant?: 'full' | 'compact';
  locale?: string;
}

const { variant = 'full', locale = 'pt' } = Astro.props;

const texts = {
  pt: {
    badge: 'App Gratuito',
    title: 'Organize suas finanças com o FinMoovi',
    description: 'Controle multi-moeda, offline, com inteligência artificial. Teste grátis por 7 dias.',
    cta: 'Começar Grátis',
    note: 'Sem cartão. Cancele quando quiser.'
  },
  en: {
    badge: 'Free App',
    title: 'Organize your finances with FinMoovi',
    description: 'Multi-currency control, offline, with AI. Try free for 7 days.',
    cta: 'Start Free',
    note: 'No credit card. Cancel anytime.'
  },
  es: {
    badge: 'App Gratuita',
    title: 'Organiza tus finanzas con FinMoovi',
    description: 'Control multi-moneda, offline, con inteligencia artificial. Prueba gratis 7 días.',
    cta: 'Comenzar Gratis',
    note: 'Sin tarjeta. Cancela cuando quieras.'
  }
};

const t = texts[locale] || texts.pt;
---

<aside class={`inline-cta inline-cta--${variant}`}>
  <div class="inline-cta__content">
    <span class="inline-cta__badge">{t.badge}</span>
    <h3 class="inline-cta__title">{t.title}</h3>
    {variant === 'full' && <p class="inline-cta__desc">{t.description}</p>}
    <a href="https://finmoovi.com" class="inline-cta__button" target="_blank" rel="noopener">
      {t.cta} →
    </a>
    {variant === 'full' && <span class="inline-cta__note">{t.note}</span>}
  </div>
</aside>

<style>
  .inline-cta {
    margin: 2rem 0;
    padding: 1.5rem;
    border-radius: 12px;
    background: linear-gradient(145deg, #161b22, #21262d);
    border: 1px solid #30363d;
    border-top: 3px solid #3fb950;
    text-align: center;
  }
  .inline-cta__badge {
    display: inline-block;
    padding: 2px 10px;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 9999px;
    background: rgba(63, 185, 80, 0.15);
    color: #3fb950;
    margin-bottom: 0.75rem;
  }
  .inline-cta__title {
    color: #f0f6fc;
    font-size: 1.2rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
  }
  .inline-cta__desc {
    color: #8b949e;
    font-size: 0.9rem;
    margin: 0 0 1rem;
    line-height: 1.5;
  }
  .inline-cta__button {
    display: inline-block;
    padding: 10px 28px;
    background: linear-gradient(135deg, #3fb950, #58a6ff);
    color: #fff;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    border-radius: 8px;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .inline-cta__button:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(63, 185, 80, 0.3);
  }
  .inline-cta__note {
    display: block;
    margin-top: 0.5rem;
    font-size: 0.75rem;
    color: #6e7681;
  }
  .inline-cta--compact {
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    text-align: left;
    gap: 1rem;
  }
  .inline-cta--compact .inline-cta__content {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .inline-cta--compact .inline-cta__title {
    font-size: 1rem;
    margin: 0;
  }
  .inline-cta--compact .inline-cta__badge {
    margin-bottom: 0;
  }
</style>
