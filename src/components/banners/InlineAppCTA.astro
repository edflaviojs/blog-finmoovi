---
import { config } from '../../../site.config';

interface Props {
  variant?: 'full' | 'compact';
  locale?: string;
  seed?: number;
}

const { variant = 'full', locale = 'pt', seed } = Astro.props;
const appName = config.app.name;
const appUrl = config.app.url;
const features = config.app.features;

// Generate CTA variations dynamically from config features
function buildCTAs(lang) {
  const f = features[lang] || features.pt;
  const ctaTitle = config.app.ctaTitle[lang] || config.app.ctaTitle.pt;
  const ctaNote = config.app.ctaNote[lang] || config.app.ctaNote.pt;

  const genericTitles = {
    pt: [
      ctaTitle,
      `${f[0]} com o ${appName}`,
      `${f[1]}`,
      `${f[2]}`,
      'Comece grátis — sem cartão de crédito',
      'Sua privacidade importa',
      `${f[3]}`,
      'Relatórios que fazem sentido',
      'Simples, rápido e inteligente',
      'Alcance seus objetivos',
      `O app que funciona offline`,
      `${appName} — o app mais completo`,
    ],
    en: [
      ctaTitle,
      `${f[0]} with ${appName}`,
      `${f[1]}`,
      `${f[2]}`,
      'Start free — no credit card needed',
      'Your privacy matters',
      `${f[3]}`,
      'Reports that make sense',
      'Simple, fast, and smart',
      'Reach your goals',
      `The app that works offline`,
      `${appName} — the most complete app`,
    ],
    es: [
      ctaTitle,
      `${f[0]} con ${appName}`,
      `${f[1]}`,
      `${f[2]}`,
      'Comienza gratis — sin tarjeta de crédito',
      'Tu privacidad importa',
      `${f[3]}`,
      'Reportes que tienen sentido',
      'Simple, rápido e inteligente',
      'Alcanza tus objetivos',
      `La app que funciona offline`,
      `${appName} — la app más completa`,
    ],
  };

  const genericDescs = {
    pt: [
      f.slice(0, 3).join('. ') + '.',
      `O ${appName} faz isso automaticamente. Menos trabalho, mais resultados.`,
      `Dashboards com insights automáticos. Saiba exatamente o que está acontecendo com o ${appName}.`,
      f.slice(1, 4).join('. ') + '.',
      ctaNote,
      `Criptografia de ponta a ponta. Seus dados ficam no seu dispositivo. Controle total com o ${appName}.`,
      `Inteligência artificial que entende você. O ${appName} faz o trabalho pesado.`,
      `Gráficos claros com insights automáticos. Identifique padrões com o ${appName}.`,
      `O ${appName} substitui planilhas e ferramentas complicadas. Tudo automático, tudo no celular.`,
      `Defina metas, acompanhe o progresso e receba alertas inteligentes. O ${appName} te mantém no caminho.`,
      `Use em qualquer lugar, mesmo sem internet. Sincroniza automaticamente quando conectar.`,
      `Usado por milhares de pessoas. O ${appName} é completo para quem quer os melhores resultados.`,
    ],
    en: [
      f.slice(0, 3).join('. ') + '.',
      `${appName} does it automatically. Less work, more results.`,
      `Dashboards with automatic insights. Know exactly what's happening with ${appName}.`,
      f.slice(1, 4).join('. ') + '.',
      ctaNote,
      `End-to-end encryption. Your data stays on your device. Full control with ${appName}.`,
      `AI that understands you. ${appName} does the heavy lifting.`,
      `Clear charts with automatic insights. Identify patterns with ${appName}.`,
      `${appName} replaces spreadsheets and complicated tools. All automatic, all on your phone.`,
      `Set goals, track progress, and get smart alerts. ${appName} keeps you on track.`,
      `Use anywhere, even without internet. Syncs automatically when you reconnect.`,
      `Used by thousands. ${appName} is the most complete app for those who want the best results.`,
    ],
    es: [
      f.slice(0, 3).join('. ') + '.',
      `${appName} lo hace automáticamente. Menos trabajo, más resultados.`,
      `Dashboards con insights automáticos. Sabe exactamente qué está pasando con ${appName}.`,
      f.slice(1, 4).join('. ') + '.',
      ctaNote,
      `Cifrado de punta a punta. Tus datos quedan en tu dispositivo. Control total con ${appName}.`,
      `IA que te entiende. ${appName} hace el trabajo pesado.`,
      `Gráficos claros con insights automáticos. Identifica patrones con ${appName}.`,
      `${appName} sustituye planillas y herramientas complicadas. Todo automático, todo en tu celular.`,
      `Define metas, acompaña el progreso y recibe alertas inteligentes. ${appName} te mantiene en el camino.`,
      `Usa en cualquier lugar, incluso sin internet. Sincroniza automáticamente al conectar.`,
      `Usado por miles de personas. ${appName} es la app más completa para quien quiere los mejores resultados.`,
    ],
  };

  const titles = genericTitles[lang] || genericTitles.pt;
  const descs = genericDescs[lang] || genericDescs.pt;

  return titles.map((title, i) => ({ title, desc: descs[i] || descs[0] }));
}

const ctas = {
  pt: buildCTAs('pt'),
  en: buildCTAs('en'),
  es: buildCTAs('es'),
};

const badges = { pt: 'App Gratuito', en: 'Free App', es: 'App Gratuita' };
const ctaButtons = { pt: config.app.ctaText.pt + ' →', en: config.app.ctaText.en + ' →', es: config.app.ctaText.es + ' →' };

const pool = ctas[locale] || ctas.pt;
const index = seed !== undefined ? seed % pool.length : Math.floor(Math.random() * pool.length);
const cta = pool[index];
const badge = badges[locale] || badges.pt;
const ctaBtn = ctaButtons[locale] || ctaButtons.pt;
---

<aside class={`cta-variado cta-variado--${variant}`}>
  <div class="cta-variado-badge">{badge}</div>
  <h4 class="cta-variado-title">{cta.title}</h4>
  {variant === 'full' && <p class="cta-variado-desc">{cta.desc}</p>}
  <a href={appUrl} class="cta-variado-btn" target="_blank" rel="noopener">
    {ctaBtn}
  </a>
</aside>

<style>
  .cta-variado {
    margin: var(--space-8) 0;
    padding: var(--space-6);
    background: var(--gradient-card);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    position: relative;
    overflow: hidden;
  }

  .cta-variado::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(135deg, #00F0FF, #A91079);
  }

  .cta-variado-badge {
    display: inline-block;
    padding: 2px var(--space-3);
    background: rgba(63, 185, 80, 0.15);
    color: var(--accent-green);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
    margin-bottom: var(--space-3);
  }

  .cta-variado-title {
    font-size: var(--text-lg);
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .cta-variado-desc {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-bottom: var(--space-4);
    line-height: var(--leading-relaxed);
  }

  .cta-variado-btn {
    display: inline-block;
    padding: var(--space-3) var(--space-5);
    background: linear-gradient(135deg, #00F0FF, #A91079);
    color: #fff;
    font-weight: 600;
    font-size: var(--text-sm);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .cta-variado-btn:hover {
    opacity: 0.9;
    transform: translateY(-1px);
    color: #fff;
  }

  .cta-variado--compact {
    padding: var(--space-4) var(--space-5);
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .cta-variado--compact .cta-variado-title {
    font-size: var(--text-base);
    margin-bottom: 0;
    flex: 1;
  }

  .cta-variado--compact .cta-variado-badge {
    margin-bottom: 0;
  }
</style>
