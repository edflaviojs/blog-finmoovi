---
---

<div class="banner-finmoovi">
  <div class="banner-content">
    <div class="banner-text">
      <span class="banner-badge">App Gratuito</span>
      <h3 class="banner-title">Organize suas finanças com o FinMoovi</h3>
      <p class="banner-description">
        Controle gastos, acompanhe investimentos e alcance seus objetivos financeiros. Multi-moeda, offline e inteligente.
      </p>
    </div>
    <div class="banner-actions">
      <a href="/app" class="banner-cta">
        Começar Grátis →
      </a>
    </div>
  </div>
</div>

<style>
  .banner-finmoovi {
    margin: var(--space-8) 0;
    padding: var(--space-8);
    background: var(--gradient-card);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-xl);
    position: relative;
    overflow: hidden;
  }

  .banner-finmoovi::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--gradient-cta);
  }

  .banner-finmoovi::after {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(88, 166, 255, 0.05) 0%, transparent 70%);
    pointer-events: none;
  }

  .banner-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .banner-content {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .banner-badge {
    display: inline-block;
    padding: 2px var(--space-3);
    background: rgba(63, 185, 80, 0.15);
    color: var(--accent-green);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
    margin-bottom: var(--space-3);
  }

  .banner-title {
    font-size: var(--text-xl);
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .banner-description {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    max-width: 500px;
    margin-bottom: 0;
  }

  .banner-cta {
    display: inline-block;
    padding: var(--space-3) var(--space-6);
    background: var(--gradient-cta);
    color: #fff;
    font-weight: 600;
    font-size: var(--text-sm);
    border-radius: var(--radius-full);
    white-space: nowrap;
    transition: all var(--transition-fast);
  }

  .banner-cta:hover {
    opacity: 0.9;
    transform: translateY(-1px);
    box-shadow: var(--shadow-glow);
    color: #fff;
  }
</style>
