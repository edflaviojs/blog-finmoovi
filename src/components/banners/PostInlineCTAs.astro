---
import { config } from '../../../site.config';

interface Props {
  locale?: string;
}

const { locale = 'pt' } = Astro.props;
const appUrl = config.app.url;
const appName = config.app.name;
const features = config.app.features;
const ctaTitle = config.app.ctaTitle;
const ctaNote = config.app.ctaNote;
const ctaText = config.app.ctaText;

// Build CTAs server-side from config (niche-agnostic)
function buildCTAs(lang) {
  const f = features[lang] || features.pt;
  const title = ctaTitle[lang] || ctaTitle.pt;
  const note = ctaNote[lang] || ctaNote.pt;

  const titles = {
    pt: [title, `${f[0]} com o ${appName}`, f[1], f[2], 'Comece grátis — sem cartão', 'Sua privacidade importa', f[3] || f[0], 'Relatórios inteligentes', 'Simples e automático', 'Alcance seus objetivos', 'Funciona offline', `${appName} — o mais completo`],
    en: [title, `${f[0]} with ${appName}`, f[1], f[2], 'Start free — no credit card', 'Your privacy matters', f[3] || f[0], 'Smart reports', 'Simple and automatic', 'Reach your goals', 'Works offline', `${appName} — the most complete`],
    es: [title, `${f[0]} con ${appName}`, f[1], f[2], 'Comienza gratis — sin tarjeta', 'Tu privacidad importa', f[3] || f[0], 'Reportes inteligentes', 'Simple y automático', 'Alcanza tus objetivos', 'Funciona offline', `${appName} — la más completa`],
  };

  const descs = {
    pt: [f.slice(0, 3).join('. ') + '.', `O ${appName} faz automaticamente. Menos trabalho, mais resultados.`, `Insights automáticos com o ${appName}.`, f.slice(1, 4).join('. ') + '.', note, `Seus dados ficam no seu dispositivo. Controle total com o ${appName}.`, `IA que entende você. O ${appName} faz o trabalho pesado.`, `Gráficos claros com insights. Identifique padrões com o ${appName}.`, `O ${appName} substitui ferramentas complicadas. Tudo automático.`, `Metas, progresso e alertas inteligentes. O ${appName} te mantém no caminho.`, `Use em qualquer lugar, sem internet. Sincroniza quando conectar.`, `Usado por milhares. O ${appName} é completo para quem quer resultados.`],
    en: [f.slice(0, 3).join('. ') + '.', `${appName} does it automatically. Less work, more results.`, `Automatic insights with ${appName}.`, f.slice(1, 4).join('. ') + '.', note, `Your data stays on your device. Full control with ${appName}.`, `AI that understands you. ${appName} does the heavy lifting.`, `Clear charts with insights. Identify patterns with ${appName}.`, `${appName} replaces complicated tools. All automatic.`, `Goals, progress, and smart alerts. ${appName} keeps you on track.`, `Use anywhere, no internet needed. Syncs when connected.`, `Used by thousands. ${appName} is the most complete for results.`],
    es: [f.slice(0, 3).join('. ') + '.', `${appName} lo hace automáticamente. Menos trabajo, más resultados.`, `Insights automáticos con ${appName}.`, f.slice(1, 4).join('. ') + '.', note, `Tus datos quedan en tu dispositivo. Control total con ${appName}.`, `IA que te entiende. ${appName} hace el trabajo pesado.`, `Gráficos claros con insights. Identifica patrones con ${appName}.`, `${appName} sustituye herramientas complicadas. Todo automático.`, `Metas, progreso y alertas inteligentes. ${appName} te mantiene en el camino.`, `Usa en cualquier lugar, sin internet. Sincroniza al conectar.`, `Usado por miles. ${appName} es la más completa para resultados.`],
  };

  const t = titles[lang] || titles.pt;
  const d = descs[lang] || descs.pt;
  return t.map((title, i) => ({ title, desc: d[i] || d[0] }));
}

const ctasData = JSON.stringify({
  pt: buildCTAs('pt'),
  en: buildCTAs('en'),
  es: buildCTAs('es'),
});
const badgeText = { pt: 'App Gratuito', en: 'Free App', es: 'App Gratuita' }[locale] || 'App Gratuito';
const btnText = (ctaText[locale] || ctaText.pt);
---

<script define:vars={{ locale, appUrl, appName, ctasData, badgeText, btnText }}>
(function() {
  const allCtas = JSON.parse(ctasData);
  const pool = allCtas[locale] || allCtas.pt;
  const badge = badgeText;

  function esc(s) {
    return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function createCTA(cta, variant) {
    const el = document.createElement('aside');
    el.className = 'post-inline-cta post-inline-cta--' + variant;
    el.setAttribute('aria-label', appName);

    const eyebrow = '<span class="pic-eyebrow">' + esc(appName) + ' · ' + esc(badge) + '</span>';
    const link = '<a href="' + appUrl + '" class="pic-btn" target="_blank" rel="noopener">' +
        esc(btnText) + '<span class="pic-arrow" aria-hidden="true">→</span></a>';

    if (variant === 'compact') {
      // Nota editorial numa linha só
      el.innerHTML =
        '<div class="pic-compact-wrap">' +
          '<div class="pic-compact-text">' +
            eyebrow +
            '<span class="pic-compact-title">' + esc(cta.title) + '</span>' +
          '</div>' +
          link +
        '</div>';
    } else {
      // full e sidebar: aparte editorial com filete de acento à esquerda.
      // 'sidebar' ganha o CTA como pílula contornada (variedade p/ A/B), 'full' como link.
      el.innerHTML =
        eyebrow +
        '<h4 class="pic-title">' + esc(cta.title) + '</h4>' +
        '<p class="pic-desc">' + esc(cta.desc) + '</p>' +
        link;
    }
    return el;
  }

  var content = document.querySelector('.post-content');
  if (!content) return;

  // Track CTA clicks for A/B analysis
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.pic-btn');
    if (!btn) return;
    var cta = btn.closest('.post-inline-cta');
    if (!cta) return;
    var variant = cta.className.includes('full') ? 'full' : cta.className.includes('sidebar') ? 'sidebar' : 'compact';
    var title = cta.querySelector('.pic-title,.pic-compact-title');
    try {
      navigator.sendBeacon('/api/cta-track', JSON.stringify({
        variant: variant,
        title: title ? title.textContent : '',
        page: window.location.pathname,
        ts: Date.now()
      }));
    } catch(e) {}
  });

  var paragraphs = content.querySelectorAll(':scope > p');
  if (paragraphs.length < 4) return;

  var seed = paragraphs.length;
  var positions = [];

  if (paragraphs.length >= 10) {
    positions = [
      { after: 2, variant: 'full' },
      { after: 5, variant: 'sidebar' },
      { after: 8, variant: 'compact' }
    ];
  } else if (paragraphs.length >= 6) {
    positions = [
      { after: 2, variant: 'full' },
      { after: 5, variant: 'sidebar' }
    ];
  } else {
    positions = [
      { after: 2, variant: 'full' }
    ];
  }

  for (var i = positions.length - 1; i >= 0; i--) {
    var pos = positions[i];
    var idx = (seed + i * 3) % pool.length;
    var cta = pool[idx];
    var ctaEl = createCTA(cta, pos.variant);
    var target = paragraphs[pos.after];
    if (target && target.nextSibling) {
      content.insertBefore(ctaEl, target.nextSibling);
    } else if (target) {
      content.appendChild(ctaEl);
    }
  }
})();
</script>

<style is:global>
  /* CTA editorial — "aparte" que faz parte da leitura, sem cara de banner.
     Filete de acento à esquerda, fundo levíssimo, CTA como link de texto. */
  .post-inline-cta {
    margin: 2.5rem 0;
    padding: 1.15rem 1.5rem 1.25rem 1.6rem;
    position: relative;
    border-radius: 0 10px 10px 0;
    background: linear-gradient(90deg,
      color-mix(in srgb, var(--accent-primary) 6%, transparent),
      transparent 62%);
  }

  .post-inline-cta::before {
    content: '';
    position: absolute;
    top: 0; bottom: 0; left: 0;
    width: 3px;
    border-radius: 3px;
    background: linear-gradient(180deg, var(--brand-cyan), var(--accent-primary));
  }

  .pic-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 0.55rem;
  }

  .pic-eyebrow::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--brand-cyan);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--brand-cyan) 22%, transparent);
  }

  .pic-title {
    color: var(--text-primary);
    font-size: 1.12rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin: 0 0 0.4rem;
    line-height: 1.35;
  }

  .pic-desc {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0 0 0.85rem;
  }

  /* CTA como LINK de texto (não botão gritante) */
  .pic-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-link) !important;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none !important;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
    transition: border-color 0.2s ease;
  }

  .pic-btn .pic-arrow {
    transition: transform 0.2s ease;
  }

  .pic-btn:hover {
    border-bottom-color: currentColor;
  }

  .pic-btn:hover .pic-arrow {
    transform: translateX(3px);
  }

  /* Variante SIDEBAR: mesmo aparte, mas CTA como pílula contornada (variedade A/B) */
  .post-inline-cta--sidebar .pic-btn {
    border: 1px solid color-mix(in srgb, var(--accent-primary) 45%, transparent);
    border-radius: 9999px;
    padding: 0.4rem 1rem;
    margin-top: 0.15rem;
  }

  .post-inline-cta--sidebar .pic-btn:hover {
    border-color: var(--accent-primary);
    background: color-mix(in srgb, var(--accent-primary) 8%, transparent);
  }

  /* Variante COMPACT: uma linha, discreta */
  .post-inline-cta--compact {
    padding: 0.9rem 1.25rem 0.9rem 1.4rem;
  }

  .pic-compact-wrap {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .pic-compact-text {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
    min-width: 0;
  }

  .post-inline-cta--compact .pic-eyebrow {
    margin-bottom: 0;
  }

  .pic-compact-title {
    color: var(--text-primary);
    font-size: 0.98rem;
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .pic-compact-wrap {
      align-items: flex-start;
    }
  }
</style>
