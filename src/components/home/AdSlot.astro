---
import { config } from '../../../site.config';

/**
 * Slot de publicidade própria (estático, sem JS).
 * IMPORTANTE: classes "promo-*" de propósito — nomes com "ad-" (ad-slot,
 * ad-rail...) estão nas listas dos bloqueadores de anúncio (EasyList) e os
 * banners sumiam para usuários com adblock. São banners PRÓPRIOS, não ads
 * de terceiros.
 * variant="rail" → retângulo vertical na coluna lateral
 * variant="strip" → faixa horizontal no meio do conteúdo
 */
interface Props {
  locale: 'pt' | 'en' | 'es';
  variant: 'rail' | 'strip';
}
const { locale, variant } = Astro.props;
const promo = variant === 'rail' ? config.ads.rail : config.ads.mid;
---

<a class={`promo-slot promo-${variant} promo-theme-${promo.theme}`} href={promo.href} target="_blank" rel="noopener">
  <span class="promo-icon" aria-hidden="true">{promo.icon}</span>
  <span class="promo-copy">
    <strong>{promo.title[locale]}</strong>
    <small>{promo.text[locale]}</small>
  </span>
  <span class="promo-cta">{promo.cta[locale]}</span>
</a>

<style>
  .promo-slot {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    padding: var(--space-5);
    border-radius: var(--radius-lg);
    color: #fff;
    overflow: hidden;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .promo-slot:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  .promo-theme-voz { background: linear-gradient(105deg, #0d1117 30%, #12303a 70%, #3a1030); }
  .promo-theme-moedas { background: linear-gradient(105deg, #04141f, #0a3d33 60%, #04141f); }
  .promo-theme-funil { background: radial-gradient(130% 160% at 15% 0%, #56123f 0%, #16070f 60%); }
  .promo-theme-offline { background: linear-gradient(105deg, #071a12, #103a24 60%, #071a12); }

  .promo-rail {
    flex-direction: column;
    text-align: center;
    gap: var(--space-3);
    min-height: 240px;
  }

  .promo-strip { min-height: 96px; flex-wrap: wrap; }

  .promo-icon { font-size: 34px; line-height: 1; }

  .promo-copy {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .promo-rail .promo-copy { align-items: center; }

  .promo-copy strong {
    font-size: clamp(15px, 2vw, 21px);
    letter-spacing: -0.01em;
    line-height: 1.25;
    color: #fff;
  }

  .promo-copy small {
    font-size: 13px;
    color: #a9c3d2;
  }

  /* Cores literais: o fundo do banner é sempre escuro, o botão precisa ser
     vivo nos dois temas (var(--brand-cyan) escurece no tema claro) */
  .promo-cta {
    background: #00F0FF;
    color: #04262b;
    font-weight: 800;
    padding: 8px 16px;
    border-radius: var(--radius-full);
    font-size: 13px;
    white-space: nowrap;
  }

  .promo-theme-funil .promo-cta { background: #ff9d5c; color: #33130a; }
  .promo-theme-moedas .promo-cta { background: #6ff2b5; color: #04291a; }
  .promo-theme-offline .promo-cta { background: #8be89f; color: #0a2912; }
</style>
