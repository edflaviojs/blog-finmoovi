---
import { config } from '../../../site.config';

/**
 * Slot de publicidade própria (estático, sem JS).
 * IMPORTANTE: classes "promo-*" de propósito — nomes com "ad-" (ad-slot,
 * ad-rail...) estão nas listas dos bloqueadores de anúncio (EasyList) e os
 * banners sumiam para usuários com adblock. São banners PRÓPRIOS, não ads
 * de terceiros.
 * variant="rail" → retângulo vertical na coluna lateral
 * variant="strip" → faixa horizontal no meio do conteúdo
 */
interface Props {
  locale: 'pt' | 'en' | 'es';
  variant: 'rail' | 'strip';
}
const { locale, variant } = Astro.props;
const promo = variant === 'rail' ? config.ads.rail : config.ads.mid;
---

<a class={`promo-slot promo-${variant} promo-theme-${promo.theme}`} href={promo.href} target="_blank" rel="noopener">
  <span class="promo-icon" aria-hidden="true">{promo.icon}</span>
  <span class="promo-copy">
    <strong>{promo.title[locale]}</strong>
    <small>{promo.text[locale]}</small>
  </span>
  <span class="promo-cta">{promo.cta[locale]}</span>
</a>

<style>
  .promo-slot {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    padding: var(--space-5);
    border-radius: var(--radius-lg);
    color: #fff;
    overflow: hidden;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .promo-slot:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  .promo-theme-voz { background: linear-gradient(105deg, #0d1117 30%, #12303a 70%, #3a1030); }
  .promo-theme-moedas { background: linear-gradient(105deg, #04141f, #0a3d33 60%, #04141f); }
  .promo-theme-funil { background: radial-gradient(130% 160% at 15% 0%, #56123f 0%, #16070f 60%); }
  .promo-theme-offline { background: linear-gradient(105deg, #071a12, #103a24 60%, #071a12); }

  .promo-rail {
    flex-direction: column;
    text-align: center;
    gap: var(--space-3);
    min-height: 240px;
    position: relative;
  }

  /* ===== MOTION do banner lateral: quebra o bloco estático da coluna =====
     4 camadas: brilho magenta orbitando + varredura de luz diagonal +
     ícone flutuando + CTA pulsando com anel de energia */
  .promo-rail::before {
    content: "";
    position: absolute;
    inset: -45%;
    background: radial-gradient(circle at 28% 22%, rgba(255, 94, 196, 0.38), transparent 52%);
    animation: promo-orbit 7s linear infinite;
    pointer-events: none;
  }

  .promo-rail::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(115deg, transparent 32%, rgba(255, 255, 255, 0.16) 48%, transparent 62%);
    transform: translateX(-130%);
    animation: promo-shine 3.8s ease infinite;
    pointer-events: none;
  }

  .promo-rail .promo-icon,
  .promo-rail .promo-copy,
  .promo-rail .promo-cta {
    position: relative;
    z-index: 1;
  }

  .promo-rail .promo-icon {
    animation: promo-float 2.8s ease-in-out infinite;
  }

  .promo-rail .promo-cta {
    animation: promo-cta-pulse 2.2s ease infinite;
  }

  @keyframes promo-orbit {
    to { transform: rotate(360deg); }
  }

  @keyframes promo-shine {
    0% { transform: translateX(-130%); }
    55%, 100% { transform: translateX(130%); }
  }

  @keyframes promo-float {
    0%, 100% { transform: translateY(0) rotate(-5deg) scale(1); }
    50% { transform: translateY(-9px) rotate(6deg) scale(1.1); }
  }

  @keyframes promo-cta-pulse {
    0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(255, 157, 92, 0.55); }
    50% { transform: scale(1.06); box-shadow: 0 0 0 14px rgba(255, 157, 92, 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .promo-rail::before, .promo-rail::after,
    .promo-rail .promo-icon, .promo-rail .promo-cta { animation: none; }
  }

  .promo-strip { min-height: 96px; flex-wrap: wrap; }

  .promo-icon { font-size: 34px; line-height: 1; }

  .promo-copy {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .promo-rail .promo-copy { align-items: center; }

  .promo-copy strong {
    font-size: clamp(15px, 2vw, 21px);
    letter-spacing: -0.01em;
    line-height: 1.25;
    color: #fff;
  }

  .promo-copy small {
    font-size: 13px;
    color: #a9c3d2;
  }

  /* Cores literais: o fundo do banner é sempre escuro, o botão precisa ser
     vivo nos dois temas (var(--brand-cyan) escurece no tema claro) */
  .promo-cta {
    background: #00F0FF;
    color: #04262b;
    font-weight: 800;
    padding: 8px 16px;
    border-radius: var(--radius-full);
    font-size: 13px;
    white-space: nowrap;
  }

  .promo-theme-funil .promo-cta { background: #ff9d5c; color: #33130a; }
  .promo-theme-moedas .promo-cta { background: #6ff2b5; color: #04291a; }
  .promo-theme-offline .promo-cta { background: #8be89f; color: #0a2912; }
</style>
