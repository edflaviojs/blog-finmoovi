---
import { config } from '../../../site.config';
import { getActiveSeasonalEvents } from '@/utils/seasonal';

/**
 * Carrossel billboard full-bleed (borda a borda da tela).
 * Slides vêm de config.ads.billboard — banners próprios, 100% estáticos.
 * Eventos sazonais ativos (config.seasonal) entram NA FRENTE das campanhas
 * fixas e saem sozinhos quando a janela fecha (build diário do bot).
 * Altura fixa (sem sobressalto), desliza sozinho a cada 5s, arrastável
 * (dedo/mouse), bolinhas clicáveis, pausa no hover.
 */
interface Props {
  locale: 'pt' | 'en' | 'es';
  /** desloca a ordem dos slides (o billboard do rodapé começa diferente) */
  offset?: number;
}
const { locale, offset = 0 } = Astro.props;

// Sazonais primeiro (destaque no carrossel do topo, offset 0); o href
// sazonal é por idioma — normalizado aqui para a mesma forma dos fixos
const seasonalSlides = getActiveSeasonalEvents(locale).map(e => ({
  theme: e.theme, icon: e.icon, href: e.href[locale as 'pt' | 'en' | 'es'],
  title: e.title, highlight: e.highlight, text: e.text, cta: e.cta,
}));
const base = [...seasonalSlides, ...config.ads.billboard];
const slides = base.map((_, i) => base[(i + offset) % base.length]);
---

<div class="bb" data-billboard>
  <div class="bb-track">
    {slides.map(s => (
      <div class={`bb-slide bb-${s.theme}`}>
        <div class="bb-in">
          <span class="bb-icon" aria-hidden="true">{s.icon}</span>
          <div class="bb-copy">
            <h2>{s.title[locale]} <em>{s.highlight[locale]}</em></h2>
            <p>{s.text[locale]}</p>
          </div>
          <a class="bb-cta" href={s.href} target="_blank" rel="noopener">{s.cta[locale]}</a>
        </div>
      </div>
    ))}
  </div>
  <div class="bb-dots" role="tablist" aria-label="Selecionar anúncio"></div>
</div>

<script>
  const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

  document.querySelectorAll('[data-billboard]').forEach((bb) => {
    const track = bb.querySelector('.bb-track') as HTMLElement;
    const slides = [...track.children];
    const dotsBox = bb.querySelector('.bb-dots') as HTMLElement;
    if (dotsBox.childElementCount > 0) return; // já inicializado
    let cur = 0;
    let timer: ReturnType<typeof setInterval> | null = null;
    let startX: number | null = null;

    slides.forEach((_, i) => {
      const d = document.createElement('button');
      d.setAttribute('role', 'tab');
      d.setAttribute('aria-label', 'Anúncio ' + (i + 1));
      if (i === 0) d.classList.add('on');
      d.addEventListener('click', () => { go(i); restart(); });
      dotsBox.appendChild(d);
    });
    const dots = [...dotsBox.children];

    function go(i: number) {
      dots[cur].classList.remove('on');
      cur = (i + slides.length) % slides.length;
      dots[cur].classList.add('on');
      track.style.transform = 'translateX(-' + (cur * 100) + '%)';
    }
    function next() { go(cur + 1); }
    function prev() { go(cur - 1); }
    function restart() { if (timer) clearInterval(timer); if (!reduced) timer = setInterval(next, 5000); }

    bb.addEventListener('mouseenter', () => { if (timer) clearInterval(timer); });
    bb.addEventListener('mouseleave', restart);
    bb.addEventListener('pointerdown', (e) => { startX = (e as PointerEvent).clientX; if (timer) clearInterval(timer); });
    bb.addEventListener('pointerup', (e) => {
      if (startX === null) return;
      const dx = (e as PointerEvent).clientX - startX;
      if (Math.abs(dx) > 40) { if (dx < 0) next(); else prev(); }
      startX = null;
      restart();
    });
    bb.addEventListener('pointercancel', () => { startX = null; restart(); });

    restart();
  });
</script>

<style>
  .bb {
    position: relative;
    width: 100%;
    height: 300px;
    overflow: hidden;
    touch-action: pan-y;
    user-select: none;
  }

  .bb-track {
    display: flex;
    height: 100%;
    transition: transform 0.55s cubic-bezier(0.3, 0.7, 0.3, 1);
    will-change: transform;
  }

  .bb-slide {
    flex: 0 0 100%;
    position: relative;
    height: 100%;
    display: grid;
    place-items: center;
    overflow: hidden;
  }

  .bb-slide::before { content: ""; position: absolute; inset: 0; }

  /* Climas visuais por tema — gradientes animados, cada campanha com o seu */
  .bb-voz::before { background: linear-gradient(115deg, #0d1117, #0e3540 30%, #4d1140 70%, #0d1117); background-size: 300% 300%; animation: bb-drift 9s ease infinite; }
  .bb-moedas::before { background: linear-gradient(120deg, #04141f, #0a3d33 45%, #04141f); background-size: 250% 250%; animation: bb-drift 11s ease infinite reverse; }
  .bb-funil::before { background: radial-gradient(120% 170% at 20% 0%, #56123f 0%, #16070f 55%), radial-gradient(90% 120% at 90% 100%, rgba(255, 120, 40, 0.35), transparent 60%); animation: bb-glow 4.5s ease infinite; }
  .bb-offline::before { background: linear-gradient(100deg, #071a12, #103a24 50%, #071a12); background-size: 280% 280%; animation: bb-drift 10s ease infinite; }

  @keyframes bb-drift { 0%, 100% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } }
  @keyframes bb-glow { 0%, 100% { filter: brightness(1); } 50% { filter: brightness(1.25); } }

  /* ===== Temas SAZONAIS (config.seasonal) — mesma linguagem dos fixos:
     gradiente escuro animado + CTA em cor viva literal (contraste nos 2 temas) */
  .bb-natal::before { background: linear-gradient(115deg, #0d1117, #0b3d2e 32%, #5a1620 68%, #0d1117); background-size: 300% 300%; animation: bb-drift 10s ease infinite; }
  .bb-natal .bb-cta { background: #f2c94c; color: #2a1e04; }
  .bb-anonovo::before { background: linear-gradient(115deg, #0d1117, #14285c 40%, #6e5308 75%, #0d1117); background-size: 300% 300%; animation: bb-drift 11s ease infinite; }
  .bb-anonovo .bb-cta { background: #ffd75e; color: #2a2104; }
  .bb-carnaval::before { background: linear-gradient(115deg, #2a0845, #7b1fa2 38%, #0d7a5f 72%, #2a0845); background-size: 300% 300%; animation: bb-drift 9s ease infinite; }
  .bb-carnaval .bb-cta { background: #ffd93d; color: #33270a; }
  .bb-blackfriday::before { background: linear-gradient(115deg, #050505, #1c1c1c 45%, #3a2405 78%, #050505); background-size: 300% 300%; animation: bb-drift 10s ease infinite; }
  .bb-blackfriday .bb-cta { background: #ffb300; color: #241800; }
  .bb-maes::before { background: linear-gradient(115deg, #2b0a1e, #8c2a5c 45%, #c96a8d 80%, #2b0a1e); background-size: 300% 300%; animation: bb-drift 11s ease infinite; }
  .bb-maes .bb-cta { background: #ffb3c9; color: #38101f; }
  .bb-ir::before { background: linear-gradient(115deg, #0d1117, #23301a 40%, #6e5a12 75%, #0d1117); background-size: 300% 300%; animation: bb-drift 10s ease infinite; }
  .bb-ir .bb-cta { background: #e4c65b; color: #2a2104; }

  .bb-in {
    position: relative;
    display: flex;
    align-items: center;
    gap: clamp(14px, 3.5vw, 44px);
    padding: 20px 24px 34px;
    color: #fff;
    flex-wrap: wrap;
    justify-content: center;
    max-height: 100%;
  }

  .bb-icon { font-size: clamp(42px, 6vw, 80px); line-height: 1; }

  .bb-copy h2 {
    margin: 0;
    font-size: clamp(22px, 3.4vw, 44px);
    letter-spacing: -0.02em;
    line-height: 1.1;
    max-width: 18ch;
    text-wrap: balance;
    /* explícito: headings globais definem color e apagariam o branco no tema claro */
    color: #fff;
  }

  .bb-copy h2 em {
    font-style: normal;
    /* literal: var(--brand-cyan) escurece no tema claro e apagava o destaque */
    background: linear-gradient(90deg, #00F0FF, #ff5ec4);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .bb-copy p {
    margin: 6px 0 0;
    color: #a7c4d2;
    font-size: clamp(13px, 1.4vw, 16px);
    max-width: 52ch;
  }

  .bb-cta {
    /* ciano vivo literal + texto quase-preto: contraste alto nos 2 temas */
    background: #00F0FF;
    color: #04262b;
    font-weight: 800;
    padding: 13px 28px;
    border-radius: var(--radius-full);
    font-size: 15px;
    white-space: nowrap;
    transition: transform var(--transition-fast);
  }

  .bb-cta:hover { transform: scale(1.06); }
  /* Slide voz: botão no gradiente da marca com texto branco — pop imediato */
  .bb-voz .bb-cta { background: linear-gradient(90deg, #00c8d7, #A91079); color: #fff; }
  .bb-moedas .bb-cta { background: #6ff2b5; color: #04291a; }
  .bb-funil .bb-cta { background: #ff9d5c; color: #33130a; }
  .bb-offline .bb-cta { background: #8be89f; color: #0a2912; }

  .bb-dots {
    position: absolute;
    bottom: 4px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0;
    z-index: 3;
  }

  /* Botão 24×24 (alvo de toque mínimo WCAG/Lighthouse); a bolinha visível
     de 9px é desenhada no ::before, então o visual continua discreto */
  .bb-dots :global(button) {
    width: 24px;
    height: 24px;
    border: 0;
    background: transparent;
    cursor: pointer;
    padding: 0;
    display: grid;
    place-items: center;
  }

  .bb-dots :global(button)::before {
    content: "";
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.35);
    transition: all 0.25s;
  }

  .bb-dots :global(button.on)::before {
    background: #fff;
    width: 22px;
    border-radius: 6px;
  }

  @media (max-width: 767px) {
    .bb { height: 330px; }
    .bb-in { flex-direction: column; text-align: center; gap: 8px; padding: 18px 18px 36px; }
    .bb-icon { font-size: 42px; }
    .bb-copy h2 { max-width: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .bb-slide::before { animation: none; }
    .bb-track { transition: none; }
  }
</style>
