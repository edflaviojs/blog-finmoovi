---
// ⚙️ MÓDULO DE NICHO (lead magnet): os textos abaixo (aqui e no <script>) anunciam o
// "Guia 30 Dias" — o material rico do nicho de finanças (entregue por functions/api/newsletter.js).
// Ao replicar o template, crie o lead magnet do NOVO nicho e atualize título/descrição/botão
// nos dois lugares + os templates de e-mail em functions/api/newsletter.js.
---

<div class="newsletter-popup" id="newsletter-popup" aria-hidden="true">
  <div class="popup-backdrop" id="popup-backdrop"></div>
  <div class="popup-content" role="dialog" aria-modal="true">
    <button class="popup-close" id="popup-close" aria-label="Fechar">&times;</button>
    <div class="popup-icon">🎁</div>
    <h3 class="popup-title" id="popup-title">Guia Grátis: 30 Dias para Organizar suas Finanças</h3>
    <p class="popup-desc" id="popup-desc">
      Receba o guia passo a passo + dicas semanais de finanças pessoais. Um email por semana, sem spam.
    </p>
    <form class="popup-form" id="popup-form">
      <input
        type="email"
        name="email"
        placeholder="seu@email.com"
        required
        class="popup-input"
        id="popup-email"
      />
      <button type="submit" class="popup-btn" id="popup-btn">Quero o Guia!</button>
    </form>
    <p class="popup-message" id="popup-message"></p>
    <p class="popup-privacy" id="popup-privacy">Sem spam. Cancele quando quiser.</p>
  </div>
</div>

<script>
  (function() {
    var popup = document.getElementById('newsletter-popup');
    var shown = false;
    try { shown = !!sessionStorage.getItem('fm-popup-shown'); } catch(e) {}
    if (shown || !popup) return;

    var lang = 'pt';
    if (window.location.pathname.startsWith('/en/')) lang = 'en';
    else if (window.location.pathname.startsWith('/es/')) lang = 'es';

    var texts = {
      pt: {
        title: 'Guia Grátis: 30 Dias para Organizar suas Finanças',
        desc: 'Receba o guia passo a passo + dicas semanais de finanças pessoais. Um email por semana, sem spam.',
        btn: 'Quero o Guia!',
        privacy: 'Sem spam. Cancele quando quiser.'
      },
      en: {
        title: 'Free Guide: 30 Days to Organize Your Finances',
        desc: 'Get the step-by-step guide + weekly personal finance tips. One email per week, no spam.',
        btn: 'Get the Guide!',
        privacy: 'No spam. Unsubscribe anytime.'
      },
      es: {
        title: 'Guía Gratis: 30 Días para Organizar tus Finanzas',
        desc: 'Recibe la guía paso a paso + consejos semanales de finanzas personales. Un email por semana, sin spam.',
        btn: '¡Quiero la Guía!',
        privacy: 'Sin spam. Cancela cuando quieras.'
      }
    };
    var t = texts[lang] || texts.pt;
    document.getElementById('popup-title').textContent = t.title;
    document.getElementById('popup-desc').textContent = t.desc;
    document.getElementById('popup-btn').textContent = t.btn;
    document.getElementById('popup-privacy').textContent = t.privacy;
    var closeLabels = { pt: 'Fechar', en: 'Close', es: 'Cerrar' };
    document.getElementById('popup-close').setAttribute('aria-label', closeLabels[lang] || 'Fechar');

    var triggered = false;
    function showPopup() {
      if (triggered) return;
      triggered = true;
      popup.classList.add('visible');
      popup.setAttribute('aria-hidden', 'false');
      document.getElementById('popup-email')?.focus();
      try { sessionStorage.setItem('fm-popup-shown', '1'); } catch(e) {}
    }

    function hidePopup() {
      popup.classList.remove('visible');
      popup.setAttribute('aria-hidden', 'true');
    }

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && popup.classList.contains('visible')) hidePopup();
    });

    window.addEventListener('scroll', function() {
      if (triggered) return;
      var scrollable = document.documentElement.scrollHeight - window.innerHeight;
      if (scrollable <= 0) return;
      var scrollPercent = (window.scrollY / scrollable) * 100;
      if (scrollPercent >= 75) showPopup();
    }, { passive: true });

    // Fallback: show after 30s for short posts where scroll triggers may never fire
    setTimeout(function() { if (!triggered) showPopup(); }, 30000);

    document.addEventListener('mouseout', function(e) {
      if (triggered) return;
      if (e.clientY <= 0 && e.relatedTarget === null) showPopup();
    });

    var lastScrollY = window.scrollY;
    var scrollUpDistance = 0;
    window.addEventListener('scroll', function() {
      if (triggered) return;
      var currentY = window.scrollY;
      if (currentY < lastScrollY) {
        scrollUpDistance += (lastScrollY - currentY);
        if (scrollUpDistance > 500 && currentY > 400) showPopup();
      } else {
        scrollUpDistance = 0;
      }
      lastScrollY = currentY;
    }, { passive: true });

    document.getElementById('popup-close')?.addEventListener('click', hidePopup);

    document.getElementById('popup-backdrop')?.addEventListener('click', hidePopup);

    document.getElementById('popup-form')?.addEventListener('submit', async function(e) {
      e.preventDefault();
      var email = document.getElementById('popup-email').value.trim();
      var msg = document.getElementById('popup-message');
      if (!email) return;

      try {
        var res = await fetch('/api/newsletter', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email, lang: lang, source: 'exit-popup' })
        });
        var data = await res.json();
        if (res.ok) {
          msg.textContent = data.message || (lang === 'en' ? 'Subscribed!' : lang === 'es' ? '¡Suscrito!' : 'Inscrito!');
          msg.className = 'popup-message success';
          setTimeout(function() {
            popup.classList.remove('visible');
          }, 2000);
        } else {
          msg.textContent = data.error || 'Erro. Tente novamente.';
          msg.className = 'popup-message error';
        }
      } catch (err) {
        msg.textContent = lang === 'en' ? 'Connection error.' : lang === 'es' ? 'Error de conexión.' : 'Erro de conexão.';
        msg.className = 'popup-message error';
      }
    });
  })();
</script>

<style>
  .newsletter-popup {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--transition-base);
  }

  .newsletter-popup.visible {
    opacity: 1;
    pointer-events: all;
  }

  .popup-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
  }

  .popup-content {
    position: relative;
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    max-width: 420px;
    width: 90%;
    text-align: center;
    transform: translateY(20px);
    transition: transform var(--transition-base);
  }

  .newsletter-popup.visible .popup-content {
    transform: translateY(0);
  }

  .popup-close {
    position: absolute;
    top: var(--space-3);
    right: var(--space-4);
    font-size: 24px;
    color: var(--text-tertiary);
    background: none;
    border: none;
    cursor: pointer;
    line-height: 1;
  }

  .popup-close:hover { color: var(--text-primary); }

  .popup-icon { font-size: 40px; margin-bottom: var(--space-3); }

  .popup-title {
    font-size: var(--text-xl);
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .popup-desc {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-bottom: var(--space-5);
  }

  .popup-form {
    display: flex;
    gap: var(--space-2);
  }

  .popup-input {
    flex: 1;
    padding: var(--space-3) var(--space-4);
    background: var(--bg-tertiary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    font-size: var(--text-sm);
  }

  .popup-input:focus {
    border-color: var(--accent-primary);
    outline: none;
  }

  .popup-btn {
    padding: var(--space-3) var(--space-5);
    background: var(--gradient-cta);
    color: #fff;
    font-weight: 600;
    font-size: var(--text-sm);
    border-radius: var(--radius-md);
    white-space: nowrap;
    transition: opacity var(--transition-fast);
  }

  .popup-btn:hover { opacity: 0.9; }

  /* Mobile: stack form vertically */
  @media (max-width: 480px) {
    .popup-content {
      width: 92%;
      padding: var(--space-6);
    }

    .popup-form {
      flex-direction: column;
    }

    .popup-btn {
      width: 100%;
      text-align: center;
      padding: var(--space-4) var(--space-5);
    }

    .popup-title {
      font-size: var(--text-lg);
    }
  }

  .popup-message {
    font-size: var(--text-xs);
    margin-top: var(--space-2);
    min-height: 1.2em;
  }

  .popup-message.success { color: var(--accent-green); }
  .popup-message.error { color: var(--accent-red); }

  .popup-privacy {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    margin-top: var(--space-3);
  }
</style>
