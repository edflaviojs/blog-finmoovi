---
import { config } from '../../../site.config';

/**
 * Popup "Adicione como Fonte Preferida no Google".
 * Regras (redesign portal 2026-07):
 * - Só é incluído em páginas de CONTEÚDO (PostLayout/glossário) — nunca na home.
 * - Aparece quando o leitor passa de 60% da página (leitor engajado).
 * - Memória via localStorage: quem clicou em "Adicionar" nunca mais vê;
 *   quem fechou no ✕ fica 30 dias sem ver.
 * Preferred Sources é sinal global do Google (2026), inclusive em AI Overviews.
 */
interface Props { locale?: 'pt' | 'en' | 'es'; }
const { locale = 'pt' } = Astro.props;

const brand = config.brand.name;
// Deeplink oficial do Google (Search Central): domínio no parâmetro q.
const domain = config.siteUrl.replace(/^https?:\/\//, '').replace(/\/$/, '');
const prefUrl = `https://google.com/preferences/source?q=${domain}`;

const T = {
  pt: {
    title: `⭐ Veja mais do ${brand}`,
    body: `Adicione como <strong>fonte preferida</strong> no Google e veja mais artigos nossos nas buscas e respostas de IA.`,
    cta: 'Adicionar no Google',
  },
  en: {
    title: `⭐ See more from ${brand}`,
    body: `Add us as a <strong>preferred source</strong> on Google to see more of our articles in search and AI answers.`,
    cta: 'Add on Google',
  },
  es: {
    title: `⭐ Ve más de ${brand}`,
    body: `Añádenos como <strong>fuente preferida</strong> en Google y verás más de nuestros artículos en búsquedas y respuestas de IA.`,
    cta: 'Añadir en Google',
  },
}[locale];
---

<aside class="pref-source" id="pref-source" aria-label="Fonte preferida" hidden>
  <button class="pref-close" id="pref-close" aria-label="Fechar">✕</button>
  <strong class="pref-title">{T.title}</strong>
  <p set:html={T.body}></p>
  <a class="pref-btn" id="pref-go" href={prefUrl} target="_blank" rel="noopener">{T.cta}</a>
</aside>

<script>
  const KEY = 'fm-pref-source';
  const SNOOZE_MS = 30 * 24 * 60 * 60 * 1000; // 30 dias
  const card = document.getElementById('pref-source') as HTMLElement;

  function eligible(): boolean {
    try {
      const v = JSON.parse(localStorage.getItem(KEY) || 'null');
      if (!v) return true;
      if (v.done) return false;
      if (v.snooze && Date.now() - v.snooze < SNOOZE_MS) return false;
      return true;
    } catch (e) { return true; }
  }

  function save(value: object) {
    try { localStorage.setItem(KEY, JSON.stringify(value)); } catch (e) {}
  }

  let shown = false;
  function maybeShow() {
    if (shown || !eligible()) return;
    const depth = (scrollY + innerHeight) / document.documentElement.scrollHeight;
    if (depth >= 0.6) {
      card.hidden = false;
      shown = true;
    }
  }

  addEventListener('scroll', maybeShow, { passive: true });

  document.getElementById('pref-go')?.addEventListener('click', () => {
    save({ done: true });
    card.remove();
  });
  document.getElementById('pref-close')?.addEventListener('click', () => {
    save({ snooze: Date.now() });
    card.remove();
  });
</script>

<style>
  .pref-source {
    position: fixed;
    left: 50%;
    bottom: 72px; /* acima do aviso de cookies, se ambos coexistirem */
    transform: translateX(-50%);
    z-index: var(--z-toast);
    width: min(92vw, 300px);
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
    box-shadow: var(--shadow-lg);
    text-align: center;
  }

  .pref-title {
    display: block;
    color: var(--text-primary);
    font-size: 13.5px;
    margin-bottom: var(--space-1);
  }

  .pref-source p {
    margin: 0 0 var(--space-3);
    color: var(--text-secondary);
    font-size: 12px;
    line-height: 1.5;
  }

  .pref-source :global(strong) { color: var(--text-primary); }

  .pref-btn {
    display: inline-block;
    background: var(--gradient-cta);
    color: #fff;
    font-size: 12.5px;
    font-weight: 700;
    padding: 7px 20px;
    border-radius: var(--radius-full);
    transition: transform var(--transition-fast);
  }

  .pref-btn:hover { transform: translateY(-1px); }

  .pref-close {
    position: absolute;
    top: 6px;
    right: 9px;
    border: 0;
    background: none;
    color: var(--text-tertiary);
    font-size: 15px;
    cursor: pointer;
  }
</style>
