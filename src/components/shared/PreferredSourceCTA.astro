---
import { config } from '../../../site.config';

/**
 * CTA "Adicione como Fonte Preferida no Google".
 * Preferred Sources virou sinal global (2026), inclusive em AI Overviews/AI Mode.
 * Custo ~zero; pede ao leitor engajado para marcar o blog como fonte preferida.
 */
interface Props { locale?: 'pt' | 'en' | 'es'; }
const { locale = 'pt' } = Astro.props;

const brand = config.brand.name;
// Deeplink oficial do Google (Search Central): domínio no parâmetro q (subdomínio elegível).
const domain = config.siteUrl.replace(/^https?:\/\//, '').replace(/\/$/, '');
const prefUrl = `https://google.com/preferences/source?q=${domain}`;
const T = {
  pt: {
    title: 'Gostou do conteúdo?',
    body: `Adicione o <strong>${brand}</strong> como <strong>fonte preferida</strong> no Google: você passa a ver mais dos nossos artigos nas notícias e nas respostas de IA.`,
    how: `Na página do Google que abrir, procure por <strong>${brand}</strong> e toque no nome para adicioná-lo às suas fontes.`,
    cta: '⭐ Adicionar como fonte preferida',
    note: 'Recurso do Google (é preciso estar logado). Se o FinMoovi ainda não aparecer, é porque estamos ganhando presença — tente novamente em breve.',
  },
  en: {
    title: 'Enjoying the content?',
    body: `Add <strong>${brand}</strong> as a <strong>preferred source</strong> on Google to see more of our articles in news and AI answers.`,
    how: `On the Google page that opens, search for <strong>${brand}</strong> and tap the name to add it to your sources.`,
    cta: '⭐ Add as preferred source',
    note: 'Google feature (you must be signed in). If FinMoovi doesn’t appear yet, we’re still gaining presence — try again soon.',
  },
  es: {
    title: '¿Te gustó el contenido?',
    body: `Añade <strong>${brand}</strong> como <strong>fuente preferida</strong> en Google y verás más de nuestros artículos en noticias y respuestas de IA.`,
    how: `En la página de Google que se abre, busca <strong>${brand}</strong> y toca el nombre para añadirlo a tus fuentes.`,
    cta: '⭐ Añadir como fuente preferida',
    note: 'Función de Google (debes iniciar sesión). Si FinMoovi aún no aparece, estamos ganando presencia — inténtalo pronto.',
  },
}[locale];
---

<aside class="pref-source" aria-label="Fonte preferida">
  <span class="pref-source-icon">⭐</span>
  <div class="pref-source-text">
    <strong class="pref-source-title">{T.title}</strong>
    <p set:html={T.body}></p>
    <a class="pref-source-btn" href={prefUrl} target="_blank" rel="noopener">{T.cta}</a>
    <p class="pref-source-how" set:html={T.how}></p>
    <span class="pref-source-note">{T.note}</span>
  </div>
</aside>

<style>
  .pref-source {
    display: flex; gap: var(--space-4); align-items: center;
    max-width: 800px; margin: var(--space-8) auto;
    padding: var(--space-5) var(--space-6);
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    border-left: 3px solid var(--brand-cyan);
    border-radius: var(--radius-lg);
  }
  .pref-source-icon { font-size: 1.75rem; line-height: 1; }
  .pref-source-title { display: block; color: var(--text-primary); margin-bottom: var(--space-1); }
  .pref-source-text p { color: var(--text-secondary); font-size: var(--text-sm); line-height: var(--leading-relaxed); margin: 0; }
  .pref-source-text :global(strong) { color: var(--text-primary); }
  .pref-source-btn {
    display: inline-block; margin-top: var(--space-3);
    padding: var(--space-2) var(--space-4);
    background: var(--gradient-cta); color: #fff;
    font-size: var(--text-sm); font-weight: 600;
    border-radius: var(--radius-full);
    transition: all var(--transition-fast);
  }
  .pref-source-btn:hover { opacity: 0.9; transform: translateY(-1px); }
  .pref-source-how { margin: var(--space-3) 0 0; color: var(--text-secondary); font-size: var(--text-sm); line-height: var(--leading-relaxed); }
  .pref-source-how :global(strong) { color: var(--text-primary); }
  .pref-source-note { display: block; margin-top: var(--space-2); color: var(--text-tertiary); font-size: var(--text-xs); }
</style>
