---
import { config } from '../../../site.config';

interface Props {
  term?: string;
}
const { term } = Astro.props;
// Giscus config comes from site.config.ts
const { repo, repoId, category, categoryId } = config.giscus;
const giscusEnabled = repoId && categoryId;
---

<section class="comments-section">
  <h3 class="comments-title" data-i18n="post.comments">Comentários</h3>
  {giscusEnabled ? (
    <div id="giscus-container">
      <script
        src="https://giscus.app/client.js"
        data-repo={repo}
        data-repo-id={repoId}
        data-category={category}
        data-category-id={categoryId}
        data-mapping="pathname"
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="top"
        data-theme="dark_dimmed"
        data-lang="pt"
        data-loading="lazy"
        crossorigin="anonymous"
        async
      ></script>
    </div>
  ) : (
    <p class="comments-placeholder" data-i18n="post.commentsPlaceholder">
      Comentários serão ativados em breve. Volte depois!
    </p>
  )}
  <p class="comments-note" data-i18n="post.commentsNote">
    Comentários via GitHub Discussions. Faça login com sua conta GitHub para participar.
  </p>
</section>

<style>
  .comments-section {
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-muted);
  }

  .comments-title {
    font-size: var(--text-xl);
    color: var(--text-primary);
    margin-bottom: var(--space-6);
  }

  .comments-note {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    margin-top: var(--space-4);
    text-align: center;
  }

  .comments-placeholder {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    text-align: center;
    padding: var(--space-8) 0;
    border: 1px dashed var(--border-default);
    border-radius: var(--radius-md);
  }
</style>
