---
/**
 * CTA Variado — mostra uma CTA diferente a cada vez
 * Pool de 10+ variações para não cansar o usuário
 *
 * ⚙️ MÓDULO DE NICHO: as variações 2-12 descrevem features do app de FINANÇAS
 * (gastos, investimentos, moedas). Ao replicar o template, reescreva o pool
 * para o novo produto/nicho (a variação 1 já deriva 100% do config).
 */
import { config } from '../../../site.config';

interface Props {
  seed?: number;
}

const { seed } = Astro.props;
const appName = config.app.name;
const appUrl = config.app.url;

const ctas = [
  { title: config.app.ctaTitle.pt, desc: `${config.app.features.pt.slice(0, 3).join('. ')}.` },
  { title: 'Controle seus gastos de forma inteligente', desc: `O ${appName} categoriza suas transações automaticamente. Menos trabalho, mais clareza sobre seu dinheiro.` },
  { title: 'Acompanhe investimentos em tempo real', desc: `Dashboards com insights automáticos. Saiba exatamente onde seu dinheiro está indo com o ${appName}.` },
  { title: 'Multi-moeda, offline e inteligente', desc: 'BRL, USD, EUR com conversão automática. Funciona sem internet. Seus dados ficam no seu dispositivo.' },
  { title: 'Comece grátis — sem cartão de crédito', desc: '7 dias grátis para experimentar todas as funcionalidades. Cancele quando quiser, sem burocracia.' },
  { title: 'Sua privacidade financeira importa', desc: `Criptografia de ponta a ponta. Seus dados nunca saem do seu dispositivo. Controle total com o ${appName}.` },
  { title: 'Lance gastos em 5 segundos com IA', desc: `Smart Capture entende linguagem natural. Diga "almocei 35 reais" e pronto. O ${appName} faz o resto.` },
  { title: 'Relatórios que fazem sentido', desc: `Gráficos claros que mostram para onde vai seu dinheiro. Identifique padrões e economize mais com o ${appName}.` },
  { title: 'Chega de planilhas complicadas', desc: `O ${appName} substitui suas planilhas por um app intuitivo. Tudo automático, tudo no celular.` },
  { title: 'Alcance seus objetivos financeiros', desc: `Defina metas, acompanhe o progresso e receba alertas inteligentes. O ${appName} te mantém no caminho.` },
  { title: 'O app que funciona offline', desc: 'Registre gastos em qualquer lugar, mesmo sem internet. Sincroniza automaticamente quando conectar.' },
  { title: 'Controle de classe mundial', desc: `Usado por milhares de brasileiros. O ${appName} é o app mais completo para quem quer organizar suas finanças.` },
];

// Pick a CTA based on seed or random
const index = seed !== undefined ? seed % ctas.length : Math.floor(Math.random() * ctas.length);
const cta = ctas[index];
---

<aside class="cta-variado">
  <span class="cta-variado-eyebrow">{appName} · App Gratuito</span>
  <h4 class="cta-variado-title">{cta.title}</h4>
  <p class="cta-variado-desc">{cta.desc}</p>
  <a href={appUrl} class="cta-variado-btn" target="_blank" rel="noopener">{config.app.ctaText.pt}<span class="cta-variado-arrow" aria-hidden="true">→</span></a>
</aside>

<style>
  /* Aparte editorial — parte da leitura, sem cara de banner */
  .cta-variado {
    margin: var(--space-8) 0;
    padding: 1.15rem 1.5rem 1.25rem 1.6rem;
    position: relative;
    border-radius: 0 10px 10px 0;
    background: linear-gradient(90deg,
      color-mix(in srgb, var(--accent-primary) 6%, transparent),
      transparent 62%);
  }

  .cta-variado::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 3px;
    border-radius: 3px;
    background: linear-gradient(180deg, var(--brand-cyan), var(--accent-primary));
  }

  .cta-variado-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 0.55rem;
  }

  .cta-variado-eyebrow::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--brand-cyan);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--brand-cyan) 22%, transparent);
  }

  .cta-variado-title {
    font-size: var(--text-lg);
    color: var(--text-primary);
    letter-spacing: -0.01em;
    margin-bottom: 0.4rem;
    line-height: 1.35;
  }

  .cta-variado-desc {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-bottom: 0.85rem;
    line-height: var(--leading-relaxed);
  }

  .cta-variado-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-link);
    font-weight: 600;
    font-size: var(--text-sm);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
    transition: border-color var(--transition-fast);
  }

  .cta-variado-arrow {
    transition: transform var(--transition-fast);
  }

  .cta-variado-btn:hover {
    border-bottom-color: currentColor;
    color: var(--text-link);
  }

  .cta-variado-btn:hover .cta-variado-arrow {
    transform: translateX(3px);
  }
</style>
