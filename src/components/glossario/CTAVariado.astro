---
/**
 * CTA Variado — mostra uma CTA diferente a cada vez
 * Pool de 10+ variações para não cansar o usuário
 *
 * ⚙️ MÓDULO DE NICHO: as variações 2-12 descrevem features do app de FINANÇAS
 * (gastos, investimentos, moedas). Ao replicar o template, reescreva o pool
 * para o novo produto/nicho (a variação 1 já deriva 100% do config).
 */
import { config } from '../../../site.config';

interface Props {
  seed?: number;
  locale?: string;
}

const { seed, locale = 'pt' } = Astro.props;
const appName = config.app.name;
const appUrl = config.app.url;

// CTAs por idioma (atenção: glossário existe em pt/en/es)
const ctasByLang: Record<string, { title: string; desc: string }[]> = {
  pt: [
    { title: config.app.ctaTitle.pt, desc: `${config.app.features.pt.slice(0, 3).join('. ')}.` },
    { title: 'Controle seus gastos de forma inteligente', desc: `O ${appName} categoriza suas transações automaticamente. Menos trabalho, mais clareza sobre seu dinheiro.` },
    { title: 'Acompanhe investimentos em tempo real', desc: `Dashboards com insights automáticos. Saiba exatamente onde seu dinheiro está indo com o ${appName}.` },
    { title: 'Multi-moeda, offline e inteligente', desc: 'BRL, USD, EUR com conversão automática. Funciona sem internet. Seus dados ficam no seu dispositivo.' },
    { title: 'Comece grátis — sem cartão de crédito', desc: '7 dias grátis para experimentar todas as funcionalidades. Cancele quando quiser, sem burocracia.' },
    { title: 'Sua privacidade financeira importa', desc: `Criptografia de ponta a ponta. Seus dados nunca saem do seu dispositivo. Controle total com o ${appName}.` },
    { title: 'Lance gastos em 5 segundos com IA', desc: `Smart Capture entende linguagem natural. Diga "almocei 35 reais" e pronto. O ${appName} faz o resto.` },
    { title: 'Relatórios que fazem sentido', desc: `Gráficos claros que mostram para onde vai seu dinheiro. Identifique padrões e economize mais com o ${appName}.` },
    { title: 'Chega de planilhas complicadas', desc: `O ${appName} substitui suas planilhas por um app intuitivo. Tudo automático, tudo no celular.` },
    { title: 'Alcance seus objetivos financeiros', desc: `Defina metas, acompanhe o progresso e receba alertas inteligentes. O ${appName} te mantém no caminho.` },
    { title: 'O app que funciona offline', desc: 'Registre gastos em qualquer lugar, mesmo sem internet. Sincroniza automaticamente quando conectar.' },
    { title: 'Controle de classe mundial', desc: `Usado por milhares de pessoas. O ${appName} é o app mais completo para quem quer organizar suas finanças.` },
  ],
  en: [
    { title: config.app.ctaTitle.en, desc: `${config.app.features.en.slice(0, 3).join('. ')}.` },
    { title: 'Track your spending intelligently', desc: `${appName} categorizes your transactions automatically. Less work, more clarity about your money.` },
    { title: 'Follow your investments in real time', desc: `Dashboards with automatic insights. Know exactly where your money is going with ${appName}.` },
    { title: 'Multi-currency, offline and smart', desc: 'BRL, USD, EUR with automatic conversion. Works without internet. Your data stays on your device.' },
    { title: 'Start free — no credit card', desc: '7 days free to try every feature. Cancel anytime, no hassle.' },
    { title: 'Your financial privacy matters', desc: `End-to-end encryption. Your data never leaves your device. Full control with ${appName}.` },
    { title: 'Log expenses in 5 seconds with AI', desc: `Smart Capture understands natural language. Say "lunch 35 dollars" and done. ${appName} handles the rest.` },
    { title: 'Reports that make sense', desc: `Clear charts that show where your money goes. Spot patterns and save more with ${appName}.` },
    { title: 'No more complicated spreadsheets', desc: `${appName} replaces your spreadsheets with an intuitive app. All automatic, all on your phone.` },
    { title: 'Reach your financial goals', desc: `Set goals, track progress and get smart alerts. ${appName} keeps you on track.` },
    { title: 'The app that works offline', desc: 'Log expenses anywhere, even without internet. Syncs automatically when you reconnect.' },
    { title: 'World-class money control', desc: `Used by thousands of people. ${appName} is the most complete app for organizing your finances.` },
  ],
  es: [
    { title: config.app.ctaTitle.es, desc: `${config.app.features.es.slice(0, 3).join('. ')}.` },
    { title: 'Controla tus gastos de forma inteligente', desc: `${appName} categoriza tus transacciones automáticamente. Menos trabajo, más claridad sobre tu dinero.` },
    { title: 'Sigue tus inversiones en tiempo real', desc: `Dashboards con insights automáticos. Sabe exactamente a dónde va tu dinero con ${appName}.` },
    { title: 'Multi-moneda, offline e inteligente', desc: 'BRL, USD, EUR con conversión automática. Funciona sin internet. Tus datos quedan en tu dispositivo.' },
    { title: 'Comienza gratis — sin tarjeta de crédito', desc: '7 días gratis para probar todas las funciones. Cancela cuando quieras, sin trámites.' },
    { title: 'Tu privacidad financiera importa', desc: `Cifrado de punta a punta. Tus datos nunca salen de tu dispositivo. Control total con ${appName}.` },
    { title: 'Registra gastos en 5 segundos con IA', desc: `Smart Capture entiende lenguaje natural. Di "almuerzo 35 euros" y listo. ${appName} hace el resto.` },
    { title: 'Reportes que tienen sentido', desc: `Gráficos claros que muestran a dónde va tu dinero. Identifica patrones y ahorra más con ${appName}.` },
    { title: 'Basta de planillas complicadas', desc: `${appName} sustituye tus planillas por una app intuitiva. Todo automático, todo en tu móvil.` },
    { title: 'Alcanza tus objetivos financieros', desc: `Define metas, sigue el progreso y recibe alertas inteligentes. ${appName} te mantiene en el camino.` },
    { title: 'La app que funciona offline', desc: 'Registra gastos en cualquier lugar, incluso sin internet. Sincroniza automáticamente al reconectar.' },
    { title: 'Control de nivel mundial', desc: `Usado por miles de personas. ${appName} es la app más completa para organizar tus finanzas.` },
  ],
};

const badges: Record<string, string> = { pt: 'App Gratuito', en: 'Free App', es: 'App Gratuita' };
const ctas = ctasByLang[locale] || ctasByLang.pt;
const badge = badges[locale] || badges.pt;
const ctaBtn = config.app.ctaText[locale] || config.app.ctaText.pt;

// Pick a CTA based on seed or random
const index = seed !== undefined ? seed % ctas.length : Math.floor(Math.random() * ctas.length);
const cta = ctas[index];
---

<aside class="cta-variado">
  <span class="cta-variado-eyebrow">{appName} · {badge}</span>
  <h4 class="cta-variado-title">{cta.title}</h4>
  <p class="cta-variado-desc">{cta.desc}</p>
  <a href={appUrl} class="cta-variado-btn" target="_blank" rel="noopener">{ctaBtn}<span class="cta-variado-arrow" aria-hidden="true">→</span></a>
</aside>

<style>
  /* Aparte editorial — parte da leitura, sem cara de banner */
  .cta-variado {
    margin: var(--space-8) 0;
    padding: 1.15rem 1.5rem 1.25rem 1.6rem;
    position: relative;
    border-radius: 0 10px 10px 0;
    background: linear-gradient(90deg,
      color-mix(in srgb, var(--accent-primary) 6%, transparent),
      transparent 62%);
  }

  .cta-variado::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 3px;
    border-radius: 3px;
    background: linear-gradient(180deg, var(--brand-cyan), var(--accent-primary));
  }

  .cta-variado-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 0.55rem;
  }

  .cta-variado-eyebrow::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--brand-cyan);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--brand-cyan) 22%, transparent);
  }

  .cta-variado-title {
    font-size: var(--text-lg);
    color: var(--text-primary);
    letter-spacing: -0.01em;
    margin-bottom: 0.4rem;
    line-height: 1.35;
  }

  .cta-variado-desc {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-bottom: 0.85rem;
    line-height: var(--leading-relaxed);
  }

  .cta-variado-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-link);
    font-weight: 600;
    font-size: var(--text-sm);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
    transition: border-color var(--transition-fast);
  }

  .cta-variado-arrow {
    transition: transform var(--transition-fast);
  }

  .cta-variado-btn:hover {
    border-bottom-color: currentColor;
    color: var(--text-link);
  }

  .cta-variado-btn:hover .cta-variado-arrow {
    transform: translateX(3px);
  }
</style>
