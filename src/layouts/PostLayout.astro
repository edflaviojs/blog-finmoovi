---
import BaseLayout from './BaseLayout.astro';
import { imgSrcset } from '@/utils/responsive-image';
import Header from '@components/header/Header.astro';
import Footer from '@components/footer/Footer.astro';
import Sidebar from '@components/sidebar/Sidebar.astro';
import BannerFinMoovi from '@components/banners/BannerFinMoovi.astro';
import PostInlineCTAs from '@components/banners/PostInlineCTAs.astro';
import ShareButtons from '@components/shared/ShareButtons.astro';
import Breadcrumbs from '@components/shared/Breadcrumbs.astro';
import SchemaBreadcrumb from '@components/seo/SchemaBreadcrumb.astro';
import TableOfContents from '@components/shared/TableOfContents.astro';
import ReadingProgress from '@components/shared/ReadingProgress.astro';
import NewsletterPopup from '@components/shared/NewsletterPopup.astro';
// Giscus desativado (exigia login GitHub — barreira p/ leitor leigo); comentários próprios via Comentarios.astro. O arquivo Giscus.astro e o bloco config.giscus foram mantidos.
import Comentarios from '@components/shared/Comentarios.astro';
import ArticleRating from '@components/shared/ArticleRating.astro';
import RelatedPosts from '@components/posts/RelatedPosts.astro';
import PreferredSourceCTA from '@components/shared/PreferredSourceCTA.astro';
import AdSlot from '@components/home/AdSlot.astro';
import { resolveAuthor, authorHref } from '@/data/authors';
import { config } from '../../site.config';

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  publishedTime?: string;
  updatedTime?: string;
  author?: string;
  keywords?: string[];
  category?: string;
  readingTime?: number;
  headings?: { depth: number; slug: string; text: string }[];
  slug?: string;
  alternates?: { pt?: string; en?: string; es?: string };
}

const { title, description, image, imageAlt, publishedTime, updatedTime, author, keywords, category, readingTime, headings = [], slug, alternates } = Astro.props;
const authorObj = resolveAuthor(author);
const postUrl = new URL(Astro.url.pathname, Astro.site).toString();
const postSlug = Astro.url.pathname.replace(/\//g, '-').replace(/^-|-$/g, '');

// Detect locale from URL
const urlPath = Astro.url.pathname;
let locale = 'pt';
if (urlPath.startsWith('/en/')) locale = 'en';
else if (urlPath.startsWith('/es/')) locale = 'es';

const byLabel = locale === 'en' ? 'By' : 'Por';
const readLabel = locale === 'en' ? 'min read' : locale === 'es' ? 'min de lectura' : 'min de leitura';
const dateLang = locale === 'en' ? 'en-US' : locale === 'es' ? 'es-ES' : 'pt-BR';
const homeHref = locale === 'pt' ? '/' : `/${locale}`;

// "Atualizado em ..." visível quando updatedAt > publishedAt (o gsc-refresh-decay
// atualiza o frontmatter) — sinal de frescor para leitores e IAs generativas.
const updatedLabel = locale === 'en' ? 'Updated on' : locale === 'es' ? 'Actualizado el' : 'Atualizado em';
const showUpdated = !!(updatedTime && publishedTime && new Date(updatedTime).getTime() > new Date(publishedTime).getTime());

const breadcrumbItems = [
  ...(category ? [{ label: category, href: `${homeHref}` }] : []),
  { label: title }
];

const homeLabel = locale === 'en' ? 'Home' : locale === 'es' ? 'Inicio' : 'Início';

// Disclaimer automático em posts de INVESTIMENTOS (3ª camada — as outras são
// a home e o rodapé): entra pelo layout, sem tocar nos markdowns.
const INVEST_DISCLAIMER: Record<string, string> = {
  pt: `⚖️ Conteúdo exclusivamente educativo. O ${config.siteName} não faz recomendações de investimento — cada decisão financeira é pessoal; considere consultar um profissional certificado.`,
  en: `⚖️ Educational content only. ${config.siteName} does not provide investment advice — every financial decision is personal; consider consulting a certified professional.`,
  es: `⚖️ Contenido exclusivamente educativo. ${config.siteName} no hace recomendaciones de inversión — cada decisión financiera es personal; considera consultar a un profesional certificado.`,
};
const investDisclaimer = category === 'investimentos' ? INVEST_DISCLAIMER[locale] : null;
const schemaBreadcrumbItems = [
  { name: homeLabel, url: homeHref },
  ...(category ? [{ name: category, url: homeHref }] : []),
  { name: title, url: Astro.url.pathname }
];
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  type="article"
  publishedTime={publishedTime}
  author={author}
  keywords={keywords}
  alternates={alternates}
  preloadImage={image}
  preloadImageSrcset={image ? imgSrcset(image) : undefined}
  preloadImageSizes="(min-width: 768px) 720px, 100vw"
>
  <ReadingProgress />
  <SchemaBreadcrumb items={schemaBreadcrumbItems} />
  <Header />

  <main class="post-page">
    <div class="container">
      <div class="post-crumbs-wrap">
        <Breadcrumbs items={breadcrumbItems} />
      </div>
      <div class="layout-with-sidebar">
        <article class="post-article" data-pagefind-body>
          <header class="post-header">
            {category && <span class="post-category" data-i18n={`cat.${category}`}>{category}</span>}
            <h1 class="post-title">{title}</h1>
            <div class="post-meta">
              {author && <span class="post-author">{byLabel} <a href={authorHref(authorObj, locale)} rel="author">{authorObj.name}</a></span>}
              {publishedTime && (
                <time datetime={publishedTime}>
                  {new Date(publishedTime).toLocaleDateString(dateLang, { day: '2-digit', month: 'long', year: 'numeric' })}
                </time>
              )}
              {showUpdated && (
                <span class="post-updated">{updatedLabel} <time datetime={updatedTime}>
                  {new Date(updatedTime!).toLocaleDateString(dateLang, { day: '2-digit', month: 'long', year: 'numeric' })}
                </time></span>
              )}
              {readingTime && <span class="post-reading-time">{readingTime} {readLabel}</span>}
            </div>
            <div class="post-share-top">
              <ShareButtons title={title} url={postUrl} />
            </div>
          </header>

          {image && (
            <div class="post-cover">
              <img src={image} srcset={imgSrcset(image)} sizes="(min-width: 768px) 720px, 100vw" alt={imageAlt || title} width="720" height="405" fetchpriority="high" />
            </div>
          )}

          <TableOfContents headings={headings} />

          <div class="post-content">
            <slot />
          </div>

          {investDisclaimer && (
            <p class="post-invest-disclaimer" data-pagefind-ignore>{investDisclaimer}</p>
          )}

          <PostInlineCTAs locale={locale} />

          <!-- Banner promo do meio do artigo: nasce aqui (fora do conteúdo,
               invisível) e o script move para depois do parágrafo do meio em
               posts longos — o markdown/HTML do conteúdo não é alterado. -->
          <div class="promo-mid-src" hidden>
            <AdSlot locale={locale as 'pt' | 'en' | 'es'} variant="strip" />
          </div>

          <div class="post-share-bottom">
            <ShareButtons title={title} url={postUrl} />
          </div>

          <BannerFinMoovi />

          <ArticleRating postSlug={postSlug} />

          <Comentarios locale={locale as 'pt' | 'en' | 'es'} />

          {category && slug && (
            <RelatedPosts currentSlug={slug} category={category} locale={locale} />
          )}

          <PreferredSourceCTA locale={locale} />
        </article>

        <aside class="post-sidebar">
          <Sidebar />
        </aside>
      </div>
    </div>
  </main>

  <NewsletterPopup />
  <Footer />
</BaseLayout>

<script>
  // Rastreador de leitura — alimenta o "Continue lendo" da home.
  // Grava {url, title, progress, ts} no localStorage enquanto o leitor rola;
  // ≥95% = leu tudo → limpa (a home só sugere leituras pela metade).
  const KEY = 'fm-reading';
  let ticking = false;
  function trackReading() {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      ticking = false;
      const h = document.documentElement.scrollHeight - innerHeight;
      if (h <= 0) return;
      const progress = Math.min(1, scrollY / h);
      try {
        if (progress >= 0.95) {
          const cur = JSON.parse(localStorage.getItem(KEY) || 'null');
          if (cur && cur.url === location.pathname) localStorage.removeItem(KEY);
        } else if (progress > 0.05) {
          localStorage.setItem(KEY, JSON.stringify({
            url: location.pathname,
            title: document.querySelector('h1')?.textContent?.trim() || document.title,
            img: document.querySelector<HTMLMetaElement>('meta[property="og:image"]')?.content || '',
            progress,
            ts: Date.now(),
          }));
        }
      } catch (e) { /* sem localStorage → sem rastreio */ }
    });
  }
  addEventListener('scroll', trackReading, { passive: true });

  // Banner promo do meio do artigo (config.ads.mid): só em posts longos
  // (≥8 parágrafos) e nunca colado num CTA inline já injetado.
  const promoSrc = document.querySelector('.promo-mid-src') as HTMLElement | null;
  const postContent = document.querySelector('.post-content');
  if (promoSrc && postContent) {
    const ps = postContent.querySelectorAll(':scope > p');
    if (ps.length >= 8) {
      let anchor: Element = ps[Math.floor(ps.length * 0.55)];
      if (anchor.nextElementSibling?.classList.contains('post-inline-cta')) {
        anchor = anchor.nextElementSibling;
      }
      anchor.after(promoSrc);
      promoSrc.hidden = false;
    }
  }
</script>

<style>
  .post-page {
    padding: var(--space-8) 0 var(--space-16);
  }

  /* Largura revisada p/ o container 1600 do portal: artigo+sidebar centrados
     (antes o conjunto ficava encostado à esquerda com um vão enorme) */
  .post-page .layout-with-sidebar,
  .post-crumbs-wrap {
    max-width: 1220px;
    margin-inline: auto;
  }

  .post-article {
    max-width: 820px;
  }

  .post-invest-disclaimer {
    margin-top: var(--space-8);
    padding: var(--space-4) var(--space-5);
    background: var(--bg-secondary);
    border: 1px solid var(--border-muted);
    border-left: 3px solid #00c8d7;
    border-radius: var(--radius-md);
    color: var(--text-tertiary);
    font-size: var(--text-xs);
    line-height: 1.6;
  }

  .promo-mid-src { margin: var(--space-8) 0; }

  .post-header {
    margin-bottom: var(--space-8);
  }

  .post-category {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    background: rgba(88, 166, 255, 0.1);
    color: var(--accent-primary);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: 500;
    margin-bottom: var(--space-4);
  }

  .post-title {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-4);
    background: var(--gradient-hero);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  @media (min-width: 768px) {
    .post-title {
      font-size: var(--text-5xl);
    }
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    color: var(--text-tertiary);
    font-size: var(--text-sm);
  }

  .post-meta span::before,
  .post-meta time::before {
    content: '·';
    margin-right: var(--space-2);
  }

  .post-meta span:first-child::before {
    content: '';
    margin-right: 0;
  }

  .post-share-top {
    margin-top: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid var(--border-muted);
  }

  .post-share-bottom {
    margin-top: var(--space-8);
    padding: var(--space-6) 0;
    border-top: 1px solid var(--border-muted);
    border-bottom: 1px solid var(--border-muted);
    margin-bottom: var(--space-8);
  }

  .post-cover {
    margin-bottom: var(--space-8);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border-default);
  }

  .post-cover img {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
  }

  .post-sidebar {
    display: none;
  }

  @media (min-width: 1024px) {
    .post-sidebar {
      display: block;
    }
  }
</style>
