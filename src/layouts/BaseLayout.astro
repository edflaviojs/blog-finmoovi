---
import '@/styles/global.css';
import { config } from '../../site.config';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  author?: string;
  keywords?: string[];
  noindex?: boolean;
  alternates?: { pt?: string; en?: string; es?: string };
}

const blogTitle = `${config.brand.name} ${config.brand.blogSuffix}`;

const {
  title,
  description = config.siteDescription.pt,
  image = '/images/og-default.png',
  type = 'website',
  publishedTime,
  author = config.content.defaultAuthor,
  keywords = config.content.defaultKeywords.pt.split(', '),
  noindex = false,
  alternates
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site);
const fullTitle = title === blogTitle ? title : `${title} | ${blogTitle}`;

// i18n: detect current locale and compute base path
const path = Astro.url.pathname;
let currentLocale = 'pt';
let basePath = path;
if (basePath.startsWith('/en/')) { currentLocale = 'en'; basePath = basePath.slice(3); }
else if (basePath.startsWith('/es/')) { currentLocale = 'es'; basePath = basePath.slice(3); }
else if (basePath === '/en') { currentLocale = 'en'; basePath = '/'; }
else if (basePath === '/es') { currentLocale = 'es'; basePath = '/'; }

const htmlLang = currentLocale === 'pt' ? 'pt-BR' : currentLocale === 'es' ? 'es' : 'en';
const hrefPt = new URL(basePath, Astro.site).toString();
const hrefEn = new URL('/en' + (basePath === '/' ? '' : basePath), Astro.site).toString();
const hrefEs = new URL('/es' + (basePath === '/' ? '' : basePath), Astro.site).toString();

// Only emit hreflang for pages that exist in all locales
const hasI18nVersion = alternates || basePath === '/' || basePath === '/glossario' || basePath === '/ferramentas' || basePath === '/sobre';
const finalHrefPt = alternates?.pt ? new URL(alternates.pt, Astro.site).toString() : hrefPt;
const finalHrefEn = alternates?.en ? new URL(alternates.en, Astro.site).toString() : hrefEn;
const finalHrefEs = alternates?.es ? new URL(alternates.es, Astro.site).toString() : hrefEs;
const ogLocale = currentLocale === 'pt' ? 'pt_BR' : currentLocale === 'es' ? 'es_ES' : 'en_US';
---

<!DOCTYPE html>
<html lang={htmlLang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <!-- SEO -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content={keywords.join(', ')} />
  <meta name="author" content={author} />
  <link rel="canonical" href={canonicalURL} />
  {noindex
    ? <meta name="robots" content="noindex, nofollow" />
    : <meta name="robots" content="max-image-preview:large, max-snippet:-1, max-video-preview:-1" />}

  <!-- hreflang -->
  {hasI18nVersion && (
    <>
      <link rel="alternate" hreflang="pt" href={finalHrefPt} />
      <link rel="alternate" hreflang="en" href={finalHrefEn} />
      <link rel="alternate" hreflang="es" href={finalHrefEs} />
      <link rel="alternate" hreflang="x-default" href={finalHrefPt} />
    </>
  )}

  <!-- Open Graph -->
  <meta property="og:type" content={type} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content={blogTitle} />
  <meta property="og:locale" content={ogLocale} />
  {publishedTime && <meta property="article:published_time" content={publishedTime} />}

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Preconnect: Cloudflare Web Analytics (reduz latência do beacon) -->
  <link rel="preconnect" href="https://static.cloudflareinsights.com" crossorigin />

  <!-- Fonts (self-hosted for performance) -->
  <link rel="preload" href="/fonts/inter-latin-400.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/inter-latin-700.woff2" as="font" type="font/woff2" crossorigin />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <!-- RSS -->
  <link rel="alternate" type="application/rss+xml" title={`${blogTitle} (PT)`} href="/rss.xml" />
  <link rel="alternate" type="application/rss+xml" title={`${blogTitle} (EN)`} href="/en/rss.xml" />
  <link rel="alternate" type="application/rss+xml" title={`${blogTitle} (ES)`} href="/es/rss.xml" />

  <!-- PWA -->
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#0d1117" />

  <!-- Organization Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": config.brand.name,
    "url": `https://${config.brand.domains.main}`,
    "logo": `${config.siteUrl}/images/og-default.png`,
    "sameAs": [config.siteUrl],
    "description": config.siteDescription.pt
  })} />

  <!-- Theme (inline para evitar request render-blocking e flash de tema) -->
  <script is:inline>
    (function() {
      var saved = null;
      try { saved = localStorage.getItem('fm-theme'); } catch(e) {}
      var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      var theme = saved || (prefersDark ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);

      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function(e) {
        var hasSaved = false;
        try { hasSaved = !!localStorage.getItem('fm-theme'); } catch(ex) {}
        if (!hasSaved) {
          document.documentElement.setAttribute('data-theme', e.matches ? 'dark' : 'light');
        }
      });
    })();
  </script>
</head>
<body>
  <slot />
  <script is:inline src="/scripts/i18n.js?v=2" defer></script>
  <!-- Cloudflare Web Analytics -->
  {config.analytics.cloudflareBeaconToken && (
    <script is:inline defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon={`{"token": "${config.analytics.cloudflareBeaconToken}"}`}></script>
  )}
</body>
</html>
